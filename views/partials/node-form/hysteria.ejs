                            </div>
                            <div class="form-group">
                                <label for="resolverUdpTimeout"><%= t('nodes.resolverTimeout') %></label>
                                <input type="text" id="resolverUdpTimeout" name="resolver.udp.timeout" value="<%= node?.resolver?.udpTimeout || '4s' %>" placeholder="4s">
                            </div>
                        </div>
                    </div>

                    <div id="resolverTcpFields" style="<%= node?.resolver?.type === 'tcp' ? '' : 'display:none' %>">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="resolverTcpAddr"><%= t('nodes.resolverAddr') %></label>
                                <input type="text" id="resolverTcpAddr" name="resolver.tcp.addr" value="<%= node?.resolver?.tcpAddr || '8.8.8.8:53' %>" placeholder="8.8.8.8:53">
                            </div>
                            <div class="form-group">
                                <label for="resolverTcpTimeout"><%= t('nodes.resolverTimeout') %></label>
                                <input type="text" id="resolverTcpTimeout" name="resolver.tcp.timeout" value="<%= node?.resolver?.tcpTimeout || '4s' %>" placeholder="4s">
                            </div>
                        </div>
                    </div>

                    <div id="resolverTlsFields" style="<%= node?.resolver?.type === 'tls' ? '' : 'display:none' %>">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="resolverTlsAddr"><%= t('nodes.resolverAddr') %></label>
                                <input type="text" id="resolverTlsAddr" name="resolver.tls.addr" value="<%= node?.resolver?.tlsAddr || '1.1.1.1:853' %>" placeholder="1.1.1.1:853">
                            </div>
                            <div class="form-group">
                                <label for="resolverTlsTimeout"><%= t('nodes.resolverTimeout') %></label>
                                <input type="text" id="resolverTlsTimeout" name="resolver.tls.timeout" value="<%= node?.resolver?.tlsTimeout || '10s' %>" placeholder="10s">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="resolverTlsSni"><%= t('nodes.resolverSni') %></label>
                                <input type="text" id="resolverTlsSni" name="resolver.tls.sni" value="<%= node?.resolver?.tlsSni || 'cloudflare-dns.com' %>" placeholder="cloudflare-dns.com">
                            </div>
                            <div class="form-group">
                                <label class="checkbox-label">
                                    <input type="checkbox" name="resolver.tls.insecure" <%= node?.resolver?.tlsInsecure ? 'checked' : '' %>>
                                    <span class="checkbox-text"><%= t('nodes.resolverInsecure') %></span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div id="resolverHttpsFields" style="<%= node?.resolver?.type === 'https' ? '' : 'display:none' %>">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="resolverHttpsAddr"><%= t('nodes.resolverAddr') %></label>
                                <input type="text" id="resolverHttpsAddr" name="resolver.https.addr" value="<%= node?.resolver?.httpsAddr || '1.1.1.1:443' %>" placeholder="1.1.1.1:443">
                            </div>
                            <div class="form-group">
                                <label for="resolverHttpsTimeout"><%= t('nodes.resolverTimeout') %></label>
                                <input type="text" id="resolverHttpsTimeout" name="resolver.https.timeout" value="<%= node?.resolver?.httpsTimeout || '10s' %>" placeholder="10s">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="resolverHttpsSni"><%= t('nodes.resolverSni') %></label>
                                <input type="text" id="resolverHttpsSni" name="resolver.https.sni" value="<%= node?.resolver?.httpsSni || 'cloudflare-dns.com' %>" placeholder="cloudflare-dns.com">
                            </div>
                            <div class="form-group">
