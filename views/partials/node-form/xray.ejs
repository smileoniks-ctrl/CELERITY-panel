            <%# ========== 12. Xray VLESS Settings ========== %>
            <div class="form-section" id="xraySection" style="<%= (node?.type || 'hysteria') !== 'xray' ? 'display:none' : '' %>">
                <h3><img src="/img/xray.svg" alt="Xray" style="width:18px;height:18px;vertical-align:middle;margin-right:8px;"><%= t('nodes.xraySettings') %></h3>

                <div class="form-row">
                    <div class="form-group">
                        <label for="xrayTransport"><%= t('nodes.xrayTransport') %></label>
                        <select id="xrayTransport" name="xray.transport" onchange="updateXrayTransportUI()">
                            <option value="tcp" <%= node?.xray?.transport === 'tcp' || !node?.xray?.transport ? 'selected' : '' %>>TCP</option>
                            <option value="ws" <%= node?.xray?.transport === 'ws' ? 'selected' : '' %>>WebSocket</option>
                            <option value="grpc" <%= node?.xray?.transport === 'grpc' ? 'selected' : '' %>>gRPC</option>
                            <option value="xhttp" <%= node?.xray?.transport === 'xhttp' ? 'selected' : '' %>>XHTTP (SplitHTTP)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="xraySecurity"><%= t('nodes.xraySecurity') %></label>
                        <select id="xraySecurity" name="xray.security" onchange="updateXraySecurityUI()">
                            <option value="reality" <%= node?.xray?.security === 'reality' || !node?.xray?.security ? 'selected' : '' %>><%= t('nodes.xraySecurityReality') %></option>
                            <option value="tls" <%= node?.xray?.security === 'tls' ? 'selected' : '' %>><%= t('nodes.xraySecurityTls') %></option>
                            <option value="none" <%= node?.xray?.security === 'none' ? 'selected' : '' %>><%= t('nodes.xraySecurityNone') %></option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="xrayFingerprint"><%= t('nodes.xrayFingerprint') %></label>
                        <select id="xrayFingerprint" name="xray.fingerprint">
                            <option value="chrome" <%= node?.xray?.fingerprint === 'chrome' || !node?.xray?.fingerprint ? 'selected' : '' %>>Chrome</option>
                            <option value="firefox" <%= node?.xray?.fingerprint === 'firefox' ? 'selected' : '' %>>Firefox</option>
                            <option value="safari" <%= node?.xray?.fingerprint === 'safari' ? 'selected' : '' %>>Safari</option>
                            <option value="ios" <%= node?.xray?.fingerprint === 'ios' ? 'selected' : '' %>>iOS</option>
                            <option value="android" <%= node?.xray?.fingerprint === 'android' ? 'selected' : '' %>>Android</option>
                            <option value="edge" <%= node?.xray?.fingerprint === 'edge' ? 'selected' : '' %>>Edge</option>
                            <option value="random" <%= node?.xray?.fingerprint === 'random' ? 'selected' : '' %>>Random</option>
                            <option value="randomized" <%= node?.xray?.fingerprint === 'randomized' ? 'selected' : '' %>>Randomized</option>
                        </select>
                        <small><%= t('nodes.xrayFingerprintHint') %></small>
                    </div>
                    <div class="form-group" id="alpnGroup" style="<%= node?.xray?.security === 'tls' ? '' : 'display:none' %>">
                        <label for="xrayAlpn"><%= t('nodes.xrayAlpn') %></label>
                        <input type="text" id="xrayAlpn" name="xray.alpn"
                               value="<%= (node?.xray?.alpn || []).join(', ') %>"
                               placeholder="h2, http/1.1">
                        <small><%= t('nodes.xrayAlpnHint') %></small>
                    </div>
                </div>

                <%# Flow — TCP only %>
                <div class="form-group" id="xrayFlowGroup" style="<%= node?.xray?.transport && node.xray.transport !== 'tcp' ? 'display:none' : '' %>">
                    <label for="xrayFlow"><%= t('nodes.xrayFlow') %></label>
                    <input type="text" id="xrayFlow" name="xray.flow" value="<%= node?.xray?.flow || 'xtls-rprx-vision' %>" placeholder="xtls-rprx-vision">
                    <small><%= t('nodes.xrayFlowHint') %></small>
                </div>

                <%# Reality-specific fields %>
                <div id="realityFields" style="<%= node?.xray?.security === 'tls' || node?.xray?.security === 'none' ? 'display:none' : '' %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="xrayRealityDest"><%= t('nodes.xrayRealityDest') %></label>
                            <input type="text" id="xrayRealityDest" name="xray.realityDest"
                                   value="<%= node?.xray?.realityDest || 'www.google.com:443' %>"
                                   placeholder="www.google.com:443">
                            <small><%= t('nodes.xrayRealityDestHint') %></small>
                        </div>
                        <div class="form-group">
                            <label for="xrayRealitySni"><%= t('nodes.xrayRealitySni') %></label>
                            <div class="input-with-button">
                                <input type="text" id="xrayRealitySni" name="xray.realitySni"
                                       value="<%= (node?.xray?.realitySni || ['www.google.com']).join(', ') %>"
                                       placeholder="www.google.com">
                                <button type="button" class="btn btn-sm" id="sniScanOpenBtn"
                                        onclick="openSniScanner()"
                                        title="<%= t('nodes.sniScanTitle') %>">
                                    <i class="ti ti-radar"></i> <%= t('nodes.sniScan') %>
                                </button>
                            </div>
                            <small><%= t('nodes.xrayRealitySniHint') %></small>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="xrayRealityPrivKey"><%= t('nodes.xrayPrivateKey') %></label>
                            <div class="input-with-button">
                                <input type="text" id="xrayRealityPrivKey" name="xray.realityPrivateKey"
                                       value="<%= node?.xray?.realityPrivateKey || '' %>"
                                       placeholder="<%= t('nodes.xrayAutoGenerated') %>">
                                <% if (node) { %>
                                <button type="button" class="btn btn-sm" onclick="generateXrayKeys()" title="<%= t('nodes.xrayGenerateKeys') %>"><i class="ti ti-refresh"></i></button>
                                <% } %>
                            </div>
                            <% if (!node) { %><small><%= t('nodes.xrayAutoGeneratedSetupHint') %></small><% } %>
                        </div>
                        <div class="form-group">
                            <label for="xrayRealityPubKey"><%= t('nodes.xrayPublicKey') %></label>
                            <input type="text" id="xrayRealityPubKey" name="xray.realityPublicKey"
                                   value="<%= node?.xray?.realityPublicKey || '' %>"
                                   placeholder="<%= t('nodes.xrayAutoGenerated') %>" readonly>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="xrayRealityShortIds"><%= t('nodes.xrayShortIds') %></label>
                        <input type="text" id="xrayRealityShortIds" name="xray.realityShortIds"
                               value="<%= (node?.xray?.realityShortIds || ['']).join(', ') %>"
                               placeholder=", 0123456789abcdef">
                        <small><%= t('nodes.xrayShortIdsHint') %></small>
                    </div>
                </div>

                <%# SNI Scanner modal (Reality only) %>
                <div id="sniScanModal" class="sni-modal-overlay" style="display:none" role="dialog" aria-modal="true">
                    <div class="sni-modal-card">
                        <div class="sni-modal-header">
                            <h3><i class="ti ti-radar"></i> <%= t('nodes.sniScanTitle') %></h3>
                            <button type="button" class="sni-modal-close" onclick="closeSniScanner()"><i class="ti ti-x"></i></button>
                        </div>
                        <div class="sni-modal-body">
                            <p class="sni-modal-hint"><%= t('nodes.sniScanHint') %></p>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="sniScanIp"><%= t('nodes.ipAddress') %></label>
                                    <input type="text" id="sniScanIp" placeholder="185.100.200.1" autocomplete="off">
                                </div>
                                <div class="form-group" style="max-width:100px">
                                    <label for="sniScanPort"><%= t('nodes.sniScanPortLabel') %></label>
                                    <input type="number" id="sniScanPort" value="443" min="1" max="65535">
                                </div>
                                <div class="form-group" style="max-width:110px">
                                    <label for="sniScanThreads"><%= t('nodes.sniScanThreads') %></label>
                                    <input type="number" id="sniScanThreads" value="50" min="1" max="200">
                                </div>
                                <div class="form-group" style="max-width:110px">
                                    <label for="sniScanTimeout"><%= t('nodes.sniScanTimeout') %></label>
                                    <input type="number" id="sniScanTimeout" value="5" min="2" max="30">
                                </div>
                            </div>
                            <div class="sni-scan-controls">
                                <button type="button" class="btn btn-primary" id="sniScanStartBtn" onclick="startSniScan()">
                                    <i class="ti ti-player-play"></i> <%= t('nodes.sniScanStart') %>
                                </button>
                                <button type="button" class="btn" id="sniScanStopBtn" onclick="stopSniScan()" style="display:none">
                                    <i class="ti ti-player-stop"></i> <%= t('nodes.sniScanStop') %>
                                </button>
                                <span id="sniScanStatus" class="sni-scan-status"></span>
                            </div>
                            <div id="sniScanProgressWrap" style="display:none">
                                <div class="sni-progress-bar"><div id="sniScanProgressFill" class="sni-progress-fill" style="width:0%"></div></div>
                            </div>
                            <div id="sniScanResults" style="display:none">
                                <div class="sni-results-header">
                                    <span class="sni-results-title"><%= t('nodes.sniScanResults') %></span>
                                    <span id="sniScanCount" class="sni-results-count"></span>
                                </div>
                                <div class="sni-table-wrap">
                                    <table class="sni-table">
                                        <thead>
                                            <tr>
                                                <th><%= t('nodes.sniScanPing') %></th>
                                                <th><%= t('nodes.sniScanDomain') %></th>
                                                <th><%= t('nodes.sniScanIssuer') %></th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody id="sniScanTableBody"></tbody>
                                    </table>
                                </div>
                            </div>
                            <div id="sniScanEmpty" style="display:none" class="sni-empty"><%= t('nodes.sniScanNoResults') %></div>
                        </div>
                    </div>
                </div>

                <%# WebSocket-specific fields %>
                <div id="wsFields" style="<%= node?.xray?.transport === 'ws' ? '' : 'display:none' %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="xrayWsPath"><%= t('nodes.xrayWsPath') %></label>
                            <input type="text" id="xrayWsPath" name="xray.wsPath"
                                   value="<%= node?.xray?.wsPath || '/' %>" placeholder="/">
                        </div>
                        <div class="form-group">
                            <label for="xrayWsHost"><%= t('nodes.xrayWsHost') %></label>
                            <input type="text" id="xrayWsHost" name="xray.wsHost"
                                   value="<%= node?.xray?.wsHost || '' %>" placeholder="cdn.example.com">
                            <small><%= t('nodes.xrayWsHostHint') %></small>
                        </div>
                    </div>
                </div>

                <%# gRPC-specific fields %>
                <div id="grpcFields" style="<%= node?.xray?.transport === 'grpc' ? '' : 'display:none' %>">
                    <div class="form-group">
                        <label for="xrayGrpcService"><%= t('nodes.xrayGrpcService') %></label>
                        <input type="text" id="xrayGrpcService" name="xray.grpcServiceName"
                               value="<%= node?.xray?.grpcServiceName || 'grpc' %>" placeholder="grpc">
                    </div>
                </div>

                <%# XHTTP (SplitHTTP) specific fields %>
                <div id="xhttpFields" style="<%= node?.xray?.transport === 'xhttp' ? '' : 'display:none' %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="xrayXhttpPath"><%= t('nodes.xrayXhttpPath') %></label>
                            <input type="text" id="xrayXhttpPath" name="xray.xhttpPath"
                                   value="<%= node?.xray?.xhttpPath || '/' %>" placeholder="/">
                        </div>
                        <div class="form-group">
                            <label for="xrayXhttpHost"><%= t('nodes.xrayXhttpHost') %></label>
                            <input type="text" id="xrayXhttpHost" name="xray.xhttpHost"
                                   value="<%= node?.xray?.xhttpHost || '' %>" placeholder="cdn.example.com">
                            <small><%= t('nodes.xrayXhttpHostHint') %></small>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="xrayXhttpMode"><%= t('nodes.xrayXhttpMode') %></label>
                        <select id="xrayXhttpMode" name="xray.xhttpMode">
                            <option value="auto" <%= node?.xray?.xhttpMode === 'auto' || !node?.xray?.xhttpMode ? 'selected' : '' %>>Auto</option>
                            <option value="packet-up" <%= node?.xray?.xhttpMode === 'packet-up' ? 'selected' : '' %>>Packet Up</option>
                            <option value="stream-up" <%= node?.xray?.xhttpMode === 'stream-up' ? 'selected' : '' %>>Stream Up</option>
                        </select>
                        <small><%= t('nodes.xrayXhttpModeHint') %></small>
                    </div>
                </div>

                <div class="form-group">
                    <label for="xrayApiPort"><%= t('nodes.xrayApiPort') %></label>
                    <input type="number" id="xrayApiPort" name="xray.apiPort"
                           value="<%= node?.xray?.apiPort || 61000 %>" placeholder="61000">
                    <small><%= t('nodes.xrayApiPortHint') %></small>
                </div>
            </div>
