// Lightweight client-side PEM check; authoritative validation happens
// server-side. Backreference forces matching BEGIN/END prefixes.
const _PEM_CERT_RE = /-----BEGIN CERTIFICATE-----[\s\S]+?-----END CERTIFICATE-----/;
const _PEM_KEY_RE = /-----BEGIN (RSA |EC |ECDSA |)PRIVATE KEY-----[\s\S]+?-----END \1PRIVATE KEY-----/;
const _MANUAL_KEY_PLACEHOLDER = '***SET***';
// Localized labels are injected at render time so the inline status string
// matches the operator's language without round-tripping through any global
// translation cache (which is server-only in this template).
const _PEM_LABELS = {
    valid:   <%- JSON.stringify(t('nodes.xrayPemValid'))   %>,
    invalid: <%- JSON.stringify(t('nodes.xrayPemInvalid')) %>,
    stored:  <%- JSON.stringify(t('nodes.xrayPemStored'))  %>,
};

function validateXrayPemField(textarea, kind) {
    if (!textarea) return;
    const status = document.getElementById(textarea.getAttribute('aria-describedby'));
    if (!status) return;
    const value = (textarea.value || '').trim();
    if (!value) {
        status.textContent = '';
        status.classList.remove('is-valid', 'is-invalid');
        return;
    }
    if (kind === 'key' && value === _MANUAL_KEY_PLACEHOLDER) {
        status.textContent = _PEM_LABELS.stored;
        status.classList.remove('is-invalid');
        status.classList.add('is-valid');
        return;
    }
    const ok = (kind === 'cert' ? _PEM_CERT_RE : _PEM_KEY_RE).test(value);
    status.textContent = ok ? _PEM_LABELS.valid : _PEM_LABELS.invalid;
    status.classList.toggle('is-valid', ok);
    status.classList.toggle('is-invalid', !ok);
}

// When the operator clicks into the masked manualKey textarea the first time,
// clear the ***SET*** placeholder so they can paste a replacement. If they
// blur without entering anything, restore the placeholder so the form submit
// continues to mean "keep the stored key".
function onXrayManualKeyFocus(textarea) {
    if (!textarea) return;
    const stored = textarea.getAttribute('data-has-stored-key') === '1';
    if (!stored) return;
    if ((textarea.value || '').trim() === _MANUAL_KEY_PLACEHOLDER) {
        textarea.value = '';
        // One-shot restore handler — re-attach a blur listener that runs once.
        const restore = function() {
            if ((textarea.value || '').trim() === '') {
                textarea.value = _MANUAL_KEY_PLACEHOLDER;
                validateXrayPemField(textarea, 'key');
            }
            textarea.removeEventListener('blur', restore);
        };
        textarea.addEventListener('blur', restore);
    }
}

