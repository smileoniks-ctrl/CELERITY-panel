// ── SNI Scanner ───────────────────────────────────────────────────────────────

const sniI18n = {
    scanning:   <%- JSON.stringify(t('nodes.sniScanScanning'))   %>,
    verifying:  <%- JSON.stringify(t('nodes.sniScanVerifying'))  %>,
    found:      <%- JSON.stringify(t('nodes.sniScanFound'))      %>,
    done:       <%- JSON.stringify(t('nodes.sniScanDone'))       %>,
    noResults:  <%- JSON.stringify(t('nodes.sniScanNoResults'))  %>,
    errInvalidIp: <%- JSON.stringify(t('nodes.sniScanErrIp'))   %>,
};

let _sniReader = null; // active SSE reader (for cancellation)

function openSniScanner() {
    const modal = document.getElementById('sniScanModal');
    if (!modal) return;
    // Pre-fill IP from the node IP field
    const nodeIp = (document.getElementById('ip')?.value || '').trim();
    const ipInput = document.getElementById('sniScanIp');
    if (ipInput && nodeIp) ipInput.value = nodeIp;
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeSniScanner() {
    stopSniScan();
    const modal = document.getElementById('sniScanModal');
    if (modal) modal.style.display = 'none';
    document.body.style.overflow = '';
}

// Close on overlay click
document.getElementById('sniScanModal')?.addEventListener('click', function(e) {
    if (e.target === this) closeSniScanner();
});

// Delegated handler for "Apply" buttons in results table
document.getElementById('sniScanTableBody')?.addEventListener('click', function(e) {
    const btn = e.target.closest('.sni-apply-btn');
    if (btn) applySniResult(btn.dataset.domain);
});

function _sniSetStatus(msg) {
    const el = document.getElementById('sniScanStatus');
    if (el) el.textContent = msg;
}

function _sniSetProgress(done, total) {
    const fill = document.getElementById('sniScanProgressFill');
    if (fill) fill.style.width = (total > 0 ? Math.round(done / total * 100) : 0) + '%';
}

function _sniPingClass(ping) {
    if (ping <= 20) return 'sni-ping-fast';
    if (ping <= 60) return 'sni-ping-mid';
    return 'sni-ping-slow';
}

function _sniAddRow(result) {
    const tbody = document.getElementById('sniScanTableBody');
    if (!tbody) return;

    // Insert in sorted order by ping (table is sorted ascending)
    const rows = tbody.querySelectorAll('tr');
    const newPing = result.ping;
    let insertBefore = null;
    for (const row of rows) {
        if (parseInt(row.dataset.ping, 10) > newPing) { insertBefore = row; break; }
    }

    const scanSubnet = (document.getElementById('sniScanIp')?.value || '').split('.').slice(0,3).join('.');
    const ipSubnet   = (result.ip || '').split('.').slice(0,3).join('.');
    const isNeighbor = scanSubnet && ipSubnet && scanSubnet === ipSubnet;
    const ipBadge    = isNeighbor
        ? `<span class="sni-ip-neighbor" title="<%- t('nodes.sniScanNeighborHint') %>">${_escHtml(result.ip)}</span>`
        : `<span class="sni-ip-other"    title="<%- t('nodes.sniScanOtherHint') %>">${_escHtml(result.ip)}</span>`;

    const tr = document.createElement('tr');
    tr.dataset.ping = newPing;
    tr.innerHTML = `
        <td><span class="${_sniPingClass(newPing)}">${newPing}ms</span></td>
        <td class="sni-domain">${_escHtml(result.domain)}</td>
        <td>${ipBadge}</td>
        <td><span class="sni-issuer" title="${_escHtml(result.issuer)}">${_escHtml(result.issuer)}</span></td>
        <td style="text-align:center"><button type="button" class="btn btn-sm btn-primary sni-apply-btn"
                    data-domain="${_escHtml(result.domain)}"
                    title="<%- t('nodes.sniScanApply') %>">
            <i class="ti ti-check"></i>
        </button></td>`;

    if (insertBefore) tbody.insertBefore(tr, insertBefore);
    else tbody.appendChild(tr);

    // Update count badge
    const count = tbody.querySelectorAll('tr').length;
    const badge = document.getElementById('sniScanCount');
    if (badge) badge.textContent = `${count} ${sniI18n.found}`;
}

function _escHtml(s) {
    return String(s || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

async function startSniScan() {
    const ip      = (document.getElementById('sniScanIp')?.value      || '').trim();
    const port    = parseInt(document.getElementById('sniScanPort')?.value    || '443', 10);
    const threads = parseInt(document.getElementById('sniScanThreads')?.value || '50',  10);
    const timeout = parseInt(document.getElementById('sniScanTimeout')?.value || '5',   10);

    if (!/^(\d{1,3}\.){3}\d{1,3}$/.test(ip)) {
        _sniSetStatus(sniI18n.errInvalidIp);
        return;
    }

    // Reset UI
    document.getElementById('sniScanTableBody').innerHTML = '';
    document.getElementById('sniScanResults').style.display = 'none';
    document.getElementById('sniScanEmpty').style.display   = 'none';
    document.getElementById('sniScanProgressWrap').style.display = '';
    document.getElementById('sniScanStartBtn').style.display  = 'none';
    document.getElementById('sniScanStopBtn').style.display   = '';
    document.getElementById('sniScanCount').textContent = '';
    _sniSetProgress(0, 1);
    _sniSetStatus(sniI18n.scanning);

    try {
        const response = await fetch('/panel/nodes/scan-sni', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ip, port, threads, timeout }),
            credentials: 'include',
        });

        if (!response.ok) {
            const err = await response.json().catch(() => ({}));
            _sniSetStatus((err.error || 'Scan failed'));
            _resetSniButtons();
            return;
        }

        const reader = response.body.getReader();
        _sniReader = reader;
        const decoder = new TextDecoder();
        let buffer = '';
        let foundAny = false;

        while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            buffer += decoder.decode(value, { stream: true });

            const lines = buffer.split('\n');
            buffer = lines.pop(); // keep incomplete trailing line

            for (const line of lines) {
                if (!line.startsWith('data: ')) continue;
                let evt;
                try { evt = JSON.parse(line.slice(6)); } catch { continue; }

                if (evt.type === 'verifying') {
                    _sniSetStatus(sniI18n.verifying);
                } else if (evt.type === 'progress') {
                    _sniSetProgress(evt.done, evt.total);
                    _sniSetStatus(`${sniI18n.scanning} ${evt.done}/${evt.total}`);
                } else if (evt.type === 'result') {
                    foundAny = true;
                    document.getElementById('sniScanResults').style.display = '';
                    _sniAddRow(evt);
                } else if (evt.type === 'done') {
                    _sniSetProgress(1, 1);
                    const count = document.getElementById('sniScanTableBody').querySelectorAll('tr').length;
                    _sniSetStatus(`${sniI18n.done} — ${count} ${sniI18n.found}`);
                    if (!foundAny) document.getElementById('sniScanEmpty').style.display = '';
                } else if (evt.type === 'error') {
                    _sniSetStatus(evt.message || 'Scan error');
                }
            }
        }
    } catch (err) {
        if (err.name !== 'AbortError') _sniSetStatus(err.message);
    } finally {
        _sniReader = null;
        _resetSniButtons();
    }
}

function stopSniScan() {
    if (_sniReader) { _sniReader.cancel(); _sniReader = null; }
    _resetSniButtons();
}

function _resetSniButtons() {
    document.getElementById('sniScanStartBtn').style.display = '';
    document.getElementById('sniScanStopBtn').style.display  = 'none';
}

function applySniResult(domain) {
    const destInput = document.getElementById('xrayRealityDest');
    const sniInput  = document.getElementById('xrayRealitySni');
    if (destInput) destInput.value = `${domain}:443`;
    if (sniInput)  sniInput.value  = domain;
    closeSniScanner();
}
</script>
