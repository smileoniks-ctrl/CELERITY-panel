// Pick the next free port for a new extra inbound. Defaults follow the
// well-known TLS ports clients usually accept on restrictive networks.
function nextFreeXrayPort() {
    const taken = new Set();
    const mainPort = parseInt(document.getElementById('port')?.value || '443', 10);
    if (Number.isFinite(mainPort)) taken.add(mainPort);
    const apiPort = parseInt(document.getElementById('xrayApiPort')?.value || '0', 10);
    if (Number.isFinite(apiPort) && apiPort > 0) taken.add(apiPort);
    if (Number.isFinite(XRAY_AGENT_PORT) && XRAY_AGENT_PORT > 0) taken.add(XRAY_AGENT_PORT);
    document.querySelectorAll('input[name="xray_extra_port"]').forEach(input => {
        const p = parseInt(input.value, 10);
        if (Number.isFinite(p) && p > 0) taken.add(p);
    });
    const candidates = [8443, 2053, 2083, 2087, 2096, 8080, 8880];
    for (const c of candidates) {
        if (!taken.has(c)) return c;
    }
    let p = 10000;
    while (taken.has(p) && p < 65535) p++;
    return p;
}

// Compute the next default tag like vless-extra-N where N is the smallest
// integer not yet used. Keeps tags stable when adding/removing inbounds.
function nextFreeXrayTag() {
    const taken = new Set();
    document.querySelectorAll('input[name="xray_extra_inboundTag"]').forEach(input => {
        const m = String(input.value || '').match(/^vless-extra-(\d+)$/);
        if (m) taken.add(parseInt(m[1], 10));
    });
    let n = 1;
    while (taken.has(n)) n++;
    return `vless-extra-${n}`;
}

// Add a new extra inbound by cloning the structure of an existing card or
// building one from scratch. Uses a hidden <template> populated below.
function addExtraInbound() {
    const container = document.getElementById('extraInboundsContainer');
    if (!container) return;

    const port = nextFreeXrayPort();
    const tag = nextFreeXrayTag();
    const id = (window.crypto && window.crypto.randomUUID)
        ? window.crypto.randomUUID()
        : 'extra-' + Date.now() + '-' + Math.random().toString(16).slice(2);

    const tpl = document.getElementById('extraInboundTemplate');
    if (!tpl) return;
    const node = tpl.content.cloneNode(true);
    const root = node.querySelector('details');
    root.dataset.extraIdx = String(container.children.length);

    root.querySelector('input[name="xray_extra_id"]').value = id;
    root.querySelector('input[name="xray_extra_port"]').value = port;
    root.querySelector('input[name="xray_extra_inboundTag"]').value = tag;
    // Keep unique-name checkbox value in sync with the row id (the parser
    // identifies checked rows by id, since unchecked checkboxes are not sent).
    const uniqueNameCb = root.querySelector('input[name="xray_extra_uniqueName"]');
    if (uniqueNameCb) {
        uniqueNameCb.value = id;
        uniqueNameCb.checked = false;
    }

    const titleSpan = root.querySelector('.extra-inbound-title');
    if (titleSpan) titleSpan.textContent = (i18n.xrayExtraInbound || 'Extra inbound') + ' #' + (container.children.length + 1);
    const summarySpan = root.querySelector('.extra-inbound-summary');
    if (summarySpan) summarySpan.textContent = 'TCP / reality : ' + port;

    root.open = true;
    container.appendChild(node);
    checkXrayPortConflict();
    if (typeof updateXraySecurityUI === 'function') updateXraySecurityUI();
}

