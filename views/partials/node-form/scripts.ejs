<style>
.proto-switcher {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 8px;
}
.proto-option {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border: 2px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    position: relative;
}
.proto-option input[type="radio"] { position: absolute; opacity: 0; pointer-events: none; }
.proto-option:hover { border-color: var(--accent); background: var(--accent-glow); }
.proto-option.active { border-color: var(--accent); background: var(--accent-glow); }
.proto-icon { font-size: 22px; }
.proto-name { font-weight: 600; font-size: 14px; }
.proto-desc { font-size: 11px; color: var(--text-muted); }
.section-subtitle {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.code-textarea {
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 15px;
    width: 100%;
    resize: vertical;
    line-height: 1.5;
}
.code-textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-glow);
}

.code-block-wrap {
    position: relative;
    margin-top: 10px;
}
.code-block {
    margin: 0;
    padding: 14px;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    line-height: 1.5;
    overflow: auto;
    white-space: pre;
}
.config-copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 11px;
    cursor: pointer;
    color: var(--text-muted);
}
.config-copy-btn.is-copied {
    color: var(--success);
    border-color: var(--success);
}
.config-hint {
    margin-bottom: 0;
}
.input-with-button {
    display: flex;
    gap: 8px;
    align-items: center;
}
.input-with-button input { flex: 1; }
.input-with-button .btn { white-space: nowrap; flex-shrink: 0; }

.ssh-warning {
    background: var(--warning-bg);
    border: 1px solid var(--warning);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    margin-bottom: 16px;
    color: var(--warning);
    display: flex;
    align-items: center;
    gap: 10px;
}
.ssh-warning-icon { font-size: 20px; }

.node-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
}
.node-info-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
}
.node-info-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.node-info-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
}
.logs-output {
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--glass-border);
    color: #4ade80;
    padding: 15px;
    border-radius: var(--radius-sm);
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    max-height: 500px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
    margin-top: 10px;
}
.logs-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.logs-output .error { color: #ff6b6b; }
.logs-output .success { color: #51cf66; }
.logs-output .warning { color: #ffd43b; }
.form-group.is-inactive {
    opacity: 0.55;
}

@media (max-width: 640px) {
    .form-row-3 { grid-template-columns: 1fr; }
}

.node-advanced-details {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 16px;
    background: var(--bg-secondary);
}
.node-advanced-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    color: var(--text-secondary);
    user-select: none;
    list-style: none;
    gap: 8px;
}
.node-advanced-summary::-webkit-details-marker { display: none; }
.node-advanced-summary:hover { color: var(--text-primary); }
.node-advanced-summary span { display: flex; align-items: center; gap: 8px; }
.node-advanced-chevron {
    transition: transform 0.2s;
    font-size: 16px;
    flex-shrink: 0;
}
.node-advanced-details[open] .node-advanced-chevron {
    transform: rotate(180deg);
}
.node-advanced-details > .form-section {
    border-top: 1px solid var(--border);
    border-radius: 0;
    margin-bottom: 0;
    margin-top: 0;
    padding: 20px 20px 16px;
    background: transparent;
}
.node-advanced-details > .form-section:last-of-type {
    border-bottom-left-radius: var(--radius);
    border-bottom-right-radius: var(--radius);
}

/* ── Extra Xray inbounds ── */
.extra-inbounds-section {
    margin-top: 24px;
    padding-top: 18px;
    border-top: 1px dashed var(--border);
}
.extra-inbounds-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 12px;
}
.extra-inbounds-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
}
.extra-inbounds-hint {
    color: var(--text-muted);
    font-size: 12px;
    display: block;
    margin-top: 4px;
}
.extra-inbound-card { margin-bottom: 12px; }
.extra-inbound-card .extra-inbound-summary {
    margin-left: 8px;
    padding: 2px 8px;
    border-radius: 10px;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2px;
}
.extra-inbound-card .extra-inbound-title {
    color: var(--text-primary);
    font-weight: 600;
}
.input-error {
    border-color: var(--error, #ff6b6b) !important;
    box-shadow: 0 0 0 3px rgba(255, 107, 107, 0.15);
}

/* ── SNI Scanner modal ── */
.sni-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(8, 8, 10, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 9000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 40px 16px 16px;
    overflow-y: auto;
}
.sni-modal-card {
    background: var(--glass-bg-strong, rgba(28, 28, 32, 0.78));
    border: 1px solid var(--glass-border-strong, rgba(255, 255, 255, 0.1));
    border-radius: var(--radius);
    backdrop-filter: var(--glass-blur, blur(20px));
    -webkit-backdrop-filter: var(--glass-blur, blur(20px));
    box-shadow: var(--glass-shadow-lg, 0 24px 64px rgba(0, 0, 0, 0.5));
    width: min(820px, 100%);
    display: flex;
    flex-direction: column;
    box-shadow: 0 32px 80px rgba(0,0,0,.6);
    margin: auto;
}
.sni-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 22px 14px;
    border-bottom: 1px solid var(--glass-border, var(--border));
    flex-shrink: 0;
}
.sni-modal-header h3 {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
}
.sni-modal-body {
    padding: 20px 22px 22px;
}
.sni-modal-hint {
    font-size: 12px;
    color: var(--text-muted);
    margin: 0 0 16px;
    line-height: 1.5;
}
/* 2-row params grid */
.sni-params {
    display: grid;
    grid-template-columns: 1fr 100px;
    gap: 12px;
    margin-bottom: 14px;
}
.sni-params-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr 160px;
    gap: 12px;
    margin-bottom: 14px;
}
.sni-scan-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}
.sni-scan-status {
    font-size: 12px;
    color: var(--text-muted);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.sni-progress-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 16px;
}
.sni-progress-fill {
    height: 100%;
    background: var(--accent);
    transition: width .1s linear;
}
.sni-results-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
}
.sni-results-title { font-weight: 600; font-size: 13px; }
.sni-results-count {
    font-size: 12px;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1px 8px;
}
.sni-table-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    max-height: 360px;
    overflow-y: auto;
    overflow-x: hidden;
}
.sni-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    table-layout: fixed;
}
.sni-table th {
    position: sticky;
    top: 0;
    background: var(--bg-secondary);
    padding: 8px 12px;
    text-align: left;
    font-weight: 600;
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .5px;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
}
.sni-table td {
    padding: 9px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.sni-table tr:last-child td { border-bottom: none; }
.sni-table tr:hover td { background: var(--accent-glow); }
/* Column widths */
.sni-table th:nth-child(1), .sni-table td:nth-child(1) { width: 72px; }   /* Ping   */
.sni-table th:nth-child(2), .sni-table td:nth-child(2) { width: auto; }    /* Domain */
.sni-table th:nth-child(3), .sni-table td:nth-child(3) { width: 140px; }  /* IP     */
.sni-table th:nth-child(4), .sni-table td:nth-child(4) { width: 130px; }  /* Issuer */
.sni-table th:nth-child(5), .sni-table td:nth-child(5) { width: 48px; text-align:center; } /* Apply */
.sni-ping-fast  { color: var(--success); font-weight: 600; }
.sni-ping-mid   { color: var(--warning); font-weight: 600; }
.sni-ping-slow  { color: var(--text-muted); }
.sni-domain     { font-weight: 500; }
.sni-issuer     { font-size: 11px; color: var(--text-muted); }
.sni-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
    padding: 28px 0;
}
.sni-ip-neighbor {
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--success);
}
.sni-ip-other {
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-muted);
}
.sni-apply-btn {
    padding: 5px 8px !important;
    font-size: 16px !important;
    line-height: 1;
}
.sni-modal-close {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px 6px;
    border-radius: 6px;
    font-size: 18px;
    transition: color .15s;
    line-height: 1;
}
.sni-modal-close:hover { color: var(--text-primary); }
</style>

<script>
const nodeType = '<%= node?.type || "hysteria" %>';
const lastInitScript = <%- JSON.stringify(lastInitScript || '').replace(/</g, '\\u003c') %>;
const i18n = {
    autoSetupConfirm: <%- JSON.stringify(t("nodes.autoSetupConfirm")) %>,
    autoSetupConfirmXray: <%- JSON.stringify(t("nodes.autoSetupConfirmXray")) %>,
    setupRunning: <%- JSON.stringify(t("nodes.setupRunning")) %>,
    loadingLogs: <%- JSON.stringify(t("nodes.loadingLogs")) %>,
    checking: <%- JSON.stringify(t("nodes.checking")) %>,
    resettingStatus: <%- JSON.stringify(t("nodes.resettingStatus")) %>,
    statusReset: <%- JSON.stringify(t("nodes.statusReset")) %>,
    autoSetup: <%- JSON.stringify(t("nodes.autoSetup")) %>,
    error: <%- JSON.stringify(t("common.error")) %>,
    confirmDeployCascade: <%- JSON.stringify(t("nodes.confirmDeployCascade")) %>,
    confirmUndeployCascade: <%- JSON.stringify(t("nodes.confirmUndeployCascade")) %>,
    confirmDeleteCascade: <%- JSON.stringify(t("nodes.confirmDeleteCascade")) %>,
    xrayGenerateKeysConfirm: <%- JSON.stringify(t("nodes.xrayGenerateKeysConfirm")) %>,
    xrayKeysSuccess: <%- JSON.stringify(t("nodes.xrayKeysSuccess")) %>
};
const i18nConfig = {
    copied: <%- JSON.stringify(t("common.copied")) %>,
    loadConfigConfirm: <%- JSON.stringify(t("nodes.loadConfigConfirm")) %>,
    configLoaded: <%- JSON.stringify(t("nodes.configLoaded")) %>,
    saveFirst: <%- JSON.stringify(t("nodes.saveFirst")) %>,
    error: <%- JSON.stringify(t("common.error")) %>,
    baseUrl: <%- JSON.stringify(baseUrl) %>
};

// ==================== Protocol switcher ====================

const PANEL_DOMAIN = '<%= panelDomain %>';

// Agent port is not exposed in the form, but we still need it in the
// conflict set so a default extra port never lands on the agent socket.
// Declared here so checkXrayPortConflict (below) sees it without TDZ risk.
const XRAY_AGENT_PORT = <%- JSON.stringify(node?.xray?.agentPort || 62080) %>;

function checkXrayPortConflict() {
    const warn = document.getElementById('xrayPortConflictWarn');
    const proto = document.querySelector('input[name="type"]:checked')?.value || 'hysteria';
    const ip = (document.getElementById('ip')?.value || '').trim().toLowerCase();
    const port = parseInt(document.getElementById('port')?.value || '443', 10);
    const panelHostname = PANEL_DOMAIN.split(':')[0].toLowerCase();
    const isSameServer = ip === 'localhost' || ip === '127.0.0.1' || ip === '::1' || ip === panelHostname;
    const isConflictPort = port === 443 || port === 80;
    if (warn) {
        warn.style.display = (proto === 'xray' && isSameServer && isConflictPort) ? '' : 'none';
    }

    // Flag duplicates among main port, API port, agent port and extras.
    const apiPort = parseInt(document.getElementById('xrayApiPort')?.value || '0', 10);
    const counts = new Map();
    const bump = (p) => {
        if (Number.isFinite(p) && p > 0) counts.set(p, (counts.get(p) || 0) + 1);
    };
    bump(port);
    bump(apiPort);
    bump(XRAY_AGENT_PORT);
    document.querySelectorAll('input[name="xray_extra_port"]').forEach(input => {
        const inputPort = parseInt(input.value, 10);
        bump(inputPort);
        const card = input.closest('details.extra-inbound-card');
        if (card) {
            // Mark dup ports with an outline; also mark tag duplicates below.
            const isDup = Number.isFinite(inputPort) && (counts.get(inputPort) || 0) > 1;
            input.classList.toggle('input-error', isDup);
        }
    });

    const tagCounts = new Map();
    // JSON.stringify guarantees a valid JS string literal even when the tag
    // contains special characters (defense-in-depth — the schema pattern
    // already restricts tags, but never trust render context).
    const mainTag = <%- JSON.stringify(node?.xray?.inboundTag || 'vless-in') %>;
    tagCounts.set(mainTag, 1);
    document.querySelectorAll('input[name="xray_extra_inboundTag"]').forEach(input => {
        const v = (input.value || '').trim();
        if (v) tagCounts.set(v, (tagCounts.get(v) || 0) + 1);
    });
    document.querySelectorAll('input[name="xray_extra_inboundTag"]').forEach(input => {
        const v = (input.value || '').trim();
        const isDup = !!v && (tagCounts.get(v) || 0) > 1;
        input.classList.toggle('input-error', isDup);
    });
}

function switchProto(proto) {
    const xraySection = document.getElementById('xraySection');
    const virtualSection = document.getElementById('virtualSection');
    const cascadeSection = document.getElementById('cascadeRoleSection');
    const labelHysteria = document.getElementById('protoHysteriaLabel');
    const labelXray = document.getElementById('protoXrayLabel');
    const labelVirtual = document.getElementById('protoVirtualLabel');
    const hysteriaOnlyEls = document.querySelectorAll('.hysteria-only');
    const ipFormGroup = document.getElementById('ipFormGroup');
    const ipInput = document.getElementById('ip');

    [labelHysteria, labelXray, labelVirtual].forEach(l => l && l.classList.remove('active'));

    if (proto === 'virtual') {
        if (xraySection) xraySection.style.display = 'none';
        if (cascadeSection) cascadeSection.style.display = 'none';
        if (virtualSection) virtualSection.style.display = '';
        if (labelVirtual) labelVirtual.classList.add('active');
        hysteriaOnlyEls.forEach(el => el.style.display = 'none');
        // Hide everything except: protocol switcher, identification, groups, virtual section.
        document.querySelectorAll('.form-section').forEach(sec => {
            if (sec.id === 'virtualSection') return;
            if (sec.querySelector('.proto-switcher')) return;
            if (sec.querySelector('input[name="groups"]')) return;
            sec.classList.add('virtual-hidden');
            sec.style.display = 'none';
        });
        // Non-form-section elements that don't belong on virtual nodes
        // (init-script <details>, ad-hoc cards, etc.). The .non-virtual-only
        // class is the canonical marker — server-side renders the same
        // state via inline `display:none`.
        document.querySelectorAll('.non-virtual-only').forEach(el => {
            el.classList.add('virtual-hidden');
            el.style.display = 'none';
        });
        if (ipFormGroup) ipFormGroup.style.display = 'none';
        if (ipInput) ipInput.removeAttribute('required');
        checkXrayPortConflict();
        return;
    }

    // Restore everything hidden by 'virtual'.
    if (virtualSection) virtualSection.style.display = 'none';
    document.querySelectorAll('.form-section.virtual-hidden, .non-virtual-only.virtual-hidden').forEach(sec => {
        sec.style.display = '';
        sec.classList.remove('virtual-hidden');
    });
    if (ipFormGroup) ipFormGroup.style.display = '';
    if (ipInput) ipInput.setAttribute('required', 'required');

    if (proto === 'xray') {
        xraySection.style.display = '';
        if (cascadeSection) cascadeSection.style.display = '';
        if (labelXray) labelXray.classList.add('active');
        hysteriaOnlyEls.forEach(el => el.style.display = 'none');
        onCascadeRoleChange();
        // Domain group is shared (no longer .hysteria-only). Its visibility
        // depends on the current Xray TLS source — defer to updateXrayTlsSourceUI.
        updateXrayTlsSourceUI();
    } else {
        xraySection.style.display = 'none';
        if (cascadeSection) cascadeSection.style.display = 'none';
        if (labelHysteria) labelHysteria.classList.add('active');
        hysteriaOnlyEls.forEach(el => el.style.display = '');
        toggleAcmeByDomain();
        toggleObfsPassword();
        toggleMasqueradeType();
        toggleBandwidthFields();
        toggleUdpFields();
        toggleSniffFields();
        toggleQuicFields();
        toggleResolverFields();
        toggleAclFields();
        const domainGroup = document.getElementById('domainGroup');
        if (domainGroup) domainGroup.style.display = '';
        const domainHintHy = document.getElementById('domainHintHysteria');
        const domainHintXr = document.getElementById('domainHintXrayManual');
        if (domainHintHy) domainHintHy.style.display = '';
        if (domainHintXr) domainHintXr.style.display = 'none';
    }
    checkXrayPortConflict();
}

function selectCascadeRole(role, cardEl) {
    document.getElementById('cascadeRole').value = role;
    document.querySelectorAll('.role-card').forEach(function(c) { c.classList.remove('active'); });
    if (cardEl) cardEl.classList.add('active');
    onCascadeRoleChange();
}

function onCascadeRoleChange() {
    const role = document.getElementById('cascadeRole').value;
    const isBridge = role === 'bridge';
    const isPortal = role === 'portal';

    var bridgeHint = document.getElementById('cascadeBridgeHint');
    var portalHint = document.getElementById('cascadePortalHint');
    if (bridgeHint) bridgeHint.style.display = isBridge ? '' : 'none';
    if (portalHint) portalHint.style.display = isPortal ? '' : 'none';

    // Bridge nodes: hide all client-facing settings.
    // They only need name, IP, SSH, and cascade role.
    ['xraySection', 'networkSection', 'limitsSection'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.style.display = isBridge ? 'none' : '';
    });
}

// ==================== Xray UI ====================

// VLESS fallbacks: tcp+tls only.
function _refreshMainFallbackVisibility() {
    const fb = document.getElementById('xrayFallbackGroup');
    if (!fb) return;
    const transport = document.getElementById('xrayTransport')?.value || 'tcp';
    const security = document.getElementById('xraySecurity')?.value || 'reality';
    fb.style.display = (transport === 'tcp' && security === 'tls') ? '' : 'none';
}

function updateXrayTransportUI() {
    const transport = document.getElementById('xrayTransport').value;
    document.getElementById('wsFields').style.display = transport === 'ws' ? '' : 'none';
    document.getElementById('grpcFields').style.display = transport === 'grpc' ? '' : 'none';
    document.getElementById('xhttpFields').style.display = transport === 'xhttp' ? '' : 'none';
    const flowGroup = document.getElementById('xrayFlowGroup');
    if (flowGroup) flowGroup.style.display = transport === 'tcp' ? '' : 'none';
    _refreshMainFallbackVisibility();
}

// True if main or any extra inbound uses TLS — drives #xrayTlsConfig visibility.
function _anyXrayTlsInboundActive() {
    const main = document.getElementById('xraySecurity')?.value || '';
    if (main === 'tls') return true;
    const extras = document.querySelectorAll('select[name="xray_extra_security"]');
    for (const el of extras) {
        if (el.value === 'tls') return true;
    }
    return false;
}

// Toggle the main inbound fingerprint UI between "single" and "pool" modes.
// The pool checkboxes are disabled in single mode so a (possibly stale)
// selection is never submitted; the empty hidden fallback still clears the pool.
function updateXrayFingerprintModeUI() {
    const checked = document.querySelector('input[name="xrayFingerprintMode"]:checked');
    const mode = checked ? checked.value : 'single';
    const single = document.getElementById('xrayFingerprintSingle');
    const poolBlock = document.getElementById('xrayFingerprintPoolBlock');
    if (single) single.style.display = mode === 'single' ? '' : 'none';
    if (poolBlock) poolBlock.style.display = mode === 'pool' ? '' : 'none';
    document.querySelectorAll('input.xray-fp-pool-cb').forEach(cb => { cb.disabled = mode !== 'pool'; });
