<% if (!node?._id) { %>
(function () {
    let siblingCheckTimer = null;

    async function checkSiblingNode() {
        const ipInput = document.getElementById('ip');
        const hint = document.getElementById('siblingNodeHint');
        const hintText = document.getElementById('siblingNodeHintText');
        if (!ipInput || !hint || !hintText) return;

        const ip = ipInput.value.trim();
        const type = document.querySelector('input[name="type"]:checked')?.value || 'hysteria';
        if (!ip) { hint.style.display = 'none'; return; }

        try {
            const res = await fetch('/api/nodes/check-ip?ip=' + encodeURIComponent(ip), { credentials: 'same-origin' });
            if (!res.ok) { hint.style.display = 'none'; return; }
            const data = await res.json();
            const sibling = (data.nodes || []).find(n => n.type !== type);
            if (sibling) {
                const protoLabel = sibling.type === 'xray' ? 'Xray VLESS' : 'Hysteria 2';
                var siblingMsg = '<%= typeof t !== "undefined" ? t("nodes.siblingExistsHint") : "{protocol} node already exists at this IP — SSH credentials will be synced automatically." %>';
                hintText.textContent = siblingMsg.replace('{protocol}', protoLabel);
                hint.style.display = '';
            } else {
                hint.style.display = 'none';
            }
        } catch (_e) {
            hint.style.display = 'none';
        }
    }

    function debouncedCheck() {
        clearTimeout(siblingCheckTimer);
        siblingCheckTimer = setTimeout(checkSiblingNode, 400);
    }

    const ipInput = document.getElementById('ip');
    if (ipInput) {
        ipInput.addEventListener('input', debouncedCheck);
        ipInput.addEventListener('blur', checkSiblingNode);
        // Also re-check when protocol type changes
        document.querySelectorAll('input[name="type"]').forEach(function(r) {
            r.addEventListener('change', checkSiblingNode);
        });
    }
})();
