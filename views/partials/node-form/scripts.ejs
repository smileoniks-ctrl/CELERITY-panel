<style>
.proto-switcher {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 8px;
}
.proto-option {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border: 2px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    position: relative;
}
.proto-option input[type="radio"] { position: absolute; opacity: 0; pointer-events: none; }
.proto-option:hover { border-color: var(--accent); background: var(--accent-glow); }
.proto-option.active { border-color: var(--accent); background: var(--accent-glow); }
.proto-icon { font-size: 22px; }
.proto-name { font-weight: 600; font-size: 14px; }
.proto-desc { font-size: 11px; color: var(--text-muted); }
.section-subtitle {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.code-textarea {
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 15px;
    width: 100%;
    resize: vertical;
    line-height: 1.5;
}
.code-textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-glow);
}

.code-block-wrap {
    position: relative;
    margin-top: 10px;
}
.code-block {
    margin: 0;
    padding: 14px;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    line-height: 1.5;
    overflow: auto;
    white-space: pre;
}
.config-copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 11px;
    cursor: pointer;
    color: var(--text-muted);
}
.config-copy-btn.is-copied {
    color: var(--success);
    border-color: var(--success);
}
.config-hint {
    margin-bottom: 0;
}
.input-with-button {
    display: flex;
    gap: 8px;
    align-items: center;
}
.input-with-button input { flex: 1; }
.input-with-button .btn { white-space: nowrap; flex-shrink: 0; }

.ssh-warning {
    background: var(--warning-bg);
    border: 1px solid var(--warning);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    margin-bottom: 16px;
    color: var(--warning);
    display: flex;
    align-items: center;
    gap: 10px;
}
.ssh-warning-icon { font-size: 20px; }

.node-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
}
.node-info-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
}
.node-info-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.node-info-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
}
.logs-output {
    background: #1a1a2e;
    color: #0f0;
    padding: 15px;
    border-radius: 8px;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    max-height: 500px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
    margin-top: 10px;
}
.logs-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.logs-output .error { color: #ff6b6b; }
.logs-output .success { color: #51cf66; }
.logs-output .warning { color: #ffd43b; }
.form-group.is-inactive {
    opacity: 0.55;
}

@media (max-width: 640px) {
    .form-row-3 { grid-template-columns: 1fr; }
}

.node-advanced-details {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 16px;
    background: var(--bg-secondary);
}
.node-advanced-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    color: var(--text-secondary);
    user-select: none;
    list-style: none;
    gap: 8px;
}
.node-advanced-summary::-webkit-details-marker { display: none; }
.node-advanced-summary:hover { color: var(--text-primary); }
.node-advanced-summary span { display: flex; align-items: center; gap: 8px; }
.node-advanced-chevron {
    transition: transform 0.2s;
    font-size: 16px;
    flex-shrink: 0;
}
.node-advanced-details[open] .node-advanced-chevron {
    transform: rotate(180deg);
}
.node-advanced-details > .form-section {
    border-top: 1px solid var(--border);
    border-radius: 0;
    margin-bottom: 0;
    margin-top: 0;
    padding: 20px 20px 16px;
    background: transparent;
}
.node-advanced-details > .form-section:last-of-type {
    border-bottom-left-radius: var(--radius);
    border-bottom-right-radius: var(--radius);
}

/* ── SNI Scanner modal ── */
.sni-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.6);
    z-index: 9000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 40px 16px 16px;
    overflow-y: auto;
}
.sni-modal-card {
    background: var(--bg-card, var(--bg-secondary));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    width: min(820px, 100%);
    display: flex;
    flex-direction: column;
    box-shadow: 0 32px 80px rgba(0,0,0,.6);
    margin: auto;
}
.sni-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 22px 14px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
}
.sni-modal-header h3 {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
}
.sni-modal-body {
    padding: 20px 22px 22px;
}
.sni-modal-hint {
    font-size: 12px;
    color: var(--text-muted);
    margin: 0 0 16px;
    line-height: 1.5;
}
/* 2-row params grid */
.sni-params {
    display: grid;
    grid-template-columns: 1fr 100px;
    gap: 12px;
    margin-bottom: 14px;
}
.sni-params-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr 160px;
    gap: 12px;
    margin-bottom: 14px;
}
.sni-scan-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}
.sni-scan-status {
    font-size: 12px;
    color: var(--text-muted);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.sni-progress-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 16px;
}
.sni-progress-fill {
    height: 100%;
    background: var(--accent);
    transition: width .1s linear;
}
.sni-results-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
}
.sni-results-title { font-weight: 600; font-size: 13px; }
.sni-results-count {
    font-size: 12px;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1px 8px;
}
.sni-table-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    max-height: 360px;
    overflow-y: auto;
    overflow-x: hidden;
}
.sni-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    table-layout: fixed;
}
.sni-table th {
    position: sticky;
    top: 0;
    background: var(--bg-secondary);
    padding: 8px 12px;
    text-align: left;
    font-weight: 600;
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .5px;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
}
.sni-table td {
    padding: 9px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.sni-table tr:last-child td { border-bottom: none; }
.sni-table tr:hover td { background: var(--accent-glow); }
/* Column widths */
.sni-table th:nth-child(1), .sni-table td:nth-child(1) { width: 72px; }   /* Ping   */
.sni-table th:nth-child(2), .sni-table td:nth-child(2) { width: auto; }    /* Domain */
.sni-table th:nth-child(3), .sni-table td:nth-child(3) { width: 140px; }  /* IP     */
.sni-table th:nth-child(4), .sni-table td:nth-child(4) { width: 130px; }  /* Issuer */
.sni-table th:nth-child(5), .sni-table td:nth-child(5) { width: 48px; text-align:center; } /* Apply */
.sni-ping-fast  { color: var(--success); font-weight: 600; }
.sni-ping-mid   { color: var(--warning); font-weight: 600; }
.sni-ping-slow  { color: var(--text-muted); }
.sni-domain     { font-weight: 500; }
.sni-issuer     { font-size: 11px; color: var(--text-muted); }
.sni-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
    padding: 28px 0;
}
.sni-ip-neighbor {
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--success);
}
.sni-ip-other {
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-muted);
}
.sni-apply-btn {
    padding: 5px 8px !important;
    font-size: 16px !important;
    line-height: 1;
}
.sni-modal-close {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px 6px;
    border-radius: 6px;
    font-size: 18px;
    transition: color .15s;
    line-height: 1;
}
.sni-modal-close:hover { color: var(--text-primary); }
</style>

<script>
const nodeType = '<%= node?.type || "hysteria" %>';
const i18n = {
    autoSetupConfirm: <%- JSON.stringify(t("nodes.autoSetupConfirm")) %>,
    autoSetupConfirmXray: <%- JSON.stringify(t("nodes.autoSetupConfirmXray")) %>,
    setupRunning: <%- JSON.stringify(t("nodes.setupRunning")) %>,
    loadingLogs: <%- JSON.stringify(t("nodes.loadingLogs")) %>,
    checking: <%- JSON.stringify(t("nodes.checking")) %>,
    resettingStatus: <%- JSON.stringify(t("nodes.resettingStatus")) %>,
    statusReset: <%- JSON.stringify(t("nodes.statusReset")) %>,
    autoSetup: <%- JSON.stringify(t("nodes.autoSetup")) %>,
    error: <%- JSON.stringify(t("common.error")) %>,
    confirmDeployCascade: <%- JSON.stringify(t("nodes.confirmDeployCascade")) %>,
    confirmUndeployCascade: <%- JSON.stringify(t("nodes.confirmUndeployCascade")) %>,
    confirmDeleteCascade: <%- JSON.stringify(t("nodes.confirmDeleteCascade")) %>,
    xrayGenerateKeysConfirm: <%- JSON.stringify(t("nodes.xrayGenerateKeysConfirm")) %>,
    xrayKeysSuccess: <%- JSON.stringify(t("nodes.xrayKeysSuccess")) %>
};
const i18nConfig = {
    copied: <%- JSON.stringify(t("common.copied")) %>,
    loadConfigConfirm: <%- JSON.stringify(t("nodes.loadConfigConfirm")) %>,
    configLoaded: <%- JSON.stringify(t("nodes.configLoaded")) %>,
    saveFirst: <%- JSON.stringify(t("nodes.saveFirst")) %>,
    error: <%- JSON.stringify(t("common.error")) %>,
    baseUrl: <%- JSON.stringify(baseUrl) %>
};

// ==================== Protocol switcher ====================

const PANEL_DOMAIN = '<%= panelDomain %>';

function checkXrayPortConflict() {
    const warn = document.getElementById('xrayPortConflictWarn');
    if (!warn) return;
    const proto = document.querySelector('input[name="type"]:checked')?.value || 'hysteria';
    const ip = (document.getElementById('ip')?.value || '').trim().toLowerCase();
    const port = parseInt(document.getElementById('port')?.value || '443', 10);
    const panelHostname = PANEL_DOMAIN.split(':')[0].toLowerCase();
    const isSameServer = ip === 'localhost' || ip === '127.0.0.1' || ip === '::1' || ip === panelHostname;
    const isConflictPort = port === 443 || port === 80;
    warn.style.display = (proto === 'xray' && isSameServer && isConflictPort) ? '' : 'none';
}

function switchProto(proto) {
    const xraySection = document.getElementById('xraySection');
    const cascadeSection = document.getElementById('cascadeRoleSection');
    const labelHysteria = document.getElementById('protoHysteriaLabel');
    const labelXray = document.getElementById('protoXrayLabel');
    const hysteriaOnlyEls = document.querySelectorAll('.hysteria-only');

    if (proto === 'xray') {
        xraySection.style.display = '';
        if (cascadeSection) cascadeSection.style.display = '';
        labelXray.classList.add('active');
        labelHysteria.classList.remove('active');
        hysteriaOnlyEls.forEach(el => el.style.display = 'none');
        onCascadeRoleChange();
    } else {
        xraySection.style.display = 'none';
        if (cascadeSection) cascadeSection.style.display = 'none';
        labelHysteria.classList.add('active');
        labelXray.classList.remove('active');
        hysteriaOnlyEls.forEach(el => el.style.display = '');
        toggleAcmeByDomain();
        toggleObfsPassword();
        toggleMasqueradeType();
        toggleBandwidthFields();
        toggleUdpFields();
        toggleSniffFields();
        toggleQuicFields();
        toggleResolverFields();
        toggleAclFields();
    }
    checkXrayPortConflict();
}

function selectCascadeRole(role, cardEl) {
    document.getElementById('cascadeRole').value = role;
    document.querySelectorAll('.role-card').forEach(function(c) { c.classList.remove('active'); });
    if (cardEl) cardEl.classList.add('active');
    onCascadeRoleChange();
}

function onCascadeRoleChange() {
    const role = document.getElementById('cascadeRole').value;
    const isBridge = role === 'bridge';
    const isPortal = role === 'portal';

    var bridgeHint = document.getElementById('cascadeBridgeHint');
    var portalHint = document.getElementById('cascadePortalHint');
    if (bridgeHint) bridgeHint.style.display = isBridge ? '' : 'none';
    if (portalHint) portalHint.style.display = isPortal ? '' : 'none';

    // Bridge nodes: hide all client-facing settings.
    // They only need name, IP, SSH, and cascade role.
    ['xraySection', 'networkSection', 'limitsSection'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.style.display = isBridge ? 'none' : '';
    });
}

// ==================== Xray UI ====================

function updateXrayTransportUI() {
    const transport = document.getElementById('xrayTransport').value;
    document.getElementById('wsFields').style.display = transport === 'ws' ? '' : 'none';
    document.getElementById('grpcFields').style.display = transport === 'grpc' ? '' : 'none';
    document.getElementById('xhttpFields').style.display = transport === 'xhttp' ? '' : 'none';
    const flowGroup = document.getElementById('xrayFlowGroup');
    if (flowGroup) flowGroup.style.display = transport === 'tcp' ? '' : 'none';
}

function updateXraySecurityUI() {
    const security = document.getElementById('xraySecurity').value;
    document.getElementById('realityFields').style.display = security === 'reality' ? '' : 'none';
    document.getElementById('alpnGroup').style.display = security === 'tls' ? '' : 'none';
}

// ==================== Hysteria helpers ====================

function toggleObfsPassword() {
    const type = document.getElementById('obfsType').value;
    document.getElementById('obfsPasswordGroup').style.display = type === 'salamander' ? '' : 'none';
}

function toggleCustomConfig() {
    const checked = document.getElementById('useCustomConfig').checked;
    document.getElementById('customConfigSection').style.display = checked ? 'block' : 'none';
}

function toggleAcmeByDomain() {
    const domain = (document.getElementById('domain')?.value || '').trim();
    const toggleGroup = document.getElementById('acmeAdvancedToggleGroup');
    if (toggleGroup) toggleGroup.style.display = domain ? '' : 'none';

    if (!domain) {
        const cb = document.getElementById('acmeAdvancedEnabled');
        if (cb) cb.checked = false;
    }

    toggleAcmeAdvancedFields();
    toggleSniField();
}

function toggleAcmeAdvancedFields() {
    const domain = (document.getElementById('domain')?.value || '').trim();
    const enabled = !!document.getElementById('acmeAdvancedEnabled')?.checked;
    const wrap = document.getElementById('acmeAdvancedFieldsWrap');
    if (wrap) wrap.style.display = (domain && enabled) ? '' : 'none';
    if (domain && enabled) toggleAcmeTypeFields();
}

function toggleAcmeTypeFields() {
    const advancedEnabled = !!document.getElementById('acmeAdvancedEnabled')?.checked;
    const domain = (document.getElementById('domain')?.value || '').trim();
    const type = document.getElementById('acmeType')?.value || '';
    const altPorts = document.getElementById('acmeAltPortFields');
    const httpGroup = document.getElementById('acmeHttpFieldGroup');
    const tlsGroup = document.getElementById('acmeTlsFieldGroup');
    const dns = document.getElementById('acmeDnsFields');
    const active = advancedEnabled && !!domain;
    if (altPorts) altPorts.style.display = active && (type === 'http' || type === 'tls') ? '' : 'none';
    if (httpGroup) httpGroup.classList.toggle('is-inactive', !active || type !== 'http');
    if (tlsGroup) tlsGroup.classList.toggle('is-inactive', !active || type !== 'tls');
    if (dns) dns.style.display = active && type === 'dns' ? '' : 'none';
}

function toggleMasqueradeType() {
    const type = document.getElementById('masqueradeType')?.value || 'proxy';
    const proxy = document.getElementById('masqueradeProxyFields');
    const str = document.getElementById('masqueradeStringFields');
    if (proxy) proxy.style.display = type === 'proxy' ? '' : 'none';
    if (str) str.style.display = type === 'string' ? '' : 'none';
    toggleSniField();
}

function toggleSniField() {
    const proto = document.querySelector('input[name="type"]:checked')?.value || 'hysteria';
    const group = document.getElementById('sniGroup');
    if (!group) return;
    if (proto === 'xray') {
        group.style.display = 'none';
        return;
    }
    const hasDomain = !!(document.getElementById('domain')?.value || '').trim();
    group.style.display = hasDomain ? 'none' : '';
}

function toggleResolverFields() {
    const enabled = document.getElementById('resolverEnabled')?.checked;
    const wrap = document.getElementById('resolverFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
    if (enabled) toggleResolverTypeFields();
}

function toggleResolverTypeFields() {
    const type = document.getElementById('resolverType')?.value || 'udp';
    const ids = ['resolverUdpFields', 'resolverTcpFields', 'resolverTlsFields', 'resolverHttpsFields'];
    ids.forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        const expected = id.replace('resolver', '').replace('Fields', '').toLowerCase();
        el.style.display = expected === type ? '' : 'none';
    });
}

function toggleAclTypeFields() {
    const enabled = !!document.getElementById('aclEnabled')?.checked;
    const type = document.getElementById('aclType')?.value || 'inline';
    const fileGroup = document.getElementById('aclFileGroup');
    const typeGroup = document.getElementById('aclTypeGroup');
    const inlineRulesGroup = document.getElementById('aclInlineRulesGroup');
    if (fileGroup) fileGroup.style.display = enabled && type === 'file' ? '' : 'none';
    if (typeGroup) typeGroup.style.gridColumn = (enabled && type === 'file') ? '' : '1 / -1';
    if (inlineRulesGroup) inlineRulesGroup.style.display = enabled && type === 'inline' ? '' : 'none';
}

function toggleAclFields() {
    const enabled = !!document.getElementById('aclEnabled')?.checked;
    const wrap = document.getElementById('aclFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
    if (enabled) toggleAclTypeFields();
}

function toggleBandwidthFields() {
    const enabled = !!document.getElementById('bandwidthEnabled')?.checked;
    const wrap = document.getElementById('bandwidthFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
}

function toggleUdpFields() {
    const enabled = !!document.getElementById('udpOptionsEnabled')?.checked;
    const wrap = document.getElementById('udpFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
}

function toggleSniffFields() {
    const enabled = !!document.getElementById('sniffEnabled')?.checked;
    const wrap = document.getElementById('sniffFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
}

function toggleQuicFields() {
    const enabled = !!document.getElementById('quicEnabled')?.checked;
    const wrap = document.getElementById('quicFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
}

function generateSecret() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    let secret = '';
    for (let i = 0; i < 32; i++) secret += chars.charAt(Math.floor(Math.random() * chars.length));
    document.getElementById('statsSecret').value = secret;
}

function generateObfsPassword() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
    let pwd = '';
    for (let i = 0; i < 24; i++) pwd += chars.charAt(Math.floor(Math.random() * chars.length));
    document.getElementById('obfsPassword').value = pwd;
}

async function generateConfig() {
    const form = document.getElementById('nodeForm');
    const output = document.getElementById('customConfig');
    if (!form || !output) return;

    const formData = new URLSearchParams(new FormData(form));
    try {
        const res = await fetch('/panel/nodes/preview-config', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: formData.toString(),
        });
        const data = await res.json();
        if (!res.ok || !data.success) {
            throw new Error(data.error || 'Failed to generate preview');
        }
        output.value = data.config || '';
    } catch (err) {
        alert(i18nConfig.error + ': ' + err.message);
    }
}

async function loadCurrentConfig() {
    <% if (node) { %>
    if (!confirm(i18nConfig.loadConfigConfirm)) return;
    try {
        const res = await fetch('/panel/nodes/<%= node._id %>/get-config');
        const data = await res.json();
        if (data.success) {
            document.getElementById('customConfig').value = data.config;
            alert(i18nConfig.configLoaded);
        } else {
            alert(i18nConfig.error + ': ' + data.error);
        }
    } catch (err) {
        alert(i18nConfig.error + ': ' + err.message);
    }
    <% } else { %>
    alert(i18nConfig.saveFirst);
    <% } %>
}

function fallbackCopyText(text) {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;left:-9999px;top:0';
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    let ok = false;
    try {
        ok = document.execCommand('copy');
    } catch (_) {
        ok = false;
    }
    document.body.removeChild(ta);
    return ok;
}

async function copyConfig(btn) {
    const code = document.querySelector('#nodeConfigCode code')?.textContent || '';
    if (!code) return;

    let copied = false;
    if (navigator.clipboard?.writeText) {
        try {
            await navigator.clipboard.writeText(code);
            copied = true;
        } catch (_) {
            copied = fallbackCopyText(code);
        }
    } else {
        copied = fallbackCopyText(code);
    }

    if (!btn) return;
    if (!btn.dataset.orig) {
        btn.dataset.orig = btn.textContent;
    }

    if (copied) {
        btn.textContent = `${i18nConfig.copied} ✓`;
        btn.classList.add('is-copied');
        setTimeout(() => {
            btn.textContent = btn.dataset.orig;
            btn.classList.remove('is-copied');
        }, 1500);
    }
}

