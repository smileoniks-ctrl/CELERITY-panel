async function cascadeAction(linkId, action, btn) {
    const confirmMsg = action === 'deploy' ? i18n.confirmDeployCascade : i18n.confirmUndeployCascade;
    if (!confirm(confirmMsg)) return;
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="ti ti-loader-2" style="animation:spin 0.7s linear infinite;display:inline-block"></i>'; }
    try {
        const res = await fetch('/api/cascade/links/' + linkId + '/' + action, { method: 'POST' });
        if (res.ok) {
            location.reload();
        } else {
            const data = await res.json().catch(() => ({}));
            alert(i18n.error + ': ' + (data.error || 'Unknown error'));
            if (btn) { btn.disabled = false; btn.innerHTML = action === 'deploy' ? '<i class="ti ti-upload"></i>' : '<i class="ti ti-upload-off"></i>'; }
        }
    } catch (err) {
        alert(i18n.error + ': ' + err.message);
        if (btn) { btn.disabled = false; }
    }
}

async function cascadeDelete(linkId, name) {
    const confirmMsg = i18n.confirmDeleteCascade.replace('{name}', name);
    if (!confirm(confirmMsg)) return;
    try {
        const res = await fetch('/api/cascade/links/' + linkId, { method: 'DELETE' });
        if (res.ok) {
            location.reload();
        } else {
            const data = await res.json().catch(() => ({}));
            alert(i18n.error + ': ' + (data.error || 'Unknown error'));
        }
    } catch (err) {
        alert(i18n.error + ': ' + err.message);
    }
}

