<% if (node?._id && node.type === 'xray') { %>
async function refreshNodeInfo() {
    const btn = document.getElementById('btnRefreshInfo');
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="ti ti-loader-2"></i>'; }
    const errEl = document.getElementById('nodeInfoError');
    if (errEl) errEl.style.display = 'none';
    try {
        const res = await fetch('/api/nodes/<%= node._id %>/agent-info', { credentials: 'include' });
        const data = await res.json();
        if (data.xray_version) document.getElementById('infoXrayVersion').textContent = data.xray_version;
        if (data.agent_version) document.getElementById('infoAgentVersion').textContent = data.agent_version;
        if (data.users_count !== undefined) document.getElementById('infoUsersCount').textContent = data.users_count;
        const statusEl = document.getElementById('infoAgentStatus');
        if (statusEl) {
            const online = res.ok && !data.error;
            statusEl.innerHTML = `<span class="badge badge-${online ? 'success' : 'danger'}">${online ? 'online' : 'offline'}</span>`;
        }
        document.getElementById('infoLastSeen').textContent = new Date().toLocaleString();
    } catch (e) {
        if (errEl) {
            errEl.innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + e.message + '</div>';
            errEl.style.display = 'block';
        }
    } finally {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="ti ti-refresh"></i>'; }
    }
}
