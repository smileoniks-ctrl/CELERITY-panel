<!-- ==================== TAB: MAINTENANCE ==================== -->
<div class="tab-content" id="tab-maintenance">
    <div class="row">
        <div class="col">
            <div class="card" id="updateCard" data-current-version="<%= appVersion %>" data-totp-enabled="<%= admin?.twoFactor?.enabled ? '1' : '0' %>">
                <div class="card-header">
                    <h2><i class="ti ti-rocket"></i> <%= t('settings.updateTitle') || 'Обновление панели' %></h2>
                </div>
                <div class="card-body">
                    <p style="color: var(--text-muted); font-size: 13px; line-height: 1.6; margin-bottom: 16px;">
                        <%= t('settings.updateDesc') || 'Обновление и откат панели на выбранную версию.' %>
                    </p>

                    <div class="update-versions" style="display:flex; gap:24px; flex-wrap:wrap; margin-bottom:16px;">
                        <div>
                            <div style="font-size:12px; color:var(--text-muted);"><%= t('settings.updateCurrentVersion') || 'Текущая версия' %></div>
                            <div style="font-size:18px; font-weight:600;">v<%= appVersion %></div>
                        </div>
                        <div>
                            <div style="font-size:12px; color:var(--text-muted);"><%= t('settings.updateLatestVersion') || 'Последняя версия' %></div>
                            <div style="font-size:18px; font-weight:600;" id="updateLatestVersion">—</div>
                        </div>
                        <div>
                            <div style="font-size:12px; color:var(--text-muted);"><%= t('settings.updateLastChecked') || 'Проверено' %></div>
                            <div style="font-size:13px;" id="updateCheckedAt">—</div>
                        </div>
                    </div>

                    <div id="updateBadge" style="display:none; margin-bottom:16px;"></div>

                    <!-- Shown only when the updater sidecar is reachable. -->
                    <div id="updateControls" style="display:none;">
                        <div class="form-group" style="max-width:420px;">
                            <label for="updateVersionSelect"><%= t('settings.updateSelectVersion') || 'Версия' %></label>
                            <select id="updateVersionSelect" class="form-control"></select>
                        </div>
                        <div id="updateChangelogWrap" class="upd-cl-wrap" style="display:none;">
                            <button type="button" class="upd-cl-toggle" id="updateChangelogToggle" aria-expanded="false">
                                <i class="ti ti-chevron-right"></i>
                                <span><%= t('settings.updateChangelogTitle') || 'Что нового в этой версии' %></span>
                            </button>
                            <div id="updateChangelog" class="upd-cl-body" style="display:none;"></div>
                        </div>
                        <div id="updateDowngradeWarn" style="display:none; margin:12px 0; padding:10px 12px; border-radius:8px; background:rgba(245,158,11,0.12); color:#fbbf24; font-size:13px;">
                            <i class="ti ti-alert-triangle"></i> <%= t('settings.updateDowngradeWarn') || 'Откат на более старую версию не откатывает изменения в базе данных. Восстановление возможно только из резервной копии.' %>
                        </div>
                        <div style="display:flex; gap:10px; flex-wrap:wrap;">
                            <button class="btn btn-primary" id="updateApplyBtn" onclick="openUpdateModal()" disabled>
                                <i class="ti ti-download"></i> <span id="updateApplyLabel"><%= t('settings.updateApply') || 'Установить' %></span>
                            </button>
                            <button class="btn btn-secondary" id="updateCheckBtn" onclick="checkForUpdates()">
                                <i class="ti ti-refresh"></i> <%= t('settings.updateCheckNow') || 'Проверить сейчас' %>
                            </button>
                        </div>
                    </div>

                    <!-- Shown when the updater is not available (dokploy/local/no secret). -->
                    <div id="updateManual" style="display:none;">
                        <div style="margin-bottom:12px; padding:10px 12px; border-radius:8px; background:rgba(148,163,184,0.12); font-size:13px; color:var(--text-muted);">
                            <i class="ti ti-info-circle"></i> <%= t('settings.updateManualNotice') || 'Обновление из UI недоступно для этого способа развёртывания. Обновите панель вручную.' %>
                        </div>
                        <button class="btn btn-secondary" id="updateCheckBtnManual" onclick="checkForUpdates()">
                            <i class="ti ti-refresh"></i> <%= t('settings.updateCheckNow') || 'Проверить сейчас' %>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-6">
            <div class="card">
                <div class="card-header">
                    <h2><i class="ti ti-eraser"></i> <%= t('settings.cacheManagement') %></h2>
                </div>
                <div class="card-body">
                    <p style="color: var(--text-muted); font-size: 13px; line-height: 1.6; margin-bottom: 16px;">
                        <%= t('settings.flushCacheDesc') %>
                    </p>
                    <button class="btn btn-warning" onclick="flushCache()">
                        <i class="ti ti-trash"></i> <%= t('settings.flushCacheBtn') %>
                    </button>
                </div>
            </div>

            <div class="card" style="margin-top: 16px;">
                <div class="card-header">
                    <h2><i class="ti ti-chart-bar-off"></i> <%= t('settings.resetStats') || 'Сброс статистики' %></h2>
                </div>
                <div class="card-body">
                    <p style="color: var(--text-muted); font-size: 13px; line-height: 1.6; margin-bottom: 16px;">
                        <%= t('settings.resetStatsDesc') || 'Удалить все исторические данные статистики.' %>
                    </p>
                    <button class="btn btn-warning" onclick="resetStats()">
                        <i class="ti ti-trash"></i> <%= t('settings.resetStatsBtn') || 'Очистить статистику' %>
                    </button>
                </div>
            </div>
        </div>

        <div class="col-6">
            <div class="card danger-zone">
                <div class="card-header">
                    <h2><i class="ti ti-alert-triangle"></i> <%= t('settings.dangerZone') %></h2>
                </div>
                <div class="card-body">
                    <h4 style="margin: 0 0 6px; font-size: 14.5px; color: #fecaca;"><%= t('settings.resetTrafficCounter') %></h4>
                    <p style="color: var(--text-muted); font-size: 13px; line-height: 1.6; margin-bottom: 16px;">
                        <%= t('settings.resetTrafficDesc') %>
                    </p>
                    <button class="btn btn-danger" onclick="resetTraffic()">
                        <i class="ti ti-trash"></i> <%= t('settings.resetAllTraffic') %>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Update confirmation modal -->
<div class="glass-modal" id="updateModal" style="display:none;">
    <div class="glass-modal-content" style="max-width:440px;">
        <h3 style="margin-top:0;"><%= t('settings.updateConfirmTitle') || 'Подтвердите обновление' %></h3>
        <p style="color:var(--text-muted); font-size:13px;" id="updateModalSummary"></p>
        <div class="form-group">
            <label for="updatePassword"><%= t('settings.updatePassword') || 'Текущий пароль' %></label>
            <input type="password" id="updatePassword" class="form-control" autocomplete="current-password">
        </div>
        <div class="form-group" id="updateTotpGroup" style="display:none;">
            <label for="updateTotp"><%= t('settings.updateTotp') || 'Код 2FA' %></label>
            <input type="text" id="updateTotp" class="form-control" inputmode="numeric" autocomplete="one-time-code" maxlength="10">
        </div>
        <label style="display:flex; align-items:center; gap:8px; font-size:13px; margin:8px 0 16px;">
            <input type="checkbox" id="updateBackup" checked>
            <%= t('settings.updateCreateBackup') || 'Создать резервную копию перед обновлением' %>
        </label>
        <div style="display:flex; gap:10px; justify-content:flex-end;">
            <button class="btn btn-secondary" onclick="closeUpdateModal()"><%= t('common.cancel') || 'Отмена' %></button>
            <button class="btn btn-primary" id="updateConfirmBtn" onclick="submitUpdate()"><%= t('settings.updateApply') || 'Установить' %></button>
        </div>
    </div>
</div>

<!-- Full-screen progress overlay shown while the panel is being updated -->
<div id="updateOverlay" class="upd-overlay" style="display:none;">
    <div class="upd-card">
        <div class="upd-head">
            <div class="upd-icon" id="updIcon"><i class="ti ti-rocket"></i></div>
            <div class="upd-head-text">
                <h2 class="upd-title" id="updTitle"><%= t('settings.updateInProgress') || 'Обновление панели' %></h2>
                <p class="upd-sub" id="updSub"></p>
            </div>
            <span class="upd-elapsed" id="updElapsed">00:00</span>
        </div>

        <div class="upd-steps" id="updSteps"></div>

        <div class="upd-log-wrap" id="updLogWrap" style="display:none;">
            <button type="button" class="upd-log-toggle" id="updLogToggle" aria-expanded="false">
                <i class="ti ti-chevron-right" id="updLogChevron"></i>
                <span><%= t('settings.updateDetails') || 'Детали' %></span>
            </button>
            <pre class="upd-log" id="updLog" style="display:none;"></pre>
        </div>

        <!-- Shown only when the flow ends in error/timeout so the admin can leave. -->
        <div class="upd-actions" id="updActions" style="display:none;">
            <button class="btn btn-secondary" onclick="location.reload()">
                <%= t('common.close') || 'Закрыть' %>
            </button>
        </div>
    </div>
</div>

<style>
.upd-overlay{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;background:rgba(8,8,10,0.72);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);}
.upd-card{width:100%;max-width:560px;background:var(--glass-bg-strong,rgba(20,20,23,0.92));border:1px solid var(--glass-border-strong,#3f3f46);border-radius:var(--radius,16px);box-shadow:var(--glass-shadow-lg,0 24px 64px rgba(0,0,0,.5));padding:28px;animation:upd-in .35s cubic-bezier(.2,.8,.2,1);}
@keyframes upd-in{from{opacity:0;transform:translateY(14px) scale(.98)}to{opacity:1;transform:none}}
.upd-head{display:flex;align-items:center;gap:16px;margin-bottom:24px;}
.upd-head-text{min-width:0;}
.upd-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;flex:0 0 auto;color:#fff;background:linear-gradient(135deg,var(--accent,#6366f1) 0%,var(--accent-gradient-end,#7c3aed) 100%);box-shadow:0 6px 18px var(--accent-glow,rgba(99,102,241,.3));transition:all .3s;}
.upd-icon.is-success{background:linear-gradient(135deg,#22c55e,#16a34a);box-shadow:0 6px 18px rgba(34,197,94,.35);}
.upd-icon.is-error{background:linear-gradient(135deg,#ef4444,#dc2626);box-shadow:0 6px 18px rgba(239,68,68,.35);}
.upd-icon .ti-loader-2{animation:upd-spin .9s linear infinite;}
.upd-title{margin:0;font-size:18px;font-weight:650;color:var(--text-primary,#fafafa);}
.upd-sub{margin:3px 0 0;font-size:13px;color:var(--text-muted,#71717a);font-family:'JetBrains Mono',monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.upd-elapsed{margin-left:auto;align-self:flex-start;font-size:12px;color:var(--text-muted,#71717a);font-family:'JetBrains Mono',monospace;background:rgba(255,255,255,.04);border:1px solid var(--border,#27272a);padding:3px 8px;border-radius:var(--radius-xs,6px);}
.upd-steps{display:flex;flex-direction:column;gap:2px;margin-bottom:20px;}
.upd-step{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:var(--radius-sm,10px);transition:background .25s;}
.upd-step.is-active{background:rgba(99,102,241,.10);}
.upd-step-ic{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;flex:0 0 auto;border:1.5px solid var(--border-light,#3f3f46);color:var(--text-muted,#71717a);background:var(--bg-tertiary,#18181b);transition:all .25s;}
.upd-step.is-active .upd-step-ic{border-color:var(--accent,#6366f1);color:var(--accent,#6366f1);}
.upd-step.is-active .upd-step-ic .ti-loader-2{animation:upd-spin .9s linear infinite;}
.upd-step.is-done .upd-step-ic{border-color:var(--success,#22c55e);background:var(--success,#22c55e);color:#fff;}
.upd-step.is-error .upd-step-ic{border-color:var(--danger,#ef4444);background:var(--danger,#ef4444);color:#fff;}
.upd-step-label{font-size:14px;color:var(--text-muted,#71717a);transition:color .25s;}
.upd-step.is-active .upd-step-label{color:var(--text-primary,#fafafa);font-weight:600;}
.upd-step.is-done .upd-step-label{color:var(--text-secondary,#a1a1aa);}
.upd-step.is-error .upd-step-label{color:#fca5a5;font-weight:600;}
@keyframes upd-spin{to{transform:rotate(360deg)}}
.upd-log-wrap{margin-bottom:18px;}
.upd-log-toggle{display:inline-flex;align-items:center;gap:6px;padding:0;background:none;border:none;cursor:pointer;font-size:12.5px;color:var(--text-muted,#71717a);transition:color .2s;font-family:inherit;}
.upd-log-toggle:hover{color:var(--text-secondary,#a1a1aa);}
.upd-log-toggle i{font-size:14px;transition:transform .2s;}
.upd-log-toggle.is-open i{transform:rotate(90deg);}
.upd-log{margin:10px 0 0;padding:12px 14px;max-height:220px;overflow:auto;background:rgba(0,0,0,.28);border:1px solid var(--border,#27272a);border-radius:var(--radius-sm,10px);font-family:'JetBrains Mono',monospace;font-size:11.5px;line-height:1.65;color:var(--text-secondary,#a1a1aa);white-space:pre-wrap;word-break:break-word;}
.upd-cl-wrap{margin:12px 0;}
.upd-cl-toggle{display:inline-flex;align-items:center;gap:6px;padding:0;background:none;border:none;cursor:pointer;font-size:13px;font-weight:500;color:var(--text-secondary,#a1a1aa);transition:color .2s;font-family:inherit;}
.upd-cl-toggle:hover{color:var(--text-primary,#fafafa);}
.upd-cl-toggle i{font-size:15px;transition:transform .2s;}
.upd-cl-toggle.is-open i{transform:rotate(90deg);}
.upd-cl-body{margin-top:10px;padding:12px 14px;max-height:260px;overflow:auto;border:1px solid var(--border,#27272a);border-radius:var(--radius-sm,10px);background:rgba(0,0,0,.18);white-space:pre-wrap;font-size:12.5px;line-height:1.6;color:var(--text-muted,#71717a);}
.upd-actions{display:flex;justify-content:flex-end;}
</style>

<script>
(function () {
    const card = document.getElementById('updateCard');
    if (!card) return;

    const t = {
        updateAvailable: <%- JSON.stringify(t('settings.updateAvailable') || 'Доступно обновление') %>,
        upToDate: <%- JSON.stringify(t('settings.updateUpToDate') || 'Установлена последняя версия') %>,
        current: <%- JSON.stringify(t('settings.updateCurrentTag') || 'текущая') %>,
        install: <%- JSON.stringify(t('settings.updateApply') || 'Установить') %>,
        rollback: <%- JSON.stringify(t('settings.updateRollback') || 'Откатиться') %>,
        checking: <%- JSON.stringify(t('settings.updateChecking') || 'Проверка...') %>,
        checkNow: <%- JSON.stringify(t('settings.updateCheckNow') || 'Проверить сейчас') %>,
        confirmSummary: <%- JSON.stringify(t('settings.updateConfirmSummary') || 'Панель будет переведена на версию v{version}. Возможен кратковременный простой.') %>,
        passwordRequired: <%- JSON.stringify(t('settings.updatePasswordRequired') || 'Введите пароль') %>,
        totpRequired: <%- JSON.stringify(t('settings.updateTotpRequired') || 'Введите код 2FA') %>,
        starting: <%- JSON.stringify(t('settings.updateStarting') || 'Запуск обновления...') %>,
        waiting: <%- JSON.stringify(t('settings.updateWaiting') || 'Ожидание перезапуска панели...') %>,
        success: <%- JSON.stringify(t('settings.updateSuccess') || 'Панель обновлена до v{version}') %>,
        failed: <%- JSON.stringify(t('settings.updateFailed') || 'Обновление не удалось') %>,
        error: <%- JSON.stringify(t('common.error') || 'Ошибка') %>,
        inProgress: <%- JSON.stringify(t('settings.updateInProgress') || 'Обновление панели') %>,
        stepBackup: <%- JSON.stringify(t('settings.updateStepBackup') || 'Резервная копия') %>,
        stepPrepare: <%- JSON.stringify(t('settings.updateStepPrepare') || 'Подготовка') %>,
        stepImage: <%- JSON.stringify(t('settings.updateStepImage') || 'Загрузка и сборка образа') %>,
        stepRestart: <%- JSON.stringify(t('settings.updateStepRestart') || 'Перезапуск панели') %>,
        done: <%- JSON.stringify(t('settings.updateDone') || 'Готово') %>,
    };

    const currentVersion = card.dataset.currentVersion;
    const totpEnabled = card.dataset.totpEnabled === '1';
    let releases = [];
    let selectedVersion = null;

    function cmp(a, b) {
        const pa = String(a).split('.').map(Number);
        const pb = String(b).split('.').map(Number);
        for (let i = 0; i < 3; i++) {
            if ((pa[i] || 0) > (pb[i] || 0)) return 1;
            if ((pa[i] || 0) < (pb[i] || 0)) return -1;
        }
        return 0;
    }

    function fmtDate(iso) {
        if (!iso) return '—';
        try { return new Date(iso).toLocaleString(); } catch (_) { return '—'; }
    }

    function renderReleases() {
        const select = document.getElementById('updateVersionSelect');
        const applyBtn = document.getElementById('updateApplyBtn');
        select.innerHTML = '';
        if (!releases.length) {
            applyBtn.disabled = true;
            return;
        }
        releases.forEach((r) => {
            const opt = document.createElement('option');
            opt.value = r.version;
            const isCurrent = cmp(r.version, currentVersion) === 0;
            opt.textContent = 'v' + r.version + (isCurrent ? ' (' + t.current + ')' : '');
            select.appendChild(opt);
        });
        // Default to the latest non-current version, else the latest.
        const firstNonCurrent = releases.find((r) => cmp(r.version, currentVersion) !== 0);
        select.value = (firstNonCurrent || releases[0]).version;
        onVersionChange();
    }

    function onVersionChange() {
        const select = document.getElementById('updateVersionSelect');
        selectedVersion = select.value;
        const rel = releases.find((r) => r.version === selectedVersion);
        const applyBtn = document.getElementById('updateApplyBtn');
        const label = document.getElementById('updateApplyLabel');
        const changelog = document.getElementById('updateChangelog');
        const changelogWrap = document.getElementById('updateChangelogWrap');
        const changelogToggle = document.getElementById('updateChangelogToggle');
        const downgradeWarn = document.getElementById('updateDowngradeWarn');

        const diff = cmp(selectedVersion, currentVersion);
        applyBtn.disabled = diff === 0;
        label.textContent = diff < 0 ? t.rollback : t.install;
        downgradeWarn.style.display = diff < 0 ? '' : 'none';

        if (rel && rel.body) {
            changelog.textContent = rel.body;
            changelogWrap.style.display = '';
            // Collapse by default on every version switch so the card stays compact.
            changelog.style.display = 'none';
            changelogToggle.classList.remove('is-open');
            changelogToggle.setAttribute('aria-expanded', 'false');
        } else {
            changelogWrap.style.display = 'none';
        }
    }

    function toggleChangelog() {
        const changelog = document.getElementById('updateChangelog');
        const toggle = document.getElementById('updateChangelogToggle');
        const open = changelog.style.display !== 'none';
        changelog.style.display = open ? 'none' : '';
        toggle.classList.toggle('is-open', !open);
        toggle.setAttribute('aria-expanded', String(!open));
    }

    function applyState(data) {
        releases = Array.isArray(data.releases) ? data.releases : [];
        document.getElementById('updateLatestVersion').textContent = data.latestVersion ? ('v' + data.latestVersion) : '—';
        document.getElementById('updateCheckedAt').textContent = fmtDate(data.checkedAt);

        const badge = document.getElementById('updateBadge');
        if (data.updateAvailable) {
            badge.style.display = '';
            badge.innerHTML = '<span style="display:inline-block; padding:4px 10px; border-radius:6px; background:rgba(34,197,94,0.15); color:#4ade80; font-size:13px;"><i class="ti ti-arrow-up-circle"></i> ' + t.updateAvailable + '</span>';
        } else if (data.latestVersion) {
            badge.style.display = '';
            badge.innerHTML = '<span style="display:inline-block; padding:4px 10px; border-radius:6px; background:rgba(148,163,184,0.12); color:var(--text-muted); font-size:13px;"><i class="ti ti-check"></i> ' + t.upToDate + '</span>';
        } else {
            badge.style.display = 'none';
        }

        const updaterAvailable = data.updater && data.updater.available;
        document.getElementById('updateControls').style.display = updaterAvailable ? '' : 'none';
        document.getElementById('updateManual').style.display = updaterAvailable ? 'none' : '';

        if (updaterAvailable) renderReleases();
    }

    async function loadStatus() {
        try {
            const res = await fetch('/panel/settings/update-status', { credentials: 'include' });
            const data = await res.json();
            if (res.ok) applyState(data);
        } catch (_) { /* keep placeholders */ }
    }

    window.checkForUpdates = async function () {
        const btns = [document.getElementById('updateCheckBtn'), document.getElementById('updateCheckBtnManual')].filter(Boolean);
        btns.forEach((b) => { b.disabled = true; });
        try {
            const res = await fetch('/panel/settings/check-updates', { method: 'POST', credentials: 'include' });
            const data = await res.json();
            if (res.ok) {
                applyState(data);
                // Partial failure: HTTP 200 with stale/empty data because the
                // GitHub fetch failed. Tell the user instead of failing silently.
                if (data.error) {
                    showToast(t.error + ': ' + data.error, 'warning');
                }
            } else {
                showToast((data.error || t.error), 'error');
            }
        } catch (e) {
            showToast(t.error + ': ' + e.message, 'error');
        } finally {
            btns.forEach((b) => { b.disabled = false; });
        }
    };

    window.openUpdateModal = function () {
        if (!selectedVersion) return;
        document.getElementById('updateModalSummary').textContent = t.confirmSummary.replace('{version}', selectedVersion);
        document.getElementById('updatePassword').value = '';
        document.getElementById('updateTotp').value = '';
        document.getElementById('updateTotpGroup').style.display = totpEnabled ? '' : 'none';
        document.getElementById('updateBackup').checked = true;
        document.getElementById('updateModal').style.display = 'flex';
    };

    window.closeUpdateModal = function () {
        document.getElementById('updateModal').style.display = 'none';
    };

    window.submitUpdate = async function () {
        const password = document.getElementById('updatePassword').value;
        const totpToken = document.getElementById('updateTotp').value;
        const backup = document.getElementById('updateBackup').checked;
        if (!password) { showToast(t.passwordRequired, 'error'); return; }
        if (totpEnabled && !totpToken) { showToast(t.totpRequired, 'error'); return; }

        const confirmBtn = document.getElementById('updateConfirmBtn');
        confirmBtn.disabled = true;
        confirmBtn.textContent = t.starting;

        try {
            const res = await fetch('/panel/settings/apply-update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({ version: selectedVersion, currentPassword: password, totpToken, backup }),
            });
            const data = await res.json();
            if (res.status === 202) {
                closeUpdateModal();
                startProgressOverlay(selectedVersion);
            } else {
                showToast((data.error || t.failed), 'error');
                confirmBtn.disabled = false;
                confirmBtn.textContent = t.install;
            }
        } catch (e) {
            showToast(t.failed + ': ' + e.message, 'error');
            confirmBtn.disabled = false;
            confirmBtn.textContent = t.install;
        }
    };

    // Ordered pipeline stages shown in the overlay. Raw updater/flow step names
    // are mapped onto these four buckets so the UI stays readable regardless of
    // mode (hub vs source use different internal steps).
    const UPD_STAGES = [
        { id: 'backup', label: t.stepBackup, icon: 'ti-database' },
        { id: 'prepare', label: t.stepPrepare, icon: 'ti-git-branch' },
        { id: 'image', label: t.stepImage, icon: 'ti-package' },
        { id: 'restart', label: t.stepRestart, icon: 'ti-refresh' },
    ];

    function stageIndexFromStep(scope, step) {
        if (scope === 'flow') {
            if (step === 'backup') return 0;
            return 1; // trigger
        }
        // updater scope
        switch (step) {
            case 'start': case 'write-tag': case 'fetch': case 'checkout': case 'rollback-checkout': return 1;
            case 'pull': case 'build': return 2;
            case 'recreate': case 'up': return 3;
            case 'done': return 3;
            default: return 1;
        }
    }

    function renderStages() {
        const wrap = document.getElementById('updSteps');
        wrap.innerHTML = '';
        UPD_STAGES.forEach((s) => {
            const row = document.createElement('div');
            row.className = 'upd-step';
            row.dataset.stage = s.id;
            row.innerHTML = '<span class="upd-step-ic"><i class="ti ' + s.icon + '"></i></span>'
                + '<span class="upd-step-label">' + s.label + '</span>';
            wrap.appendChild(row);
        });
    }

    function setStepIcon(row, kind, fallbackIcon) {
        const ic = row.querySelector('.upd-step-ic i');
        if (kind === 'active') ic.className = 'ti ti-loader-2';
        else if (kind === 'done') ic.className = 'ti ti-check';
        else if (kind === 'error') ic.className = 'ti ti-x';
        else ic.className = 'ti ' + fallbackIcon;
    }

    // Mark stages: everything before activeIdx is done, activeIdx is active
    // (or error/allDone). activeIdx = stage index; opts.error / opts.allDone.
    function paintStages(activeIdx, opts = {}) {
        const rows = document.querySelectorAll('#updSteps .upd-step');
        rows.forEach((row, i) => {
            row.classList.remove('is-active', 'is-done', 'is-error');
            const stageIcon = UPD_STAGES[i].icon;
            if (opts.allDone) {
                row.classList.add('is-done');
                setStepIcon(row, 'done', stageIcon);
            } else if (i < activeIdx) {
                row.classList.add('is-done');
                setStepIcon(row, 'done', stageIcon);
            } else if (i === activeIdx) {
                if (opts.error) { row.classList.add('is-error'); setStepIcon(row, 'error', stageIcon); }
                else { row.classList.add('is-active'); setStepIcon(row, 'active', stageIcon); }
            } else {
                setStepIcon(row, 'pending', stageIcon);
            }
        });
    }

    function startProgressOverlay(targetVersion) {
        const overlay = document.getElementById('updateOverlay');
        const iconEl = document.getElementById('updIcon');
        const titleEl = document.getElementById('updTitle');
        const subEl = document.getElementById('updSub');
        const elapsedEl = document.getElementById('updElapsed');
        const logWrapEl = document.getElementById('updLogWrap');
        const logToggleEl = document.getElementById('updLogToggle');
        const logEl = document.getElementById('updLog');
        const actionsEl = document.getElementById('updActions');

        logToggleEl.onclick = () => {
            const open = logEl.style.display !== 'none';
            logEl.style.display = open ? 'none' : '';
            logToggleEl.classList.toggle('is-open', !open);
            logToggleEl.setAttribute('aria-expanded', String(!open));
            if (!open) logEl.scrollTop = logEl.scrollHeight;
        };

        renderStages();
        titleEl.textContent = t.inProgress;
        subEl.textContent = 'v' + currentVersion + '  →  v' + targetVersion;
        iconEl.className = 'upd-icon';
        iconEl.innerHTML = '<i class="ti ti-loader-2"></i>';
        overlay.style.display = 'flex';
        paintStages(0);

        let settled = false;
        let maxStage = 0;
        const started = Date.now();
        const POLL_TIMEOUT_MS = 30 * 60 * 1000;

        const elapsedTimer = setInterval(() => {
            const s = Math.floor((Date.now() - started) / 1000);
            const mm = String(Math.floor(s / 60)).padStart(2, '0');
            const ss = String(s % 60).padStart(2, '0');
            elapsedEl.textContent = mm + ':' + ss;
        }, 1000);

        function showLog(lines) {
            if (!lines || !lines.length) return;
            logWrapEl.style.display = '';
            const text = lines.join('\n');
            if (logEl.textContent !== text) {
                logEl.textContent = text;
                if (logEl.style.display !== 'none') logEl.scrollTop = logEl.scrollHeight;
            }
        }

        function openLog() {
            logWrapEl.style.display = '';
            logEl.style.display = '';
            logToggleEl.classList.add('is-open');
            logToggleEl.setAttribute('aria-expanded', 'true');
            logEl.scrollTop = logEl.scrollHeight;
        }

        // Advance the visible stage monotonically (never jump backwards on a
        // transient status blip).
        function advance(idx) {
            if (idx > maxStage) maxStage = idx;
            paintStages(maxStage);
        }

        function finishSuccess() {
            settled = true;
            clearInterval(elapsedTimer);
            paintStages(0, { allDone: true });
            iconEl.className = 'upd-icon is-success';
            iconEl.innerHTML = '<i class="ti ti-check"></i>';
            titleEl.textContent = t.success.replace('{version}', targetVersion);
            subEl.textContent = t.done;
            setTimeout(() => location.reload(), 1600);
        }

        function finishError(message, log) {
            settled = true;
            clearInterval(elapsedTimer);
            paintStages(maxStage, { error: true });
            iconEl.className = 'upd-icon is-error';
            iconEl.innerHTML = '<i class="ti ti-alert-triangle"></i>';
            titleEl.textContent = t.failed;
            subEl.textContent = message || '';
            if (log && log.length) { showLog(log); openLog(); }
            actionsEl.style.display = '';
        }

        async function poll() {
            if (settled) return;
            if (Date.now() - started > POLL_TIMEOUT_MS) {
                finishError(t.failed + ' (timeout)');
                return;
            }
            try {
                const res = await fetch('/panel/settings/update-status', { credentials: 'include', cache: 'no-store' });
                if (res.ok) {
                    const data = await res.json();
                    const u = data.updater || {};
                    const flow = data.flow || {};

                    // Panel-side failure (pre-update backup or trigger) happens
                    // before the updater touches anything - safe to stop.
                    if (flow.state === 'error') {
                        finishError(flow.error || '');
                        return;
                    }
                    if (flow.state === 'running' && flow.step) {
                        advance(stageIndexFromStep('flow', flow.step));
                    }

                    // Only trust the sidecar when its run started after our flow
                    // (it persists the LAST run; ISO timestamps compare lexically).
                    const updaterCurrent = !!(u.startedAt && flow.startedAt && u.startedAt >= flow.startedAt);
                    if (updaterCurrent) {
                        if (u.log) showLog(u.log);
                        if (u.state === 'running' && u.step) advance(stageIndexFromStep('updater', u.step));
                        if (u.state === 'error') { finishError(u.error || '', u.log); return; }
                    }

                    // Success once the running panel reports the new version.
                    if (cmp(String(data.currentVersion), String(targetVersion)) === 0 && (Date.now() - started) > 3000) {
                        finishSuccess();
                        return;
                    }
                }
            } catch (_) {
                // Panel is mid-restart and briefly unreachable - that IS the
                // final stage, so surface it as such.
                advance(3);
            }
            setTimeout(poll, 3000);
        }
        setTimeout(poll, 4000);
    }

    document.getElementById('updateVersionSelect')?.addEventListener('change', onVersionChange);
    document.getElementById('updateChangelogToggle')?.addEventListener('click', toggleChangelog);

    // Load current status once the maintenance tab is first shown, but cheaply on
    // page load is fine too (single cached call).
    loadStatus();
})();
</script>
