<% if (!enabled) { %>
<div class="alert alert-warning" style="margin-bottom: 16px;">
    <i class="ti ti-alert-triangle"></i>
    <%= t('accessLogs.disabledBanner') || 'Сбор access-логов выключен. Включите его в Настройках.' %>
    <a href="/panel/settings#tab-accessLogs" style="margin-left: 8px;"><%= t('nav.settings') || 'Настройки' %></a>
</div>
<% } %>

<div id="accessLogsApp" data-enabled="<%= enabled ? '1' : '0' %>">
    <!-- Indeterminate top progress bar; active whenever a request is in flight -->
    <div id="alProgress" class="al-progress"></div>

    <!-- Degraded-mode banner (toggled by JS) -->
    <div id="alDegraded" class="alert alert-info" style="display:none; margin-bottom:14px;">
        <i class="ti ti-info-circle"></i>
        <%= t('accessLogs.chRequired') || 'Функция требует ClickHouse. Настройте подключение в Настройках.' %>
    </div>

    <!-- Summary cards -->
    <div class="stats-grid stats-summary-grid" style="margin-bottom:16px;">
        <div class="stat-card">
            <div class="stat-header"><span class="stat-icon"><i class="ti ti-list"></i></span></div>
            <div class="stat-value" id="alTotal">—</div>
            <div class="stat-label"><%= t('accessLogs.statEvents') || 'Событий' %></div>
        </div>
        <div class="stat-card">
            <div class="stat-header"><span class="stat-icon"><i class="ti ti-users"></i></span></div>
            <div class="stat-value" id="alUsers">—</div>
            <div class="stat-label"><%= t('accessLogs.statUsers') || 'Пользователей' %></div>
        </div>
        <div class="stat-card">
            <div class="stat-header"><span class="stat-icon"><i class="ti ti-world"></i></span></div>
            <div class="stat-value" id="alIps">—</div>
            <div class="stat-label"><%= t('accessLogs.statUniqueIps') || 'Уникальных IP' %></div>
        </div>
        <div class="stat-card">
            <div class="stat-header"><span class="stat-icon"><i class="ti ti-map-pin"></i></span></div>
            <div class="stat-value" id="alDests">—</div>
            <div class="stat-label"><%= t('accessLogs.statUniqueDests') || 'Назначений' %></div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card" style="margin-bottom:16px;">
        <div class="card-body">
            <form id="alFilters" class="settings-grid" style="gap:12px;">
                <div class="form-group">
                    <label><%= t('accessLogs.filterFrom') || 'С' %></label>
                    <input type="datetime-local" name="from" id="alFrom">
                </div>
                <div class="form-group">
                    <label><%= t('accessLogs.filterTo') || 'По' %></label>
                    <input type="datetime-local" name="to" id="alTo">
                </div>
                <div class="form-group">
                    <label><%= t('accessLogs.filterNode') || 'Нода' %></label>
                    <select name="nodeId" id="alNode">
                        <option value=""><%= t('accessLogs.scopeAll') || 'Все' %></option>
                        <% (nodes || []).forEach(n => { %>
                            <option value="<%= n._id %>"><%= n.name %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label><%= t('accessLogs.filterUser') || 'Пользователь' %></label>
                    <input type="text" name="email" id="alEmail" placeholder="email">
                </div>
                <div class="form-group">
                    <label><%= t('accessLogs.filterSourceIp') || 'Source IP' %></label>
                    <input type="text" name="sourceIp" id="alSourceIp">
                </div>
                <div class="form-group">
                    <label><%= t('accessLogs.filterDestination') || 'Назначение' %></label>
                    <input type="text" name="destination" id="alDest">
                </div>
                <div class="form-group">
                    <label><%= t('accessLogs.filterProtocol') || 'Протокол' %></label>
                    <select name="network" id="alNetwork">
                        <option value=""><%= t('accessLogs.scopeAll') || 'Все' %></option>
                        <option value="tcp">tcp</option>
                        <option value="udp">udp</option>
                    </select>
                </div>
                <div class="form-group">
                    <label><%= t('accessLogs.filterAction') || 'Действие' %></label>
                    <select name="action" id="alAction">
                        <option value=""><%= t('accessLogs.scopeAll') || 'Все' %></option>
                        <option value="accepted">accepted</option>
                        <option value="rejected">rejected</option>
                        <option value="blocked">blocked</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>&nbsp;</label>
                    <div style="display:flex; gap:8px;">
                        <button type="submit" class="btn btn-primary" id="alSearchBtn">
                            <i class="ti ti-search" id="alSearchIcon"></i> <%= t('accessLogs.search') || 'Поиск' %>
                        </button>
                        <button type="button" class="btn" id="alReset"><%= t('common.reset') || 'Сброс' %></button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Charts -->
    <div class="al-charts-grid" style="margin-bottom:16px;">
        <div class="card al-chart-wide">
            <div class="card-header"><h2><i class="ti ti-chart-area"></i> <%= t('accessLogs.activityTimeline') || 'Активность во времени' %></h2></div>
            <div class="card-body al-chart-body"><canvas id="alTimeline"></canvas></div>
        </div>
        <div class="card">
            <div class="card-header"><h2><i class="ti ti-chart-donut"></i> <%= t('accessLogs.actionBreakdown') || 'Действия' %></h2></div>
            <div class="card-body al-chart-body al-chart-body-sm"><canvas id="alActionChart"></canvas></div>
        </div>
        <div class="card">
            <div class="card-header"><h2><i class="ti ti-chart-pie"></i> <%= t('accessLogs.protocolBreakdown') || 'Протоколы' %></h2></div>
            <div class="card-body al-chart-body al-chart-body-sm"><canvas id="alProtoChart"></canvas></div>
        </div>
    </div>

    <!-- Users: sharing + fan-out lenses -->
    <div class="al-row" style="margin-bottom:16px;">
        <div class="card al-col">
            <div class="card-header">
                <h2><i class="ti ti-user-share"></i> <%= t('accessLogs.usersByIp') || 'Пользователи по числу IP' %></h2>
            </div>
            <div class="card-body">
                <p class="hint" style="margin:0 0 10px;">
                    <%= t('accessLogs.usersByIpHint') || '' %>
                    <span class="hint"><%= t('accessLogs.usersByIpExpand') || 'Нажмите на пользователя, чтобы увидеть все его IP.' %></span>
                </p>
                <div style="overflow-x:auto;">
                    <table class="al-tbl">
                        <thead><tr>
                            <th><%= t('accessLogs.colUser') || 'Пользователь' %></th>
                            <th style="text-align:right;"><%= t('accessLogs.colIps') || 'IP' %></th>
                            <th style="text-align:right;"><%= t('accessLogs.colSubnets') || '/24' %></th>
                            <th style="text-align:right;"><%= t('accessLogs.colEvents') || 'Событий' %></th>
                            <th style="text-align:right;"><%= t('accessLogs.colLastSeen') || 'Активность' %></th>
                        </tr></thead>
                        <tbody id="alUsersByIp"></tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="card al-col">
            <div class="card-header">
                <h2><i class="ti ti-affiliate"></i> <%= t('accessLogs.usersByFanout') || 'Пользователи по назначениям' %></h2>
            </div>
            <div class="card-body">
                <p class="hint" style="margin:0 0 10px;"><%= t('accessLogs.usersByFanoutHint') || '' %></p>
                <div style="overflow-x:auto;">
                    <table class="al-tbl">
                        <thead><tr>
                            <th><%= t('accessLogs.colUser') || 'Пользователь' %></th>
                            <th style="text-align:right;"><%= t('accessLogs.colDests') || 'Назнач.' %></th>
                            <th style="text-align:right;"><%= t('accessLogs.colUdp') || 'UDP %' %></th>
                            <th style="text-align:right;"><%= t('accessLogs.colEvents') || 'Событий' %></th>
                        </tr></thead>
                        <tbody id="alUsersByFanout"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Top lists -->
    <div class="al-row al-row-3" style="margin-bottom:16px;">
        <div class="card al-col">
            <div class="card-header"><h2><i class="ti ti-map-pin"></i> <%= t('accessLogs.topDestinations') || 'Топ назначений' %></h2></div>
            <div class="card-body"><table class="al-tbl al-tbl-top"><tbody id="alTopDest"></tbody></table></div>
        </div>
        <div class="card al-col">
            <div class="card-header"><h2><i class="ti ti-plug"></i> <%= t('accessLogs.topPorts') || 'Топ портов' %></h2></div>
            <div class="card-body"><table class="al-tbl al-tbl-top"><tbody id="alTopPorts"></tbody></table></div>
        </div>
        <div class="card al-col">
            <div class="card-header"><h2><i class="ti ti-shield-x"></i> <%= t('accessLogs.topBlocked') || 'Топ заблокированных' %></h2></div>
            <div class="card-body"><table class="al-tbl al-tbl-top"><tbody id="alTopBlocked"></tbody></table></div>
        </div>
    </div>

    <!-- Recent events -->
    <div class="card" style="margin-bottom:16px;">
        <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
            <h2><i class="ti ti-list-details"></i> <%= t('accessLogs.recentEvents') || 'Последние события' %></h2>
            <span id="alResultCount" class="hint"></span>
        </div>
        <div class="card-body" style="overflow-x:auto;">
            <table class="al-tbl">
                <thead>
                    <tr>
                        <th><%= t('accessLogs.colTime') || 'Время' %></th>
                        <th><%= t('accessLogs.filterNode') || 'Нода' %></th>
                        <th><%= t('accessLogs.colUser') || 'Пользователь' %></th>
                        <th><%= t('accessLogs.colSource') || 'Источник' %></th>
                        <th><%= t('accessLogs.colDest') || 'Назначение' %></th>
                        <th><%= t('accessLogs.colNet') || 'Проток.' %></th>
                        <th><%= t('accessLogs.colAction') || 'Действие' %></th>
                    </tr>
                </thead>
                <tbody id="alResults"></tbody>
            </table>
            <div id="alNoResults" class="hint" style="display:none; padding:12px;">
                <%= t('accessLogs.noResults') || 'Ничего не найдено' %>
            </div>
        </div>
    </div>

    <!-- Node status + purge -->
    <div class="card">
        <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
            <h2><i class="ti ti-server-cog"></i> Status</h2>
            <span class="hint">Spool: <span id="alSpool">—</span></span>
        </div>
        <div class="card-body" style="overflow-x:auto;">
            <table class="al-tbl">
                <thead><tr><th><%= t('accessLogs.filterNode') || 'Нода' %></th><th>agent</th><th>status</th><th><%= t('accessLogs.lastIngestAt') || 'Последний приём' %></th><th>error</th></tr></thead>
                <tbody id="alNodeStatus"></tbody>
            </table>
            <hr class="settings-divider">
            <button type="button" class="btn btn-danger" id="alPurge">
                <i class="ti ti-trash"></i> <%= t('accessLogs.purge') || 'Очистить сохранённые логи' %>
            </button>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

<style>
.al-charts-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 16px;
}
.al-chart-wide { grid-column: auto; }
.al-chart-body { height: 280px; position: relative; }
.al-chart-body-sm { height: 280px; }
.al-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.al-row-3 { grid-template-columns: 1fr 1fr 1fr; }
/* ── Tables ─────────────────────────────────────────────────────────── */
.al-tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
.al-tbl thead th {
    text-align: left; font-weight: 600; font-size: 11px;
    text-transform: uppercase; letter-spacing: .04em;
    color: var(--text-muted, #8b8b96);
    padding: 8px 10px; white-space: nowrap;
    border-bottom: 1px solid var(--border-color, rgba(255,255,255,.08));
}
.al-tbl tbody td {
    padding: 9px 10px; vertical-align: middle;
    border-bottom: 1px solid var(--border-color, rgba(255,255,255,.05));
}
.al-tbl tbody tr:last-child td { border-bottom: 0; }
.al-tbl tbody tr:hover { background: rgba(255,255,255,.035); }
.al-tbl-top tbody td { padding: 7px 10px; }
.al-mono {
    font-family: 'JetBrains Mono', 'SFMono-Regular', ui-monospace, Consolas, monospace;
    font-size: 12px;
}
.al-trunc { max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.al-num { text-align: right; font-variant-numeric: tabular-nums; }

.al-badge {
    display: inline-block; padding: 2px 9px; border-radius: 999px;
    font-size: 11px; font-weight: 600; line-height: 1.5; white-space: nowrap;
}
.al-badge-accepted { background: rgba(34,197,94,.14); color: #4ade80; }
.al-badge-rejected { background: rgba(245,158,11,.15); color: #fbbf24; }
.al-badge-blocked  { background: rgba(239,68,68,.15);  color: #f87171; }
.al-badge-net      { background: rgba(99,102,241,.16); color: #a5b4fc; }
.al-badge-udp      { background: rgba(6,182,212,.16);  color: #67e8f9; }

.al-bar-cell { position: relative; }
.al-bar {
    position: absolute; right: 0; top: 4px; bottom: 4px;
    background: var(--accent-glow, rgba(124,58,237,.22));
    border-radius: 4px; z-index: 0;
}
.al-bar-label { position: relative; z-index: 1; font-variant-numeric: tabular-nums; }
.al-flag { color: var(--danger, #ef4444); font-weight: 600; }

/* ── Expandable user rows (per-user IP list) ────────────────────────── */
.al-user-row { cursor: pointer; }
.al-caret {
    display: inline-block; transition: transform .15s ease;
    color: var(--text-muted, #8b8b96); margin-right: 4px;
}
.al-user-row.open .al-caret { transform: rotate(90deg); }
.al-ip-detail > td { background: rgba(255,255,255,.02); padding: 10px 14px !important; }
.al-ip-wrap { display: flex; flex-wrap: wrap; gap: 8px; }
.al-ip-chip {
    display: inline-flex; flex-direction: column; gap: 1px;
    padding: 5px 10px; border-radius: 8px;
    background: rgba(255,255,255,.05);
    border: 1px solid var(--border-color, rgba(255,255,255,.07));
}
.al-ip-chip .al-ip-meta { font-size: 10.5px; color: var(--text-muted, #8b8b96); }
.al-empty { color: var(--text-muted, #8b8b96); padding: 12px 10px; }

/* ── Loading indicators ─────────────────────────────────────────────── */
.al-progress {
    position: relative; height: 3px; margin-bottom: 14px;
    border-radius: 3px; overflow: hidden; background: transparent;
    opacity: 0; transition: opacity .2s ease;
}
.al-progress.active { opacity: 1; }
.al-progress::before {
    content: ''; position: absolute; top: 0; bottom: 0; left: -45%; width: 45%;
    border-radius: 3px;
    background: linear-gradient(90deg, transparent, var(--accent, #7c3aed), transparent);
    animation: al-slide 1.1s ease-in-out infinite;
}
@keyframes al-slide { 0% { left: -45%; } 100% { left: 100%; } }

.al-spin { display: inline-block; animation: al-rot .7s linear infinite; }
@keyframes al-rot { to { transform: rotate(360deg); } }
#alSearchBtn[disabled] { opacity: .75; cursor: progress; }

/* Skeleton shimmer for first-load placeholders. */
.al-skel {
    display: inline-block; height: 1em; min-width: 40px; width: 100%;
    border-radius: 6px; vertical-align: middle;
    background: linear-gradient(90deg,
        rgba(255,255,255,.05) 25%,
        rgba(255,255,255,.12) 37%,
        rgba(255,255,255,.05) 63%);
    background-size: 400% 100%;
    animation: al-shimmer 1.3s ease infinite;
}
.stat-value .al-skel { height: 1.4em; max-width: 90px; }
@keyframes al-shimmer { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }

@media (max-width: 1100px) {
    .al-charts-grid { grid-template-columns: 1fr; }
    .al-row, .al-row-3 { grid-template-columns: 1fr; }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
<script>
window.__AL_I18N = {
    purgeConfirm: <%- JSON.stringify(t('accessLogs.purgeConfirm') || 'Удалить все сохранённые access-логи? Это необратимо.') %>,
    noResults: <%- JSON.stringify(t('accessLogs.noResults') || 'Ничего не найдено') %>,
    never: <%- JSON.stringify(t('settings.never') || 'никогда') %>,
    chRequired: <%- JSON.stringify(t('accessLogs.chRequired') || 'ClickHouse is required. Configure the connection in Settings.') %>,
    noIps: <%- JSON.stringify(t('accessLogs.noIps') || 'Нет IP за выбранный период.') %>,
    accepted: <%- JSON.stringify(t('accessLogs.stateActive') || 'accepted') %>,
    labels: {
        accepted: 'accepted', rejected: 'rejected', blocked: 'blocked', tcp: 'tcp', udp: 'udp'
    }
};
// Node id -> display name, so raw event rows show a readable node instead of a hash.
window.__AL_NODES = <%- JSON.stringify((nodes || []).reduce((m, n) => { m[String(n._id)] = n.name; return m; }, {})) %>;
</script>
<script defer src="/js/access-logs.js"></script>
