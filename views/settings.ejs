<% if (message) { %>
<div class="alert alert-success"><%= message %></div>
<% } %>
<% if (error) { %>
<div class="alert alert-error"><%= error %></div>
<% } %>

<style>
.settings-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--border);
    margin-bottom: 1.5rem;
    overflow-x: auto;
}
.settings-tab {
    padding: 0.75rem 1.25rem;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all 0.2s;
}
.settings-tab:hover {
    color: var(--text);
    background: var(--bg-tertiary);
}
.settings-tab.active {
    color: var(--primary);
    border-bottom-color: var(--primary);
}
.tab-content {
    display: none;
}
.tab-content.active {
    display: block;
}
.settings-section {
    margin-bottom: 1.5rem;
}
.settings-section:last-child {
    margin-bottom: 0;
}
.section-title {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
}
</style>

<div class="settings-tabs">
    <button class="settings-tab active" data-tab="system"><i class="ti ti-settings"></i> <%= t('settings.tabSystem') || 'Система' %></button>
    <button class="settings-tab" data-tab="subscription"><i class="ti ti-link"></i> <%= t('settings.tabSubscription') || 'Подписка' %></button>
    <button class="settings-tab" data-tab="security"><i class="ti ti-lock"></i> <%= t('settings.tabSecurity') || 'Безопасность' %></button>
    <button class="settings-tab" data-tab="backup"><i class="ti ti-device-floppy"></i> <%= t('settings.tabBackup') || 'Бэкапы' %></button>
    <button class="settings-tab" data-tab="maintenance"><i class="ti ti-tool"></i> <%= t('settings.tabMaintenance') || 'Обслуживание' %></button>
</div>

<!-- ==================== TAB: SYSTEM ==================== -->
<div class="tab-content active" id="tab-system">
    <!-- System Info Row -->
    <div class="row" style="margin-bottom: 1.5rem;">
        <div class="col-4">
            <div class="card">
                <div class="card-body" style="padding: 1rem;">
                    <div class="settings-list">
                        <div class="setting-item">
                            <label><%= t('settings.baseUrl') %></label>
                            <code style="font-size: 11px;"><%= config.BASE_URL %></code>
                        </div>
                        <div class="setting-item">
                            <label><%= t('settings.mongodb') %></label>
                            <code style="font-size: 11px;"><%= config.MONGO_URI.replace(/\/\/.*@/, '//***@').substring(0, 30) %>...</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-4">
            <div class="card">
                <div class="card-body" style="padding: 1rem;">
                    <div class="settings-list">
                        <div class="setting-item">
                            <label>Uptime</label>
                            <span><%= Math.floor(process.uptime() / 3600) %>h <%= Math.floor((process.uptime() % 3600) / 60) %>m</span>
                        </div>
                        <div class="setting-item">
                            <label>Memory / Node.js</label>
                            <span><%= Math.round(process.memoryUsage().heapUsed / 1024 / 1024) %> MB / <%= process.version %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-4">
            <div class="card">
                <div class="card-body" style="padding: 1rem;">
                    <% if (ssl.enabled) { %>
                    <div style="color: var(--success); font-weight: 500;"><i class="ti ti-shield-check"></i> HTTPS</div>
                    <div style="font-size: 12px; color: var(--text-muted);"><%= ssl.domain %></div>
                    <% } else { %>
                    <div style="color: var(--warning); font-weight: 500;"><i class="ti ti-alert-triangle"></i> HTTP</div>
                    <div style="font-size: 12px; color: var(--text-muted);">SSL не настроен</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    
    <!-- System Settings Form -->
    <form method="POST" action="/panel/settings">
        <!-- Row 1: Load Balancing + Limits -->
        <div class="row" style="margin-bottom: 1rem;">
            <div class="col-6">
                <div class="card">
                    <div class="card-header">
                        <h2><i class="ti ti-scale"></i> <%= t('settings.loadBalancing') %></h2>
                    </div>
                    <div class="card-body">
                        <div class="settings-list">
                            <label class="checkbox-label">
                                <input type="checkbox" name="loadBalancing.enabled" 
                                       <%= settings?.loadBalancing?.enabled ? 'checked' : '' %>>
                                <span><%= t('settings.loadBalancingEnabled') %></span>
                            </label>
                            <small class="hint" style="display: block; margin-top: 0.25rem;">
                                <%= t('settings.loadBalancingHint') %>
                            </small>
                            
                            <label class="checkbox-label" style="margin-top: 0.75rem;">
                                <input type="checkbox" name="loadBalancing.hideOverloaded" 
                                       <%= settings?.loadBalancing?.hideOverloaded ? 'checked' : '' %>>
                                <span><%= t('settings.hideOverloaded') %></span>
                            </label>
                            <small class="hint" style="display: block; margin-top: 0.25rem;">
                                <%= t('settings.hideOverloadedHint') %>
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-6">
                <div class="card">
                    <div class="card-header">
                        <h2><i class="ti ti-device-mobile"></i> <%= t('settings.deviceLimit') %> &amp; <i class="ti ti-shield"></i> <%= t('settings.rateLimiting') %></h2>
                    </div>
                    <div class="card-body">
                        <div class="settings-grid">
                            <div class="form-group">
                                <label for="deviceGracePeriod"><%= t('settings.gracePeriod') %></label>
                                <input type="number" name="deviceGracePeriod" id="deviceGracePeriod" 
                                       value="<%= settings?.deviceGracePeriod ?? 15 %>" min="1" max="60">
                                <small class="hint"><%= t('settings.gracePeriodHint') %></small>
                            </div>
                            <div class="form-group">
                                <label for="rateLimit.subscriptionPerMinute"><%= t('settings.subscriptionsPerMinute') %></label>
                                <input type="number" name="rateLimit.subscriptionPerMinute" id="rateLimit.subscriptionPerMinute" 
                                       value="<%= settings?.rateLimit?.subscriptionPerMinute || 100 %>" min="10" max="1000">
                                <small class="hint"><%= t('settings.subscriptionsPerMinuteHint') %></small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Row 2: Caching + SSH Pool -->
        <div class="row" style="margin-bottom: 1rem;">
            <div class="col-6">
                <div class="card">
                    <div class="card-header">
                        <h2><i class="ti ti-database"></i> <%= t('settings.caching') %></h2>
                    </div>
                    <div class="card-body">
                        <div class="settings-grid">
                            <div class="form-group">
                                <label for="cache.subscriptionTTL"><%= t('settings.subscriptionsTTL') %></label>
                                <input type="number" name="cache.subscriptionTTL" id="cache.subscriptionTTL" 
                                       value="<%= settings?.cache?.subscriptionTTL || 3600 %>" min="60" max="86400">
                                <small class="hint"><%= t('settings.subscriptionsTTLHint') %></small>
                            </div>
                            <div class="form-group">
                                <label for="cache.userTTL"><%= t('settings.usersTTL') %></label>
                                <input type="number" name="cache.userTTL" id="cache.userTTL" 
                                       value="<%= settings?.cache?.userTTL || 900 %>" min="60" max="3600">
                                <small class="hint"><%= t('settings.usersTTLHint') %></small>
                            </div>
                            <div class="form-group">
                                <label for="cache.onlineSessionsTTL"><%= t('settings.onlineSessionsTTL') %></label>
                                <input type="number" name="cache.onlineSessionsTTL" id="cache.onlineSessionsTTL" 
                                       value="<%= settings?.cache?.onlineSessionsTTL || 10 %>" min="5" max="60">
                                <small class="hint"><%= t('settings.onlineSessionsTTLHint') %></small>
                            </div>
                            <div class="form-group">
                                <label for="cache.activeNodesTTL"><%= t('settings.activeNodesTTL') %></label>
                                <input type="number" name="cache.activeNodesTTL" id="cache.activeNodesTTL" 
                                       value="<%= settings?.cache?.activeNodesTTL || 30 %>" min="10" max="300">
                                <small class="hint"><%= t('settings.activeNodesTTLHint') %></small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-6">
                <div class="card">
                    <div class="card-header">
                        <h2><i class="ti ti-plug-connected"></i> <%= t('settings.sshPool') %></h2>
                    </div>
                    <div class="card-body">
                        <label class="checkbox-label" style="margin-bottom: 0.75rem;">
                            <input type="checkbox" name="sshPool.enabled" 
                                   <%= settings?.sshPool?.enabled !== false ? 'checked' : '' %>>
                            <span><%= t('settings.sshPoolEnabled') %></span>
                        </label>
                        <div class="settings-grid">
                            <div class="form-group">
                                <label for="sshPool.maxIdleTime"><%= t('settings.sshPoolIdleTime') %></label>
                                <input type="number" name="sshPool.maxIdleTime" id="sshPool.maxIdleTime" 
                                       value="<%= settings?.sshPool?.maxIdleTime || 120 %>" min="30" max="600">
                            </div>
                            <div class="form-group">
                                <label for="sshPool.connectTimeout"><%= t('settings.sshPoolTimeout') %></label>
                                <input type="number" name="sshPool.connectTimeout" id="sshPool.connectTimeout" 
                                       value="<%= settings?.sshPool?.connectTimeout || 15 %>" min="5" max="60">
                            </div>
                            <div class="form-group">
                                <label for="sshPool.keepAliveInterval"><%= t('settings.sshPoolKeepalive') %></label>
                                <input type="number" name="sshPool.keepAliveInterval" id="sshPool.keepAliveInterval" 
                                       value="<%= settings?.sshPool?.keepAliveInterval || 30 %>" min="10" max="120">
                            </div>
                            <div class="form-group">
                                <label for="sshPool.maxRetries"><%= t('settings.sshPoolRetries') %></label>
                                <input type="number" name="sshPool.maxRetries" id="sshPool.maxRetries" 
                                       value="<%= settings?.sshPool?.maxRetries || 2 %>" min="0" max="5">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Save Button -->
        <div style="display: flex; justify-content: flex-end; margin-top: 0.5rem;">
            <button type="submit" class="btn btn-primary" style="padding: 0.75rem 2rem; font-size: 15px;">
                <i class="ti ti-device-floppy"></i> <%= t('settings.saveAllSettings') %>
            </button>
        </div>
    </form>
</div>

<!-- ==================== TAB: SUBSCRIPTION ==================== -->
<div class="tab-content" id="tab-subscription">
    <div class="card">
        <div class="card-header">
            <h2><i class="ti ti-device-mobile"></i> <%= t('settings.subClientApps') || 'Клиентские приложения' %></h2>
        </div>
        <div class="card-body">
            <form method="POST" action="/panel/settings">
                <input type="hidden" name="_subscriptionSettings" value="1">

                <div class="row" style="margin-bottom: 1rem;">
                    <div class="col-6">
                        <div class="form-group">
                            <label><%= t('settings.subLogoUrl') || 'URL логотипа' %></label>
                            <input type="url" name="subscription.logoUrl"
                                   value="<%= settings?.subscription?.logoUrl || '' %>"
                                   placeholder="https://example.com/logo.png"
                                   id="subLogoUrlInput"
                                   oninput="previewLogo(this.value)">
                            <small class="hint"><%= t('settings.subLogoUrlHint') || 'Ссылка на PNG/SVG/WebP. Оставьте пустым для иконки по умолчанию.' %></small>
                        </div>
                    </div>
                    <div class="col-6" style="display: flex; align-items: center; gap: 1rem; padding-top: 0.5rem;">
                        <div id="logoPreview" style="<%= settings?.subscription?.logoUrl ? '' : 'display:none;' %>">
                            <img id="logoPreviewImg"
                                 src="<%= settings?.subscription?.logoUrl || '' %>"
                                 style="height: 48px; border-radius: 8px; border: 1px solid var(--border); padding: 4px; background: #0a0a0a;"
                                 onerror="this.style.display='none'">
                        </div>
                        <div id="logoDefaultPreview" style="color: var(--text-muted); font-size: 13px; <%= settings?.subscription?.logoUrl ? 'display:none;' : '' %>">
                            <i class="ti ti-rocket" style="font-size: 32px;"></i>
                            <div style="font-size: 11px; margin-top: 4px;">по умолчанию</div>
                        </div>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 1rem;">
                    <label><%= t('settings.subPageTitle') || 'Заголовок страницы' %></label>
                    <input type="text" name="subscription.pageTitle"
                           value="<%= settings?.subscription?.pageTitle || '' %>"
                           placeholder="Подключение">
                    <small class="hint"><%= t('settings.subPageTitleHint') || 'Текст над логотипом. По умолчанию: «Подключение».' %></small>
                </div>

                <hr style="margin: 1.25rem 0; border-color: var(--border);">

                <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 1rem;">
                    <i class="ti ti-info-circle"></i>
                    Ссылки ниже отображаются в клиентах Hiddify / Clash как кнопки в карточке профиля.
                </p>

                <div class="settings-grid">
                    <div class="form-group">
                        <label><%= t('settings.subSupportUrl') || 'Ссылка на поддержку' %></label>
                        <input type="url" name="subscription.supportUrl"
                               value="<%= settings?.subscription?.supportUrl || '' %>"
                               placeholder="https://t.me/yoursupport">
                        <small class="hint"><%= t('settings.subSupportUrlHint') || 'Кнопка «Поддержка» в Hiddify.' %></small>
                    </div>
                    <div class="form-group">
                        <label><%= t('settings.subWebPageUrl') || 'Ссылка на веб-страницу' %></label>
                        <input type="url" name="subscription.webPageUrl"
                               value="<%= settings?.subscription?.webPageUrl || '' %>"
                               placeholder="https://example.com">
                        <small class="hint"><%= t('settings.subWebPageUrlHint') || 'Кнопка «Открыть веб-страницу» в Hiddify.' %></small>
                    </div>
                </div>

                <hr style="margin: 1.25rem 0; border-color: var(--border);">

                <div class="form-group" style="max-width: 300px;">
                    <label><%= t('settings.subHappProviderId') || 'HAPP Provider ID' %></label>
                    <input type="text" name="subscription.happProviderId"
                           value="<%= settings?.subscription?.happProviderId || '' %>"
                           placeholder="Ab12Cd34"
                           maxlength="8"
                           style="font-family: monospace; letter-spacing: 0.05em;">
                    <small class="hint"><%= t('settings.subHappProviderIdHint') || '8-символьный код из happ-proxy.com (опционально).' %></small>
                </div>

                <div style="display: flex; justify-content: flex-end; margin-top: 1.25rem;">
                    <button type="submit" class="btn btn-primary" style="padding: 0.75rem 2rem;">
                        <i class="ti ti-device-floppy"></i> <%= t('common.save') || 'Сохранить' %>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ==================== TAB: SECURITY ==================== -->
<div class="tab-content" id="tab-security">
    <div class="row">
        <div class="col-6">
            <div class="card">
                <div class="card-header">
                    <h2><i class="ti ti-user-shield"></i> <%= t('settings.administrator') %></h2>
                </div>
                <div class="card-body">
                    <div class="settings-list">
                        <div class="setting-item">
                            <label><%= t('settings.administrator') %></label>
                            <span><%= admin?.username || 'N/A' %></span>
                        </div>
                        <div class="setting-item">
                            <label><%= t('settings.lastLogin') %></label>
                            <span><%= admin?.lastLogin ? new Date(admin.lastLogin).toLocaleString(lang === 'en' ? 'en-US' : 'ru-RU') : t('settings.never') %></span>
                        </div>
                        <div class="setting-item">
                            <label><%= t('settings.ipWhitelist') %></label>
                            <span><%= config.PANEL_IP_WHITELIST || t('settings.ipWhitelistDisabled') %></span>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Node Auth API - под Администратором -->
            <div class="card" style="margin-top: 1rem;">
                <div class="card-header">
                    <h2><i class="ti ti-lock"></i> <%= t('settings.nodeAuth') || 'Node Auth API' %></h2>
                </div>
                <div class="card-body">
                    <form method="POST" action="/panel/settings">
                        <label class="checkbox-label" style="margin-bottom: 0.75rem;">
                            <input type="checkbox" name="nodeAuth.insecure"
                                   <%= settings?.nodeAuth?.insecure !== false ? 'checked' : '' %>>
                            <span><%= t('settings.nodeAuthInsecure') || 'Allow self-signed certificates' %></span>
                        </label>
                        <p class="hint" style="margin-bottom: 1rem;">
                            <%= t('settings.nodeAuthInsecureHint') || 'Enable if panel uses HTTP or self-signed SSL. Nodes will accept any certificate when connecting to auth API. Disable for production with valid SSL.' %>
                        </p>
                        <button type="submit" class="btn btn-primary"><%= t('common.save') || 'Save' %></button>
                    </form>
                </div>
            </div>
        </div>
        
        <div class="col-6">
            <div class="card">
                <div class="card-header">
                    <h2><i class="ti ti-key"></i> <%= t('settings.changePassword') %></h2>
                </div>
                <div class="card-body">
                    <form method="POST" action="/panel/settings/password">
                        <div class="form-group">
                            <label><%= t('settings.currentPassword') %></label>
                            <input type="password" name="currentPassword" required>
                        </div>
                        <div class="form-group">
                            <label><%= t('settings.newPassword') %></label>
                            <input type="password" name="newPassword" minlength="6" required>
                        </div>
                        <div class="form-group">
                            <label><%= t('settings.confirmPassword') %></label>
                            <input type="password" name="confirmPassword" minlength="6" required>
                        </div>
                        <button type="submit" class="btn btn-primary"><i class="ti ti-key"></i> <%= t('settings.changePasswordBtn') %></button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== API KEYS ==================== -->
    <div class="card" style="margin-top: 1.5rem;">
        <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
            <h2><i class="ti ti-api"></i> <%= t('apiKeys.title') || 'API Keys' %></h2>
            <button class="btn btn-primary btn-sm" onclick="openApiKeyModal()"><i class="ti ti-plus"></i> <%= t('apiKeys.create') || 'Create Key' %></button>
        </div>
        <div class="card-body" style="padding: 0;">
            <% if (!apiKeys || apiKeys.length === 0) { %>
            <div style="padding: 2rem; text-align:center; color: var(--text-muted); font-size:14px;">
                <%= t('apiKeys.empty') || 'No API keys yet. Create one to enable external integrations.' %>
            </div>
            <% } else { %>
            <div style="overflow-x:auto;">
                <table class="table" style="margin:0;">
                    <thead>
                        <tr>
                            <th><%= t('apiKeys.name') || 'Name' %></th>
                            <th><%= t('apiKeys.prefix') || 'Key Prefix' %></th>
                            <th><%= t('apiKeys.scopes') || 'Scopes' %></th>
                            <th><%= t('apiKeys.rateLimit') || 'Limit/min' %></th>
                            <th><%= t('apiKeys.lastUsed') || 'Last Used' %></th>
                            <th><%= t('apiKeys.expires') || 'Expires' %></th>
                            <th><%= t('common.status') %></th>
                            <th><%= t('common.actions') %></th>
                        </tr>
                    </thead>
                    <tbody>
                    <% apiKeys.forEach(key => { %>
                        <tr id="apikey-row-<%= key._id %>">
                            <td><strong><%= key.name %></strong></td>
                            <td><code style="font-size:12px;"><%= key.keyPrefix %>...</code></td>
                            <td>
                                <% (key.scopes || []).forEach(scope => { %>
                                <span class="badge" style="font-size:10px; margin:1px; background: var(--primary-dim, rgba(99,102,241,0.15)); color: var(--primary); border-radius:4px; padding:2px 6px;"><%= scope %></span>
                                <% }) %>
                                <% if (!key.scopes || key.scopes.length === 0) { %>
                                <span style="color:var(--text-muted); font-size:12px;">—</span>
                                <% } %>
                            </td>
                            <td style="font-size:13px;"><%= key.rateLimit %></td>
                            <td style="font-size:12px; color:var(--text-muted);">
                                <%= key.lastUsedAt ? new Date(key.lastUsedAt).toLocaleString(lang === 'en' ? 'en-US' : 'ru-RU') : '—' %>
                                <% if (key.lastUsedIP) { %><br><span style="font-size:11px;"><%= key.lastUsedIP %></span><% } %>
                            </td>
                            <td style="font-size:12px; color:var(--text-muted);">
                                <%= key.expiresAt ? new Date(key.expiresAt).toLocaleDateString(lang === 'en' ? 'en-US' : 'ru-RU') : '—' %>
                            </td>
                            <td>
                                <span class="status-badge <%= key.active ? 'online' : 'offline' %>">
                                    <%= key.active ? (t('common.active') || 'Active') : (t('common.inactive') || 'Inactive') %>
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm"
                                        data-id="<%= key._id %>"
                                        data-active="<%= key.active %>"
                                        onclick="toggleApiKey(this.dataset.id, this.dataset.active === 'true')"
                                        style="margin-right:4px;">
                                    <%= key.active ? t('common.disable') : t('common.enable') %>
                                </button>
                                <button class="btn btn-sm btn-danger"
                                        data-id="<%= key._id %>"
                                        data-name="<%= key.name %>"
                                        onclick="deleteApiKey(this.dataset.id, this.dataset.name)">
                                    <%= t('common.delete') %>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>
    </div>

    <!-- ==================== WEBHOOKS ==================== -->
    <div class="card" style="margin-top: 1.5rem;">
        <div class="card-header">
            <h2><i class="ti ti-webhook"></i> <%= t('webhooks.title') || 'Webhooks' %></h2>
        </div>
        <div class="card-body">
            <form method="POST" action="/panel/settings" id="webhookSettingsForm">
                <input type="hidden" name="_webhookSettings" value="1">

                <label class="checkbox-label" style="margin-bottom: 1rem;">
                    <input type="checkbox" name="webhook.enabled" id="webhookEnabled"
                           <%= settings?.webhook?.enabled ? 'checked' : '' %>>
                    <span><%= t('webhooks.enabled') || 'Enable webhooks' %></span>
                </label>

                <div id="webhookFields" style="<%= settings?.webhook?.enabled ? '' : 'display:none;' %>">
                    <div class="form-group">
                        <label><%= t('webhooks.url') || 'Webhook URL' %></label>
                        <div style="display:flex; gap:0.5rem;">
                            <input type="url" name="webhook.url" id="webhookUrl" placeholder="https://example.com/webhook"
                                   value="<%= settings?.webhook?.url || '' %>" style="flex:1;">
                            <button type="button" class="btn btn-sm" onclick="testWebhook()"><%= t('webhooks.test') || 'Test' %></button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label><%= t('webhooks.secret') || 'Secret (HMAC-SHA256)' %></label>
                        <input type="text" name="webhook.secret" placeholder="<%= t('webhooks.secretPlaceholder') || 'Leave empty to skip signature verification' %>"
                               value="<%= settings?.webhook?.secret || '' %>">
                        <small class="hint"><%= t('webhooks.secretHint') || 'Verify via X-Webhook-Signature header: sha256=HMAC-SHA256(secret, timestamp.body)' %></small>
                    </div>
                    <div class="form-group">
                        <label><%= t('webhooks.events') || 'Events' %> <small style="color:var(--text-muted);">(<%= t('webhooks.eventsHint') || 'empty = all events' %>)</small></label>
                        <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap:0.4rem; margin-top:0.5rem;">
                            <% (webhookEvents || []).forEach(ev => { %>
                            <label class="checkbox-label" style="font-size:13px;">
                                <input type="checkbox" name="webhook.events" value="<%= ev %>"
                                       <%= (settings?.webhook?.events || []).includes(ev) || (settings?.webhook?.events || []).length === 0 ? 'checked' : '' %>>
                                <span><code style="font-size:11px;"><%= ev %></code></span>
                            </label>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="margin-top: 0.75rem;"><%= t('common.save') %></button>
            </form>
        </div>
    </div>
</div>

<!-- ==================== API KEY MODAL ==================== -->
<div id="apiKeyModal" style="display:none; position:fixed; inset:0; z-index:1000; background:rgba(0,0,0,0.6); align-items:center; justify-content:center;">
    <div style="background:var(--bg-secondary, #1a1a1a); border:1px solid var(--border); border-radius:12px; padding:1.5rem; width:100%; max-width:520px; max-height:90vh; overflow-y:auto;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <h3 style="margin:0;"><%= t('apiKeys.createTitle') || 'Create API Key' %></h3>
            <button onclick="closeApiKeyModal()" style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-muted);">×</button>
        </div>
        <form id="apiKeyForm" onsubmit="submitApiKey(event)">
            <div class="form-group">
                <label><%= t('apiKeys.name') || 'Name' %> *</label>
                <input type="text" id="akName" placeholder="<%= t('apiKeys.namePlaceholder') || 'e.g. Telegram Bot' %>" required>
            </div>
            <div class="form-group">
                <label><%= t('apiKeys.scopes') || 'Scopes' %></label>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.35rem; margin-top:0.4rem;">
                    <% (validScopes || []).forEach(scope => { %>
                    <label class="checkbox-label" style="font-size:13px;">
                        <input type="checkbox" class="ak-scope" value="<%= scope %>">
                        <span><code style="font-size:11px;"><%= scope %></code></span>
                    </label>
                    <% }) %>
                </div>
                <small class="hint" style="margin-top:0.4rem; display:block;"><%= t('apiKeys.scopesHint') || 'No scopes selected = no access.' %></small>
            </div>
            <div class="form-group">
                <label><%= t('apiKeys.rateLimit') || 'Rate Limit (req/min)' %></label>
                <input type="number" id="akRateLimit" value="60" min="1" max="10000">
            </div>
            <div class="form-group">
                <label><%= t('apiKeys.allowedIPs') || 'Allowed IPs (one per line, empty = all)' %></label>
                <textarea id="akAllowedIPs" rows="3" placeholder="1.2.3.4&#10;5.6.7.8" style="width:100%; resize:vertical;"></textarea>
            </div>
            <div class="form-group">
                <label><%= t('apiKeys.expiresAt') || 'Expires At (optional)' %></label>
                <input type="date" id="akExpiresAt">
            </div>
            <div style="display:flex; gap:0.75rem; justify-content:flex-end; margin-top:1rem;">
                <button type="button" class="btn" onclick="closeApiKeyModal()"><%= t('common.cancel') %></button>
                <button type="submit" class="btn btn-primary" id="akSubmitBtn"><%= t('apiKeys.create') || 'Create' %></button>
            </div>
        </form>
    </div>
</div>

<!-- ==================== API KEY REVEAL MODAL ==================== -->
<div id="apiKeyRevealModal" style="display:none; position:fixed; inset:0; z-index:1001; background:rgba(0,0,0,0.7); align-items:center; justify-content:center;">
    <div style="background:var(--bg-secondary, #1a1a1a); border:1px solid var(--border); border-radius:12px; padding:1.5rem; width:100%; max-width:500px;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <h3 style="margin:0; color:var(--success, #22c55e);"><i class="ti ti-check"></i> <%= t('apiKeys.created') || 'Key Created' %></h3>
            <button onclick="closeRevealModal()" style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--text-muted);">×</button>
        </div>
        <div style="background:var(--warning-dim, rgba(245,158,11,0.1)); border:1px solid var(--warning, #f59e0b); border-radius:8px; padding:0.75rem; margin-bottom:1rem; font-size:13px; color:var(--warning, #f59e0b);">
            <i class="ti ti-alert-triangle"></i> <%= t('apiKeys.revealWarning') || 'Copy this key now. It will never be shown again.' %>
        </div>
        <div style="display:flex; gap:0.5rem; margin-bottom:1rem;">
            <input type="text" id="revealKeyInput" readonly style="flex:1; font-family:monospace; font-size:13px; background:var(--bg-tertiary, #111); border:1px solid var(--border);">
            <button class="btn btn-primary" onclick="copyRevealKey()"><%= t('apiKeys.copy') || 'Copy' %></button>
        </div>
        <button class="btn" style="width:100%;" onclick="closeRevealModal()"><%= t('apiKeys.done') || 'Done, I copied it' %></button>
    </div>
</div>

<script>
// ── API Keys ──

function openApiKeyModal() {
    document.getElementById('apiKeyModal').style.display = 'flex';
}

function closeApiKeyModal() {
    document.getElementById('apiKeyModal').style.display = 'none';
    document.getElementById('apiKeyForm').reset();
}

function closeRevealModal() {
    document.getElementById('apiKeyRevealModal').style.display = 'none';
    window.location.reload();
}

function copyRevealKey() {
    const input = document.getElementById('revealKeyInput');
    input.select();
    navigator.clipboard?.writeText(input.value).catch(() => document.execCommand('copy'));
    const btn = event.target;
        btn.innerHTML = '<i class="ti ti-check"></i>';
    setTimeout(() => btn.textContent = '<%= t("apiKeys.copy") || "Copy" %>', 1500);
}

async function submitApiKey(e) {
    e.preventDefault();
    const btn = document.getElementById('akSubmitBtn');
    btn.disabled = true;
    btn.textContent = '...';

    const scopes = [...document.querySelectorAll('.ak-scope:checked')].map(c => c.value);

    const body = new URLSearchParams();
    body.append('name', document.getElementById('akName').value);
    scopes.forEach(s => body.append('scopes', s));
    body.append('rateLimit', document.getElementById('akRateLimit').value);
    body.append('allowedIPs', document.getElementById('akAllowedIPs').value);
    const exp = document.getElementById('akExpiresAt').value;
    if (exp) body.append('expiresAt', exp);

    try {
        const res = await fetch('/panel/api-keys', { method: 'POST', body, headers: { 'Content-Type': 'application/x-www-form-urlencoded' } });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');
        closeApiKeyModal();
        document.getElementById('revealKeyInput').value = data.key;
        document.getElementById('apiKeyRevealModal').style.display = 'flex';
    } catch (err) {
        alert(err.message);
    } finally {
        btn.disabled = false;
        btn.textContent = '<%= t("apiKeys.create") || "Create" %>';
    }
}

async function toggleApiKey(id, currentActive) {
    if (!confirm(currentActive ? '<%= t("apiKeys.confirmDisable") || "Disable this key?" %>' : '<%= t("apiKeys.confirmEnable") || "Enable this key?" %>')) return;
    try {
        const res = await fetch(`/panel/api-keys/${id}/toggle`, { method: 'POST' });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error);
        window.location.reload();
    } catch (err) {
        alert(err.message);
    }
}

async function deleteApiKey(id, name) {
    if (!confirm(`<%= t("apiKeys.confirmDelete") || "Delete key" %> "${name}"?`)) return;
    try {
        const res = await fetch(`/panel/api-keys/${id}/delete`, { method: 'POST' });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error);
        document.getElementById(`apikey-row-${id}`)?.remove();
    } catch (err) {
        alert(err.message);
    }
}

// ── Subscription logo preview ──

function previewLogo(url) {
    const preview = document.getElementById('logoPreview');
    const img = document.getElementById('logoPreviewImg');
    const def = document.getElementById('logoDefaultPreview');
    if (url) {
        img.src = url;
        img.style.display = '';
        preview.style.display = '';
        def.style.display = 'none';
    } else {
        preview.style.display = 'none';
        def.style.display = '';
    }
}

// ── Webhooks ──

document.getElementById('webhookEnabled')?.addEventListener('change', function() {
    document.getElementById('webhookFields').style.display = this.checked ? '' : 'none';
});

async function testWebhook() {
    const url = document.getElementById('webhookUrl').value.trim();
    const secret = document.querySelector('[name="webhook.secret"]')?.value || '';
    if (!url) { alert('<%= t("webhooks.urlRequired") || "Enter a URL first" %>'); return; }

    const btn = event.target;
    btn.disabled = true;
    btn.textContent = '...';

    try {
        const body = new URLSearchParams({ url, secret });
        const res = await fetch('/panel/settings/test-webhook', { method: 'POST', body, headers: { 'Content-Type': 'application/x-www-form-urlencoded' } });
        const data = await res.json();
        if (data.success) {
            btn.textContent = `✓ HTTP ${data.status}`;
            btn.style.color = 'var(--success)';
        } else {
            btn.textContent = `✗ ${data.status || data.error}`;
            btn.style.color = 'var(--danger, #ef4444)';
        }
    } catch (err) {
        btn.textContent = '✗ Error';
        btn.style.color = 'var(--danger, #ef4444)';
    } finally {
        btn.disabled = false;
        setTimeout(() => { btn.textContent = '<%= t("webhooks.test") || "Test" %>'; btn.style.color = ''; }, 3000);
    }
}
</script>

