<div class="page-header sticky-header">
    <div class="page-header-left">
        <div class="view-tabs">
            <button class="view-tab active" id="tabList" onclick="switchNodesView('list')">
                <i class="ti ti-list"></i> <%= t('nodes.title') %>
                <span class="tab-badge"><%= nodes.length %></span>
            </button>
            <button class="view-tab" id="tabNetwork" onclick="switchNodesView('network')">
                <i class="ti ti-topology-star-3"></i> <%= t('network.title') %>
                <% if (linksCount) { %><span class="tab-badge"><%= linksCount %></span><% } %>
            </button>
        </div>
    </div>
    <div class="page-header-center" id="listFilters">
        <div class="filters-bar">
            <select id="filterStatus" class="filter-select" onchange="applyFilters()">
                <option value=""><%= t('nodes.allStatuses') %></option>
                <option value="online"><%= t('nodes.statusOnline') %></option>
                <option value="offline"><%= t('nodes.statusOffline') %></option>
                <option value="error"><%= t('nodes.statusError') %></option>
            </select>
            <select id="filterGroup" class="filter-select" onchange="applyFilters()">
                <option value=""><%= t('users.allGroups') %></option>
                <% if (groups) { groups.forEach(group => { %>
                <option value="<%= group._id %>"><%= group.name %></option>
                <% }); } %>
            </select>
        </div>
    </div>
    <div class="page-header-center" id="networkToolbar" style="display:none">
        <div class="filters-bar">
            <button class="btn btn-sm" id="btnAutoLayout" title="<%= t('network.autoLayout') %>">
                <i class="ti ti-layout-distribute-horizontal"></i> <%= t('network.autoLayout') %>
            </button>
            <button class="btn btn-sm" id="btnFitView" title="<%= t('network.fitView') %>">
                <i class="ti ti-arrows-maximize"></i>
            </button>
            <button class="btn btn-sm" id="btnRefresh" title="<%= t('network.refresh') %>">
                <i class="ti ti-refresh"></i>
            </button>
        </div>
    </div>
    <div class="page-header-right" id="listActions">
        <a href="/panel/nodes/add" class="btn btn-primary"><i class="ti ti-server-2"></i> <%= t('nodes.addNode') %></a>
    </div>
    <div class="page-header-right" id="networkActions" style="display:none">
        <button class="btn btn-primary" id="btnAddLink"><i class="ti ti-plus"></i> <%= t('network.addLink') %></button>
    </div>
</div>

<div id="viewList">
<div class="card">
    <div class="card-body no-padding">
        <div class="table-wrapper">
            <table class="table" id="nodesTable">
                <thead>
                    <tr>
                        <th><%= t('common.name') %></th>
                        <th><%= t('common.server') %></th>
                        <th><%= t('common.ports') %></th>
                        <th><%= t('common.status') %></th>
                        <th><%= t('common.online') %></th>
                        <th><%= t('nodes.groups') %></th>
                        <th><%= t('nodes.nodeInfo') %></th>
                        <th><%= t('common.actions') %></th>
                    </tr>
                </thead>
                <tbody>
                    <% if (nodes.length === 0) { %>
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            <div class="empty-state">
                                <span class="empty-icon"><i class="ti ti-server"></i></span>
                                <p><%= t('nodes.noNodes') %></p>
                                <a href="/panel/nodes/add" class="btn btn-primary"><%= t('nodes.addFirstNode') %></a>
                            </div>
                        </td>
                    </tr>
                    <% } %>
                    <% nodes.forEach(node => { 
                        const groupIds = (node.groups || []).map(g => g._id?.toString() || g.toString()).join(',');
                    %>
                    <tr class="node-row" data-status="<%= node.status %>" data-groups="<%= groupIds %>" data-active="<%= node.active %>">
                        <td>
                            <div class="node-name-cell">
                                <% if (node.flag) { %><span class="node-flag"><%= node.flag %></span><% } %>
                                <div>
                                    <strong><%= node.name %></strong>
                                    <% if (node.type === 'xray') { %>
                                    <img src="/img/xray.svg" alt="Xray" title="Xray VLESS" style="width:16px;height:16px;vertical-align:middle;margin-left:6px;opacity:0.7;">
                                    <% } else { %>
                                    <img src="/img/hysteria.svg" alt="Hysteria" title="Hysteria 2" style="width:16px;height:16px;vertical-align:middle;margin-left:6px;opacity:0.7;">
                                    <% } %>
                                    <% if (node.cascadeRole && node.cascadeRole !== 'standalone') { %>
                                    <span class="badge-cascade <%= node.cascadeRole %>"><%= node.cascadeRole.toUpperCase() %></span>
                                    <% } %>
                                    <% if (node.domain) { %>
                                    <br><small class="text-muted"><%= node.domain %></small>
                                    <% } %>
                                </div>
                            </div>
                        </td>
                        <td><code><%= node.ip %></code></td>
                        <td>
                            <code><%= node.port %></code>
                            <% if (node.portRange) { %>
                            <br><small class="text-muted">hop: <%= node.portRange %></small>
                            <% } %>
                        </td>
                        <td>
                            <span class="badge badge-<%= node.status === 'online' ? 'success' : (node.status === 'error' ? 'danger' : 'warning') %>">
                                <%= node.status %>
                            </span>
                            <% if (!node.active) { %>
                            <span class="badge badge-secondary"><%= t('nodes.off') %></span>
                            <% } %>
                        </td>
                        <td>
                            <span class="<%= node.maxOnlineUsers && node.onlineUsers >= node.maxOnlineUsers ? 'text-danger' : '' %>">
                                <%= node.onlineUsers || 0 %><% if (node.maxOnlineUsers) { %>/<%= node.maxOnlineUsers %><% } %>
                            </span>
                        </td>
                        <td>
                            <% if (node.groups && node.groups.length > 0) { %>
                                <% node.groups.slice(0,2).forEach(group => { %>
                                    <span class="group-tag-sm" style="background: <%= group.color %>20; border-color: <%= group.color %>; color: <%= group.color %>">
                                        <%= group.name %>
                                    </span>
                                <% }); %>
                                <% if (node.groups.length > 2) { %>
                                    <span class="group-more">+<%= node.groups.length - 2 %></span>
                                <% } %>
                            <% } else { %>
                                <span class="text-muted"><%= t('common.all') %></span>
                            <% } %>
                        </td>
                        <td class="node-info-cell">
                            <% if (node.type === 'xray') { %>
                                <% if (node.xrayVersion) { %>
                                <span class="node-info-badge" title="<%= t('nodes.xrayVersion') %>">
                                    <img src="/img/xray.svg" style="width:12px;height:12px;vertical-align:middle;"> v<%= node.xrayVersion %>
                                </span>
                                <% } %>
                                <span class="node-info-badge badge-agent-<%= node.agentStatus || 'unknown' %>" title="<%= t('nodes.agentStatus') %>">
                                    <i class="ti ti-cpu"></i> <%= node.agentStatus || 'unknown' %>
                                </span>
                            <% } else { %>
                                <span class="text-muted">—</span>
                            <% } %>
                        </td>
                        <td>
                            <div class="node-actions">
                                <button class="btn-icon" onclick="restartNode('<%= node._id %>')" title="<%= t('nodes.restart') %>" <%= !node.ssh?.password ? 'disabled' : '' %>><i class="ti ti-refresh"></i></button>
                                <a href="/panel/nodes/<%= node._id %>/terminal" class="btn-icon" title="<%= t('nodes.terminal') %>" <%= !node.ssh?.password ? 'style="pointer-events:none;opacity:0.5"' : '' %>><i class="ti ti-terminal-2"></i></a>
                                <a href="/panel/nodes/<%= node._id %>" class="btn-icon" title="<%= t('common.edit') %>"><i class="ti ti-pencil"></i></a>
                                <button class="btn-icon btn-icon-danger" onclick="deleteNode('<%= node._id %>')" title="<%= t('common.delete') %>"><i class="ti ti-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        
        <!-- Mobile Cards -->
        <div class="mobile-nodes-list">
            <% if (nodes.length === 0) { %>
                <div style="text-align: center; padding: 40px 20px;">
                    <p style="color: var(--text-muted); margin-bottom: 16px;"><%= t('nodes.noNodes') %></p>
                    <a href="/panel/nodes/add" class="btn btn-primary btn-sm"><%= t('nodes.addFirstNode') %></a>
                </div>
            <% } %>
            <% nodes.forEach(node => { 
                const groupIds = (node.groups || []).map(g => g._id?.toString() || g.toString()).join(',');
            %>
                <div class="mobile-node-card node-row-mobile" data-status="<%= node.status %>" data-groups="<%= groupIds %>">
                    <div class="mobile-node-header">
                        <div class="mobile-node-title">
                            <% if (node.flag) { %><span><%= node.flag %></span><% } %>
                            <strong><%= node.name %></strong>
                            <code style="font-size: 11px;"><%= node.ip %></code>
                        </div>
                        <span class="badge badge-<%= node.status === 'online' ? 'success' : (node.status === 'error' ? 'danger' : 'warning') %>">
                            <%= node.status %>
                        </span>
                    </div>
                    
                    <div class="mobile-node-stats">
                        <div class="mobile-stat-item">
                            <span class="mobile-stat-label"><%= t('common.online') %></span>
                            <span class="mobile-stat-value"><%= node.onlineUsers || 0 %><% if (node.maxOnlineUsers) { %>/<%= node.maxOnlineUsers %><% } %></span>
                        </div>
                        <div class="mobile-stat-item">
                            <span class="mobile-stat-label"><%= t('common.ports') %></span>
                            <span class="mobile-stat-value"><%= node.port %></span>
                        </div>
                    </div>
                    
                    <div class="mobile-node-actions">
                        <button class="btn btn-sm" onclick="restartNode('<%= node._id %>')" <%= !node.ssh?.password ? 'disabled' : '' %>><i class="ti ti-refresh"></i> <%= t('nodes.restart') %></button>
                        <a href="/panel/nodes/<%= node._id %>" class="btn btn-sm" style="flex: 1;"><i class="ti ti-pencil"></i> <%= t('common.edit') %></a>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</div>
</div><!-- /viewList -->

<!-- Network Map View (hidden by default, loaded on demand) -->
<div id="viewNetwork" style="display:none">
    <link rel="stylesheet" href="/css/network.css">
    <div class="network-page">
        <div class="network-container">
            <div id="cy" class="cytoscape-canvas"></div>

            <!-- Empty state -->
            <div class="network-empty" id="networkEmpty" style="display:none">
                <i class="ti ti-topology-star-3"></i>
                <p><%= t('network.noNodesOrLinks') %></p>
            </div>

            <!-- Legend -->
            <div class="network-legend" id="networkLegend">
                <div class="legend-title"><%= t('network.legendTitle') %></div>
                <div class="legend-section">
                    <div class="legend-item"><span class="legend-dot" style="background:#22c55e"></span><%= t('network.legendOnline') %></div>
                    <div class="legend-item"><span class="legend-dot" style="background:#ef4444"></span><%= t('network.legendOffline') %></div>
                    <div class="legend-item"><span class="legend-dot" style="background:#3b82f6"></span><%= t('network.legendDeployed') %></div>
                    <div class="legend-item"><span class="legend-dot" style="background:#64748b"></span><%= t('network.legendPending') %></div>
                </div>
                <div class="legend-divider"></div>
                <div class="legend-section">
                    <div class="legend-item"><span class="legend-role legend-portal"></span><%= t('network.legendPortal') %></div>
                    <div class="legend-item"><span class="legend-role legend-bridge"></span><%= t('network.legendBridge') %></div>
                    <div class="legend-item"><span class="legend-role legend-relay"></span><%= t('network.legendRelay') %></div>
                </div>
            </div>
        </div>

    </div>

    <!-- Node/Edge info modal -->
    <div class="modal-overlay" id="nodeInfoModal">
        <div class="modal-card modal-card-sm">
            <div class="modal-header">
                <h3 id="nodeInfoTitle"><i class="ti ti-info-circle"></i> <span id="nodeInfoTitleText"></span></h3>
                <button class="modal-close" id="nodeInfoClose"><i class="ti ti-x"></i></button>
            </div>
            <div class="modal-body" id="nodeInfoBody"></div>
        </div>
    </div>

    <!-- Add Link Modal -->
    <div class="modal-overlay" id="addLinkModal">
        <div class="modal-card modal-card-lg">
            <div class="modal-header">
                <h3><i class="ti ti-link"></i> <span id="linkModalTitle"><%= t('network.addLink') %></span></h3>
                <button class="modal-close" id="modalClose"><i class="ti ti-x"></i></button>
            </div>
            <form id="addLinkForm" class="modal-body">
                <input type="hidden" name="linkId" id="linkIdInput" value="">
                <div class="form-group">
                    <label><%= t('network.linkName') %></label>
                    <input type="text" name="name" class="form-input" required placeholder="YandexCloud → France">
                </div>

                <!-- Mode Switcher -->
                <div class="form-group">
                    <label><%= t('network.linkMode') %></label>
                    <div class="mode-switcher" id="modeSwitcher">
                        <button type="button" class="mode-btn active" data-mode="reverse">
                            <i class="ti ti-arrows-exchange"></i> <%= t('network.modeReverse') %>
                        </button>
                        <button type="button" class="mode-btn" data-mode="forward">
                            <i class="ti ti-arrow-right"></i> <%= t('network.modeForward') %>
                        </button>
                    </div>
                    <input type="hidden" name="mode" id="linkModeInput" value="reverse">
                    <div class="form-hint" id="modeHint"><%= t('network.modeReverseHint') %></div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label><%= t('network.portalNode') %></label>
                        <select name="portalNodeId" class="form-input" id="selectPortal" required></select>
                    </div>
                    <div class="form-group">
                        <label><%= t('network.bridgeNode') %></label>
                        <select name="bridgeNodeId" class="form-input" id="selectBridge" required></select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label><%= t('network.tunnelPort') %></label>
                        <input type="number" name="tunnelPort" class="form-input" value="10086" min="1" max="65535">
                    </div>
                    <div class="form-group">
                        <label><%= t('network.tunnelProtocol') %></label>
                        <select name="tunnelProtocol" class="form-input">
                            <option value="vless">VLESS</option>
                            <option value="vmess">VMess</option>
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label><%= t('network.tunnelTransport') %></label>
                        <select name="tunnelTransport" class="form-input" id="selectTransport">
                            <option value="tcp">TCP</option>
                            <option value="ws">WebSocket</option>
                            <option value="grpc">gRPC</option>
                            <option value="splithttp">SplitHTTP</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label><%= t('network.tunnelSecurity') %></label>
                        <select name="tunnelSecurity" class="form-input" id="selectSecurity">
                            <option value="none">None</option>
                            <option value="tls">TLS</option>
                            <option value="reality">REALITY</option>
                        </select>
                    </div>
                </div>

                <!-- REALITY Settings (hidden by default) -->
                <div class="form-section" id="realitySection" style="display:none">
                    <div class="form-section-title"><i class="ti ti-shield-lock"></i> REALITY</div>
                    <div class="form-row">
                        <div class="form-group">
                            <label><%= t('network.realityDest') %></label>
                            <input type="text" name="realityDest" class="form-input" placeholder="www.google.com:443">
                        </div>
                        <div class="form-group">
                            <label><%= t('network.realitySni') %></label>
                            <input type="text" name="realitySni" class="form-input" placeholder="www.google.com">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label><%= t('network.realityPrivateKey') %></label>
                            <input type="text" name="realityPrivateKey" class="form-input" placeholder="Server private key">
                        </div>
                        <div class="form-group">
                            <label><%= t('network.realityPublicKey') %></label>
                            <input type="text" name="realityPublicKey" class="form-input" placeholder="Client public key">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label><%= t('network.realityShortIds') %></label>
                            <input type="text" name="realityShortIds" class="form-input" placeholder="Short ID (hex)">
                        </div>
                        <div class="form-group">
                            <label><%= t('network.realityFingerprint') %></label>
                            <select name="realityFingerprint" class="form-input">
                                <option value="chrome">Chrome</option>
                                <option value="firefox">Firefox</option>
                                <option value="safari">Safari</option>
                                <option value="random">Random</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Advanced Options -->
                <details class="form-details">
                    <summary><%= t('network.advancedOptions') %></summary>

                    <!-- MUX -->
                    <div class="form-row" style="margin-top:10px">
                        <div class="form-group">
                            <label class="form-checkbox">
                                <input type="checkbox" name="muxEnabled" id="muxEnabledCheck">
                                <span><%= t('network.muxEnabled') %></span>
                            </label>
                        </div>
                        <div class="form-group">
                            <label><%= t('network.muxConcurrency') %></label>
                            <input type="number" name="muxConcurrency" class="form-input" value="8" min="1" max="64">
                        </div>
                    </div>

                    <!-- Geo Routing -->
                    <div class="form-group">
                        <label class="form-checkbox">
                            <input type="checkbox" id="geoRoutingEnabled">
                            <span><%= t('network.geoRoutingEnabled') %></span>
                        </label>
                    </div>
                    <div id="geoRoutingFields" style="display:none">
                        <div class="form-row">
                            <div class="form-group">
                                <label><%= t('network.geoRoutingDomains') %></label>
                                <input type="text" id="geoRoutingDomains" class="form-input" placeholder="cn, google, category-ads">
                            </div>
                            <div class="form-group">
                                <label><%= t('network.geoRoutingGeoip') %></label>
                                <input type="text" id="geoRoutingGeoip" class="form-input" placeholder="cn, ru, us">
                            </div>
                        </div>
                    </div>

                    <!-- Priority -->
                    <div class="form-row">
                        <div class="form-group">
                            <label><%= t('network.priority') %></label>
                            <input type="number" name="priority" class="form-input" value="100" min="1" max="999">
                        </div>
                        <div class="form-group">
                            <!-- Tunnel domain (reverse only) -->
                            <div id="tunnelDomainGroup">
                                <label><%= t('network.tunnelDomain') %></label>
                                <input type="text" name="tunnelDomain" class="form-input" value="reverse.tunnel.internal">
                            </div>
                        </div>
                    </div>
                </details>

                <div class="form-actions">
                    <label class="form-checkbox" style="margin-right:auto">
                        <input type="checkbox" name="autoDeploy" checked>
                        <span><%= t('network.autoDeploy') %></span>
                    </label>
                    <button type="button" class="btn" id="modalCancel"><%= t('common.cancel') %></button>
                    <button type="submit" class="btn btn-primary" id="linkModalSubmit"><%= t('network.createLink') %></button>
                </div>
            </form>
        </div>
    </div>

    <!-- Quick Link Modal (opened by drag-to-create on map) -->
    <div class="modal-overlay" id="quickLinkModal">
        <div class="modal-card modal-card-sm">
            <div class="modal-header">
                <h3><i class="ti ti-link"></i> <span id="quickLinkTitle"><%= t('network.quickLinkTitle') %></span></h3>
                <button class="modal-close" id="quickModalClose"><i class="ti ti-x"></i></button>
            </div>
            <form id="quickLinkForm" class="modal-body">
                <input type="hidden" id="quickPortalId">
                <input type="hidden" id="quickBridgeId">
                <input type="hidden" id="quickLinkMode" value="reverse">
                <div class="quick-link-nodes">
                    <div class="quick-node portal">
                        <div class="quick-node-label"><%= t('network.quickLinkPortal') %></div>
                        <div class="quick-node-name" id="quickPortalName"></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-icon" id="quickSwapBtn" title="<%= t('network.swapNodes') %>">
                        <i class="ti ti-arrows-exchange"></i>
                    </button>
                    <div class="quick-node bridge">
                        <div class="quick-node-label"><%= t('network.quickLinkBridge') %></div>
                        <div class="quick-node-name" id="quickBridgeName"></div>
                    </div>
                </div>
                <!-- Quick Mode Switcher -->
                <div class="form-group" style="margin-top:10px">
                    <div class="mode-switcher mode-switcher-sm" id="quickModeSwitcher">
                        <button type="button" class="mode-btn active" data-mode="reverse">
                            <i class="ti ti-arrows-exchange"></i> <%= t('network.modeReverse') %>
                        </button>
                        <button type="button" class="mode-btn" data-mode="forward">
                            <i class="ti ti-arrow-right"></i> <%= t('network.modeForward') %>
                        </button>
                    </div>
                </div>
                <div class="form-group">
                    <label><%= t('network.linkName') %></label>
                    <input type="text" id="quickLinkName" class="form-input" required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label><%= t('network.tunnelPort') %></label>
                        <input type="number" id="quickTunnelPort" class="form-input" value="10086" min="1" max="65535">
                    </div>
                    <div class="form-group">
                        <label><%= t('network.tunnelProtocol') %></label>
                        <select id="quickTunnelProtocol" class="form-input">
                            <option value="vless">VLESS</option>
                            <option value="vmess">VMess</option>
                        </select>
                    </div>
                </div>
                <div class="form-actions">
                    <label class="form-checkbox" style="margin-right:auto">
                        <input type="checkbox" id="quickAutoDeploy" checked>
                        <span><%= t('network.autoDeploy') %></span>
                    </label>
                    <button type="button" class="btn" id="quickModalCancel"><%= t('common.cancel') %></button>
                    <button type="submit" class="btn btn-primary" id="quickLinkSubmit">
                        <i class="ti ti-plus"></i> <%= t('network.createLink') %>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Reconnect Modal (change bridge/portal of an existing link) -->
    <div class="modal-overlay" id="reconnectModal">
        <div class="modal-card modal-card-sm">
            <div class="modal-header">
                <h3><i class="ti ti-arrows-exchange"></i> <span id="reconnectModalTitle"></span></h3>
                <button class="modal-close" id="reconnectModalClose"><i class="ti ti-x"></i></button>
            </div>
            <div class="modal-body" id="reconnectModalBody">
                <input type="hidden" id="reconnectLinkId">
                <input type="hidden" id="reconnectMode">
                <div class="form-group">
                    <label id="reconnectNodeLabel"></label>
                    <select id="reconnectNodeSelect" class="form-input"></select>
                </div>
                <div class="form-actions">
                    <button type="button" class="btn" id="reconnectModalCancel"><%= t('common.cancel') %></button>
                    <button type="button" class="btn btn-primary" id="reconnectModalSubmit">
                        <i class="ti ti-check"></i> <%= t('common.save') %>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div><!-- /viewNetwork -->

<div id="toast" class="toast"></div>

<style>
.node-name-cell {
    display: flex;
    align-items: center;
    gap: 8px;
}
.node-flag {
    font-size: 20px;
}
.btn-icon-danger:hover {
    background: var(--danger-bg);
    border-color: var(--danger);
}
.badge-xray {
    display: inline-block;
    background: #7c3aed20;
    border: 1px solid #7c3aed;
    color: #a78bfa;
