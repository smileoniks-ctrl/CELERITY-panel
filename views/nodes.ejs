function loadNetworkScripts() {
    const scripts = [
        'https://cdnjs.cloudflare.com/ajax/libs/cytoscape/3.30.4/cytoscape.min.js',
        'https://cdnjs.cloudflare.com/ajax/libs/dagre/0.8.5/dagre.min.js',
        'https://cdn.jsdelivr.net/npm/cytoscape-dagre@2.5.0/cytoscape-dagre.min.js',
        'https://cdn.jsdelivr.net/npm/cytoscape-edgehandles@4.0.1/cytoscape-edgehandles.min.js',
        '/js/network.js'
    ];

    let idx = 0;
    function next() {
        if (idx >= scripts.length) return;
        const s = document.createElement('script');
        s.src = scripts[idx];
        s.onload = function() { idx++; next(); };
        s.onerror = function() { idx++; next(); };
        document.body.appendChild(s);
    }
    next();
}

// Restore network view after page load
if (_restoreNetworkView) {
    switchNodesView('network');
}
</script>
