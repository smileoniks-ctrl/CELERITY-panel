                    <label for="xrayFlow"><%= t('nodes.xrayFlow') %></label>
                    <input type="text" id="xrayFlow" name="xray.flow" value="<%= node?.xray?.flow || 'xtls-rprx-vision' %>" placeholder="xtls-rprx-vision">
                    <small><%= t('nodes.xrayFlowHint') %></small>
                </div>

                <%# Reality-specific fields %>
                <div id="realityFields" style="<%= node?.xray?.security === 'tls' || node?.xray?.security === 'none' ? 'display:none' : '' %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="xrayRealityDest"><%= t('nodes.xrayRealityDest') %></label>
                            <input type="text" id="xrayRealityDest" name="xray.realityDest"
                                   value="<%= node?.xray?.realityDest || 'www.google.com:443' %>"
                                   placeholder="www.google.com:443">
                            <small><%= t('nodes.xrayRealityDestHint') %></small>
                        </div>
                        <div class="form-group">
                            <label for="xrayRealitySni"><%= t('nodes.xrayRealitySni') %></label>
                            <input type="text" id="xrayRealitySni" name="xray.realitySni"
                                   value="<%= (node?.xray?.realitySni || ['www.google.com']).join(', ') %>"
                                   placeholder="www.google.com">
                            <small><%= t('nodes.xrayRealitySniHint') %></small>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="xrayRealityPrivKey"><%= t('nodes.xrayPrivateKey') %></label>
                            <div class="input-with-button">
                                <input type="text" id="xrayRealityPrivKey" name="xray.realityPrivateKey"
                                       value="<%= node?.xray?.realityPrivateKey || '' %>"
                                       placeholder="<%= t('nodes.xrayAutoGenerated') %>">
                                <% if (node) { %>
                                <button type="button" class="btn btn-sm" onclick="generateXrayKeys()" title="<%= t('nodes.xrayGenerateKeys') %>"><i class="ti ti-refresh"></i></button>
                                <% } %>
                            </div>
                            <% if (!node) { %><small><%= t('nodes.xrayAutoGeneratedSetupHint') %></small><% } %>
                        </div>
                        <div class="form-group">
                            <label for="xrayRealityPubKey"><%= t('nodes.xrayPublicKey') %></label>
                            <input type="text" id="xrayRealityPubKey" name="xray.realityPublicKey"
                                   value="<%= node?.xray?.realityPublicKey || '' %>"
                                   placeholder="<%= t('nodes.xrayAutoGenerated') %>" readonly>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="xrayRealityShortIds"><%= t('nodes.xrayShortIds') %></label>
                        <input type="text" id="xrayRealityShortIds" name="xray.realityShortIds"
                               value="<%= (node?.xray?.realityShortIds || ['']).join(', ') %>"
                               placeholder=", 0123456789abcdef">
                        <small><%= t('nodes.xrayShortIdsHint') %></small>
                    </div>
                </div>

                <%# WebSocket-specific fields %>
                <div id="wsFields" style="<%= node?.xray?.transport === 'ws' ? '' : 'display:none' %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="xrayWsPath"><%= t('nodes.xrayWsPath') %></label>
                            <input type="text" id="xrayWsPath" name="xray.wsPath"
                                   value="<%= node?.xray?.wsPath || '/' %>" placeholder="/">
                        </div>
                        <div class="form-group">
                            <label for="xrayWsHost"><%= t('nodes.xrayWsHost') %></label>
                            <input type="text" id="xrayWsHost" name="xray.wsHost"
                                   value="<%= node?.xray?.wsHost || '' %>" placeholder="cdn.example.com">
                            <small><%= t('nodes.xrayWsHostHint') %></small>
                        </div>
                    </div>
                </div>

                <%# gRPC-specific fields %>
                <div id="grpcFields" style="<%= node?.xray?.transport === 'grpc' ? '' : 'display:none' %>">
                    <div class="form-group">
                        <label for="xrayGrpcService"><%= t('nodes.xrayGrpcService') %></label>
                        <input type="text" id="xrayGrpcService" name="xray.grpcServiceName"
                               value="<%= node?.xray?.grpcServiceName || 'grpc' %>" placeholder="grpc">
                    </div>
                </div>

                <%# XHTTP (SplitHTTP) specific fields %>
                <div id="xhttpFields" style="<%= node?.xray?.transport === 'xhttp' ? '' : 'display:none' %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="xrayXhttpPath"><%= t('nodes.xrayXhttpPath') %></label>
                            <input type="text" id="xrayXhttpPath" name="xray.xhttpPath"
                                   value="<%= node?.xray?.xhttpPath || '/' %>" placeholder="/">
                        </div>
                        <div class="form-group">
                            <label for="xrayXhttpHost"><%= t('nodes.xrayXhttpHost') %></label>
                            <input type="text" id="xrayXhttpHost" name="xray.xhttpHost"
                                   value="<%= node?.xray?.xhttpHost || '' %>" placeholder="cdn.example.com">
                            <small><%= t('nodes.xrayXhttpHostHint') %></small>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="xrayXhttpMode"><%= t('nodes.xrayXhttpMode') %></label>
                        <select id="xrayXhttpMode" name="xray.xhttpMode">
                            <option value="auto" <%= node?.xray?.xhttpMode === 'auto' || !node?.xray?.xhttpMode ? 'selected' : '' %>>Auto</option>
                            <option value="packet-up" <%= node?.xray?.xhttpMode === 'packet-up' ? 'selected' : '' %>>Packet Up</option>
                            <option value="stream-up" <%= node?.xray?.xhttpMode === 'stream-up' ? 'selected' : '' %>>Stream Up</option>
                        </select>
                        <small><%= t('nodes.xrayXhttpModeHint') %></small>
                    </div>
                </div>

                <div class="form-group">
                    <label for="xrayApiPort"><%= t('nodes.xrayApiPort') %></label>
                    <input type="number" id="xrayApiPort" name="xray.apiPort"
                           value="<%= node?.xray?.apiPort || 61000 %>" placeholder="61000">
                    <small><%= t('nodes.xrayApiPortHint') %></small>
                </div>
            </div>

            <%# ========== 8. SSH Access ========== %>
            <div class="form-section">
                <h3><%= t('nodes.sshSettings') %></h3>
                <small class="section-hint"><%= t('nodes.sshSettingsHint') %></small>
                <div class="form-row">
                    <div class="form-group">
                        <label for="sshPort"><%= t('nodes.sshPort') %></label>
                        <input type="number" id="sshPort" name="ssh.port" value="<%= node?.ssh?.port || 22 %>">
                    </div>
                    <div class="form-group">
                        <label for="sshUsername"><%= t('nodes.sshUsername') %></label>
                        <input type="text" id="sshUsername" name="ssh.username" value="<%= node?.ssh?.username || 'root' %>">
                    </div>
                </div>
                <div class="form-group">
                    <label for="sshPassword"><%= t('nodes.sshPassword') %> <%= node?.ssh?.password ? t('nodes.sshPasswordSet') : '' %></label>
                    <input type="password" id="sshPassword" name="ssh.password"
                           placeholder="<%= node?.ssh?.password ? t('nodes.sshPasswordKeep') : t('nodes.sshPasswordPlaceholder') %>">
                    <small class="hint"><%= t('nodes.sshPasswordEncrypted') %></small>
                </div>
                <div class="form-group">
                    <label for="sshPrivateKey">
                        <%= t('nodes.sshPrivateKey') %>
                        <% if (node?.ssh?.privateKey) { %>
                            <span class="badge badge-success" id="sshPrivateKeyBadge"><%= t('nodes.sshPrivateKeySet') %></span>
                        <% } else { %>
                            <span class="badge badge-success" id="sshPrivateKeyBadge" style="display:none"><%= t('nodes.sshPrivateKeySet') %></span>
                        <% } %>
                    </label>
                    <textarea id="sshPrivateKey" name="ssh.privateKey" rows="5"
                              placeholder="<%= t('nodes.sshPrivateKeyHint') %>"
                              style="font-family: monospace; font-size: 12px; resize: vertical;"></textarea>
                    <input type="hidden" name="ssh.clearPrivateKey" id="clearPrivateKeyInput" value="0">
                    <div style="display: flex; align-items: center; gap: 8px; margin-top: 6px; flex-wrap: wrap;">
                        <label class="btn btn-sm btn-secondary" for="sshPrivateKeyFile" style="cursor:pointer; margin:0;">
                            <%= t('nodes.sshPrivateKeyUpload') %>
                            <input type="file" id="sshPrivateKeyFile" accept=".pem,.key,*" style="display:none">
                        </label>
                        <% if (node?.ssh?.privateKey) { %>
                        <button type="button" id="clearPrivateKeyBtn" class="btn btn-sm btn-danger">
                            <%= t('nodes.sshPrivateKeyClear') %>
                        </button>
                        <% } %>
                        <small class="hint" style="margin:0"><%= t('nodes.sshPrivateKeyEncrypted') %></small>
                    </div>
                </div>
                <% if (node?._id) { %>
                <div class="form-group" id="generateSshKeyGroup">
                    <small class="hint" style="display: block; margin-bottom: 8px;"><%= t('nodes.generateSshKeyHint') %></small>
                    <button type="button" id="generateSshKeyBtn" class="btn btn-secondary">
                        <%= t('nodes.generateSshKey') %>
                    </button>
                    <span id="generateSshKeyStatus" style="margin-left: 10px; font-size: 13px;"></span>
                </div>
                <% } %>
            </div>

            <%# ========== 9. Limits & Priority ========== %>
            <div class="form-section" id="limitsSection">
                <h3><%= t('nodes.sectionLimits') %></h3>
                <div class="form-row">
                    <div class="form-group hysteria-only" id="maxOnlineGroup" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                        <label for="maxOnlineUsers"><%= t('nodes.maxOnlineUsers') %></label>
                        <input type="number" id="maxOnlineUsers" name="maxOnlineUsers"
                               value="<%= node?.maxOnlineUsers || 0 %>" placeholder="0" min="0">
                        <small><%= t('nodes.maxOnlineHint') %></small>
                    </div>
                    <div class="form-group">
                        <label for="rankingCoefficient"><%= t('nodes.rankingCoefficient') %></label>
                        <input type="number" id="rankingCoefficient" name="rankingCoefficient"
                               value="<%= node?.rankingCoefficient || 1 %>" placeholder="1" min="0" step="0.1">
                        <small><%= t('nodes.rankingHint') %></small>
                    </div>
                </div>
            </div>

            <%# ========== 10. Hysteria: Custom Config ========== %>
            <div class="form-section hysteria-only" id="hysteriaConfigSection" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                <h3><%= t('nodes.hysteriaConfig') %></h3>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="useCustomConfig" id="useCustomConfig"
                               <%= node?.useCustomConfig ? 'checked' : '' %>
                               onchange="toggleCustomConfig()">
                        <span class="checkbox-text"><%= t('nodes.useCustomConfig') %></span>
                    </label>
                    <small><%= t('nodes.customConfigHint') %></small>
                </div>
                <div id="customConfigSection" style="<%= node?.useCustomConfig ? '' : 'display:none' %>">
                    <div class="form-group">
                        <label for="customConfig"><%= t('nodes.customConfigLabel') %></label>
                        <textarea id="customConfig" name="customConfig" rows="20"
                                  class="code-textarea" placeholder="listen: :443&#10;&#10;acme:&#10;  domains:&#10;    - example.com..."><%= node?.customConfig || '' %></textarea>
                        <small><%= t('nodes.customConfigFormat') %></small>
                    </div>
                    <div style="display:flex;gap:8px;margin-top:4px;">
                        <button type="button" class="btn btn-sm" onclick="generateConfig()"><i class="ti ti-wand"></i> <%= t('nodes.generateConfig') %></button>
                        <button type="button" class="btn btn-sm" onclick="loadCurrentConfig()"><i class="ti ti-cloud-download"></i> <%= t('nodes.loadCurrentConfig') %></button>
                    </div>
                </div>
            </div>

            <%# ========== Active + Submit ========== %>
            <div class="form-group" style="margin-top:24px;">
                <label class="checkbox-label">
                    <input type="checkbox" name="active" <%= node?.active !== false ? 'checked' : '' %>>
                    <span class="checkbox-text"><%= t('nodes.nodeActive') %></span>
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <%= node ? t('nodes.saveNode') : t('nodes.createNode') %>
                </button>
                <a href="/panel/nodes" class="btn"><%= t('common.cancel') %></a>
            </div>
        </form>
    </div>
</div>

<%# ========== Xray Node Info (edit only) ========== %>
<% if (node && node.type === 'xray') { %>
<div class="card mt-3" id="xrayNodeInfoCard">
    <div class="card-header">
        <h2><img src="/img/xray.svg" alt="Xray" style="width:18px;height:18px;vertical-align:middle;margin-right:8px;"><%= t('nodes.nodeInfo') %></h2>
        <button class="btn btn-sm" onclick="refreshNodeInfo()" id="btnRefreshInfo" title="<%= t('common.refresh') %>">
            <i class="ti ti-refresh"></i>
        </button>
    </div>
    <div class="card-body">
        <div class="node-info-grid" id="nodeInfoGrid">
            <div class="node-info-item">
                <span class="node-info-label"><%= t('nodes.xrayVersion') %></span>
                <span class="node-info-value" id="infoXrayVersion"><%= node.xrayVersion || '—' %></span>
            </div>
            <div class="node-info-item">
                <span class="node-info-label"><%= t('nodes.agentVersion') %></span>
                <span class="node-info-value" id="infoAgentVersion"><%= node.agentVersion || '—' %></span>
            </div>
            <div class="node-info-item">
                <span class="node-info-label"><%= t('nodes.agentStatus') %></span>
                <span class="node-info-value" id="infoAgentStatus">
                    <span class="badge badge-<%= node.agentStatus === 'online' ? 'success' : (node.agentStatus === 'offline' ? 'danger' : 'warning') %>">
                        <%= node.agentStatus || 'unknown' %>
                    </span>
                </span>
            </div>
            <div class="node-info-item">
                <span class="node-info-label"><%= t('nodes.usersInMemory') %></span>
                <span class="node-info-value" id="infoUsersCount">—</span>
            </div>
            <div class="node-info-item">
                <span class="node-info-label"><%= t('nodes.agentLastSeen') %></span>
                <span class="node-info-value" id="infoLastSeen">
                    <%= node.agentLastSeen ? new Date(node.agentLastSeen).toLocaleString() : '—' %>
                </span>
            </div>
            <div class="node-info-item">
                <span class="node-info-label"><%= t('nodes.agentPort') %></span>
                <span class="node-info-value"><%= node.xray?.agentPort || 62080 %></span>
            </div>
        </div>
        <div id="nodeInfoError" class="mt-2" style="display:none;"></div>
    </div>
</div>
<% } %>

<%# ========== Cascade Links (edit only, xray) ========== %>
<% if (node && node.type === 'xray') { %>
<div class="card mt-3">
    <div class="card-header">
        <h2><i class="ti ti-topology-star-3" style="margin-right:6px"></i> <%= t('nodes.cascadeLinks') %></h2>
        <% if (cascadeLinks && cascadeLinks.length > 0) { %>
        <span class="badge badge-secondary"><%= cascadeLinks.length %></span>
        <% } %>
        <a href="/panel/nodes" onclick="switchNodesViewNetwork(); return false;" class="btn btn-sm" style="margin-left:auto">
            <i class="ti ti-map-2"></i> <%= t('nodes.goToNetworkMap') %>
        </a>
    </div>
    <% if (cascadeLinks && cascadeLinks.length > 0) { %>
    <div class="card-body no-padding">
        <table class="table cascade-links-table">
            <thead>
                <tr>
                    <th><%= t('common.name') %></th>
                    <th><%= t('nodes.portalColumn') %></th>
                    <th><%= t('nodes.bridgeColumn') %></th>
                    <th><%= t('network.tunnelPort') %></th>
                    <th><%= t('common.status') %></th>
                    <th><%= t('common.actions') %></th>
                </tr>
            </thead>
            <tbody>
                <% cascadeLinks.forEach(link => {
                    const isPortal = link.portalNode && link.portalNode._id.toString() === node._id.toString();
                    const statusClass = link.status === 'online' ? 'success' : (link.status === 'error' ? 'danger' : (link.status === 'deployed' ? 'info' : 'warning'));
                %>
                <tr>
                    <td><strong><%= link.name %></strong></td>
                    <td>
                        <% if (link.portalNode) { %>
                            <span class="cascade-node-cell">
                                <%= link.portalNode.flag || '' %> <%= link.portalNode.name %>
                                <% if (isPortal) { %><span class="badge-this"><%= t('nodes.thisNode') %></span><% } %>
                            </span>
                        <% } else { %><span class="text-muted">—</span><% } %>
                    </td>
                    <td>
                        <% if (link.bridgeNode) { %>
                            <span class="cascade-node-cell">
                                <%= link.bridgeNode.flag || '' %> <%= link.bridgeNode.name %>
                                <% if (!isPortal) { %><span class="badge-this"><%= t('nodes.thisNode') %></span><% } %>
                            </span>
                        <% } else { %><span class="text-muted">—</span><% } %>
                    </td>
                    <td><code><%= link.tunnelPort %></code></td>
                    <td>
                        <span class="badge badge-<%= statusClass %>"><%= link.status %></span>
                    </td>
                    <td>
                        <div class="cascade-link-actions">
                        <button class="btn btn-sm btn-success" onclick="cascadeAction('<%= link._id %>', 'deploy', this)">
                            <i class="ti ti-upload"></i> <%= t('network.deploy') %>
                        </button>
                        <button class="btn btn-sm btn-danger btn-icon" onclick="cascadeDelete('<%= link._id %>', '<%= link.name.replace(/'/g, "\\'") %>')" title="<%= t('common.delete') %>">
                            <i class="ti ti-trash"></i>
                        </button>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <% } else { %>
    <div class="card-body">
        <p class="hint" style="margin:0"><%= t('nodes.addCascadeLink') %> — <a href="/panel/nodes" onclick="switchNodesViewNetwork(); return false;"><%= t('nodes.goToNetworkMap') %></a></p>
    </div>
    <% } %>
</div>
<% } %>

<%# ========== Management (edit only) ========== %>
<% if (node) { %>
<div class="card mt-3">
    <div class="card-header">
        <h2><%= t('nodes.management') %></h2>
    </div>
    <div class="card-body">
        <% if (!node.ssh?.password && !node.ssh?.privateKey) { %>
        <div class="ssh-warning" id="sshWarning">
            <span class="ssh-warning-icon"><i class="ti ti-alert-triangle"></i></span>
            <span><%= t('nodes.sshNotConfigured') %></span>
        </div>
        <% } %>
        <div class="actions-grid">
            <button class="action-btn" onclick="setupNode()" id="btnSetup" <%= !node.ssh?.password && !node.ssh?.privateKey ? 'disabled title="Configure SSH first"' : '' %>>
                <span class="action-icon"><i class="ti ti-settings"></i></span>
                <span><%= t('nodes.autoSetup') %></span>
            </button>
            <a href="/panel/nodes/<%= node._id %>/outbounds" class="action-btn" style="text-decoration:none;text-align:center;">
                <span class="action-icon"><i class="ti ti-arrow-up-right"></i></span>
                <span>Outbounds</span>
                <% if (node.outbounds && node.outbounds.length > 0) { %>
                <span class="badge" style="font-size:10px;background:var(--accent);color:#fff;border-radius:10px;padding:1px 6px;margin-left:4px;"><%= node.outbounds.length %></span>
                <% } %>
            </a>
            <% if (node.ssh?.privateKey) { %>
            <a href="/panel/nodes/<%= node._id %>/download-ssh-key" class="action-btn" style="text-decoration:none;text-align:center;">
                <span class="action-icon"><i class="ti ti-download"></i></span>
                <span><%= t('nodes.downloadSshKey') %></span>
            </a>
            <% } else { %>
            <span class="action-btn is-disabled" style="text-decoration:none;text-align:center;" title="<%= t('nodes.downloadSshKeyMissing') %>" aria-disabled="true">
                <span class="action-icon"><i class="ti ti-download"></i></span>
                <span><%= t('nodes.downloadSshKey') %></span>
            </span>
            <% } %>
            <button class="action-btn" onclick="openTerminal()">
                <span class="action-icon"><i class="ti ti-terminal-2"></i></span>
                <span><%= t('nodes.terminal') %></span>
            </button>
            <button class="action-btn" onclick="getNodeLogs()">
                <span class="action-icon"><i class="ti ti-file-text"></i></span>
                <span><%= t('nodes.viewLogs') %></span>
            </button>
            <button class="action-btn" onclick="checkStatus()">
                <span class="action-icon"><i class="ti ti-search"></i></span>
                <span><%= t('nodes.checkStatus') %></span>
            </button>
            <button class="action-btn" onclick="resetStatus()">
                <span class="action-icon"><i class="ti ti-refresh"></i></span>
                <span><%= t('nodes.resetStatus') %></span>
            </button>
        </div>
        <div id="setupResult" class="mt-2"></div>
        <div id="logsContainer" class="mt-2" style="display:none;">
            <div class="logs-header">
                <strong><%= t('nodes.executionLogs') %></strong>
                <button class="btn btn-sm" onclick="clearLogs()"><%= t('common.clear') %></button>
            </div>
            <pre class="logs-output" id="logsOutput"></pre>
        </div>
    </div>
</div>
<% } %>

<%# ========== Config Preview (Hysteria, edit only) ========== %>
<% if (node && node.type !== 'xray') { %>
<div class="card mt-3">
    <div class="card-header">
        <h2><%= t('nodes.nodeConfig') %></h2>
    </div>
    <div class="card-body">
        <p class="hint"><%- t('nodes.configHint') %></p>
        <pre class="code-block"><code><%= nodeConfigPreview || '' %></code></pre>
        <button class="btn btn-sm" onclick="copyConfig()"><%= t('common.copy') %></button>
    </div>
</div>
<% } %>

<style>
.proto-switcher {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 8px;
}
.proto-option {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border: 2px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    position: relative;
}
.proto-option input[type="radio"] { position: absolute; opacity: 0; pointer-events: none; }
.proto-option:hover { border-color: var(--accent); background: var(--accent-glow); }
.proto-option.active { border-color: var(--accent); background: var(--accent-glow); }
.proto-icon { font-size: 22px; }
.proto-name { font-weight: 600; font-size: 14px; }
.proto-desc { font-size: 11px; color: var(--text-muted); }
.section-subtitle {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.code-textarea {
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 15px;
    width: 100%;
    resize: vertical;
    line-height: 1.5;
}
.code-textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-glow);
}
.input-with-button {
    display: flex;
    gap: 8px;
    align-items: center;
}
.input-with-button input { flex: 1; }
.input-with-button .btn { white-space: nowrap; flex-shrink: 0; }

.ssh-warning {
    background: var(--warning-bg);
    border: 1px solid var(--warning);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    margin-bottom: 16px;
    color: var(--warning);
    display: flex;
    align-items: center;
    gap: 10px;
}
.ssh-warning-icon { font-size: 20px; }

.node-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
}
.node-info-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
}
.node-info-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.node-info-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
}
.logs-output {
    background: #1a1a2e;
    color: #0f0;
    padding: 15px;
    border-radius: 8px;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    max-height: 500px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
    margin-top: 10px;
}
.logs-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.logs-output .error { color: #ff6b6b; }
.logs-output .success { color: #51cf66; }
.logs-output .warning { color: #ffd43b; }
.form-group.is-inactive {
    opacity: 0.55;
}

@media (max-width: 640px) {
    .form-row-3 { grid-template-columns: 1fr; }
}
</style>

<script>
const nodeType = '<%= node?.type || "hysteria" %>';
const i18n = {
    autoSetupConfirm: <%- JSON.stringify(t("nodes.autoSetupConfirm")) %>,
    autoSetupConfirmXray: <%- JSON.stringify(t("nodes.autoSetupConfirmXray")) %>,
    setupRunning: <%- JSON.stringify(t("nodes.setupRunning")) %>,
    loadingLogs: <%- JSON.stringify(t("nodes.loadingLogs")) %>,
    checking: <%- JSON.stringify(t("nodes.checking")) %>,
    resettingStatus: <%- JSON.stringify(t("nodes.resettingStatus")) %>,
    statusReset: <%- JSON.stringify(t("nodes.statusReset")) %>,
    autoSetup: <%- JSON.stringify(t("nodes.autoSetup")) %>,
    error: <%- JSON.stringify(t("common.error")) %>,
    confirmDeployCascade: <%- JSON.stringify(t("nodes.confirmDeployCascade")) %>,
    confirmUndeployCascade: <%- JSON.stringify(t("nodes.confirmUndeployCascade")) %>,
    confirmDeleteCascade: <%- JSON.stringify(t("nodes.confirmDeleteCascade")) %>,
    xrayGenerateKeysConfirm: <%- JSON.stringify(t("nodes.xrayGenerateKeysConfirm")) %>,
    xrayKeysSuccess: <%- JSON.stringify(t("nodes.xrayKeysSuccess")) %>
};
const i18nConfig = {
    copied: <%- JSON.stringify(t("common.copied")) %>,
    loadConfigConfirm: <%- JSON.stringify(t("nodes.loadConfigConfirm")) %>,
    configLoaded: <%- JSON.stringify(t("nodes.configLoaded")) %>,
    saveFirst: <%- JSON.stringify(t("nodes.saveFirst")) %>,
    error: <%- JSON.stringify(t("common.error")) %>,
    baseUrl: <%- JSON.stringify(baseUrl) %>
};

// ==================== Protocol switcher ====================

const PANEL_DOMAIN = '<%= panelDomain %>';

function checkXrayPortConflict() {
    const warn = document.getElementById('xrayPortConflictWarn');
    if (!warn) return;
    const proto = document.querySelector('input[name="type"]:checked')?.value || 'hysteria';
    const ip = (document.getElementById('ip')?.value || '').trim().toLowerCase();
    const port = parseInt(document.getElementById('port')?.value || '443', 10);
    const panelHostname = PANEL_DOMAIN.split(':')[0].toLowerCase();
    const isSameServer = ip === 'localhost' || ip === '127.0.0.1' || ip === '::1' || ip === panelHostname;
    const isConflictPort = port === 443 || port === 80;
    warn.style.display = (proto === 'xray' && isSameServer && isConflictPort) ? '' : 'none';
}

function switchProto(proto) {
    const xraySection = document.getElementById('xraySection');
    const cascadeSection = document.getElementById('cascadeRoleSection');
    const labelHysteria = document.getElementById('protoHysteriaLabel');
    const labelXray = document.getElementById('protoXrayLabel');
    const hysteriaOnlyEls = document.querySelectorAll('.hysteria-only');

    if (proto === 'xray') {
        xraySection.style.display = '';
        if (cascadeSection) cascadeSection.style.display = '';
        labelXray.classList.add('active');
        labelHysteria.classList.remove('active');
        hysteriaOnlyEls.forEach(el => el.style.display = 'none');
        onCascadeRoleChange();
    } else {
        xraySection.style.display = 'none';
        if (cascadeSection) cascadeSection.style.display = 'none';
        labelHysteria.classList.add('active');
        labelXray.classList.remove('active');
        hysteriaOnlyEls.forEach(el => el.style.display = '');
        toggleAcmeByDomain();
        toggleObfsPassword();
        toggleMasqueradeType();
        toggleBandwidthFields();
        toggleUdpFields();
        toggleSniffFields();
        toggleQuicFields();
        toggleResolverFields();
        toggleAclFields();
    }
    checkXrayPortConflict();
}

function selectCascadeRole(role, cardEl) {
    document.getElementById('cascadeRole').value = role;
    document.querySelectorAll('.role-card').forEach(function(c) { c.classList.remove('active'); });
    if (cardEl) cardEl.classList.add('active');
    onCascadeRoleChange();
}

function onCascadeRoleChange() {
    const role = document.getElementById('cascadeRole').value;
    const isBridge = role === 'bridge';
    const isPortal = role === 'portal';

    var bridgeHint = document.getElementById('cascadeBridgeHint');
    var portalHint = document.getElementById('cascadePortalHint');
    if (bridgeHint) bridgeHint.style.display = isBridge ? '' : 'none';
    if (portalHint) portalHint.style.display = isPortal ? '' : 'none';

    // Bridge nodes: hide all client-facing settings.
    // They only need name, IP, SSH, and cascade role.
    ['xraySection', 'networkSection', 'limitsSection'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.style.display = isBridge ? 'none' : '';
    });
}

// ==================== Xray UI ====================

function updateXrayTransportUI() {
    const transport = document.getElementById('xrayTransport').value;
    document.getElementById('wsFields').style.display = transport === 'ws' ? '' : 'none';
    document.getElementById('grpcFields').style.display = transport === 'grpc' ? '' : 'none';
    document.getElementById('xhttpFields').style.display = transport === 'xhttp' ? '' : 'none';
    const flowGroup = document.getElementById('xrayFlowGroup');
    if (flowGroup) flowGroup.style.display = transport === 'tcp' ? '' : 'none';
}

function updateXraySecurityUI() {
    const security = document.getElementById('xraySecurity').value;
    document.getElementById('realityFields').style.display = security === 'reality' ? '' : 'none';
    document.getElementById('alpnGroup').style.display = security === 'tls' ? '' : 'none';
}

// ==================== Hysteria helpers ====================

function toggleObfsPassword() {
    const type = document.getElementById('obfsType').value;
    document.getElementById('obfsPasswordGroup').style.display = type === 'salamander' ? '' : 'none';
}

function toggleCustomConfig() {
    const checked = document.getElementById('useCustomConfig').checked;
    document.getElementById('customConfigSection').style.display = checked ? 'block' : 'none';
}

function toggleAcmeByDomain() {
    const domain = (document.getElementById('domain')?.value || '').trim();
    const toggleGroup = document.getElementById('acmeAdvancedToggleGroup');
    if (toggleGroup) toggleGroup.style.display = domain ? '' : 'none';

    if (!domain) {
        const cb = document.getElementById('acmeAdvancedEnabled');
        if (cb) cb.checked = false;
    }

    toggleAcmeAdvancedFields();
}

function toggleAcmeAdvancedFields() {
    const domain = (document.getElementById('domain')?.value || '').trim();
    const enabled = !!document.getElementById('acmeAdvancedEnabled')?.checked;
    const wrap = document.getElementById('acmeAdvancedFieldsWrap');
    if (wrap) wrap.style.display = (domain && enabled) ? '' : 'none';
    if (domain && enabled) toggleAcmeTypeFields();
}

function toggleAcmeTypeFields() {
    const advancedEnabled = !!document.getElementById('acmeAdvancedEnabled')?.checked;
    const domain = (document.getElementById('domain')?.value || '').trim();
    const type = document.getElementById('acmeType')?.value || '';
    const altPorts = document.getElementById('acmeAltPortFields');
    const httpGroup = document.getElementById('acmeHttpFieldGroup');
    const tlsGroup = document.getElementById('acmeTlsFieldGroup');
    const dns = document.getElementById('acmeDnsFields');
    const active = advancedEnabled && !!domain;
    if (altPorts) altPorts.style.display = active && (type === 'http' || type === 'tls') ? '' : 'none';
    if (httpGroup) httpGroup.classList.toggle('is-inactive', !active || type !== 'http');
    if (tlsGroup) tlsGroup.classList.toggle('is-inactive', !active || type !== 'tls');
    if (dns) dns.style.display = active && type === 'dns' ? '' : 'none';
}

function toggleMasqueradeType() {
    const type = document.getElementById('masqueradeType')?.value || 'proxy';
    const proxy = document.getElementById('masqueradeProxyFields');
    const str = document.getElementById('masqueradeStringFields');
    if (proxy) proxy.style.display = type === 'proxy' ? '' : 'none';
    if (str) str.style.display = type === 'string' ? '' : 'none';
}

function toggleResolverFields() {
    const enabled = document.getElementById('resolverEnabled')?.checked;
    const wrap = document.getElementById('resolverFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
    if (enabled) toggleResolverTypeFields();
}

function toggleResolverTypeFields() {
    const type = document.getElementById('resolverType')?.value || 'udp';
    const ids = ['resolverUdpFields', 'resolverTcpFields', 'resolverTlsFields', 'resolverHttpsFields'];
    ids.forEach(id => {
        const el = document.getElementById(id);
        if (!el) return;
        const expected = id.replace('resolver', '').replace('Fields', '').toLowerCase();
        el.style.display = expected === type ? '' : 'none';
    });
}

function toggleAclTypeFields() {
    const enabled = !!document.getElementById('aclEnabled')?.checked;
    const type = document.getElementById('aclType')?.value || 'inline';
    const fileGroup = document.getElementById('aclFileGroup');
    const typeGroup = document.getElementById('aclTypeGroup');
    const inlineRulesGroup = document.getElementById('aclInlineRulesGroup');
    if (fileGroup) fileGroup.style.display = enabled && type === 'file' ? '' : 'none';
    if (typeGroup) typeGroup.style.gridColumn = (enabled && type === 'file') ? '' : '1 / -1';
    if (inlineRulesGroup) inlineRulesGroup.style.display = enabled && type === 'inline' ? '' : 'none';
}

function toggleAclFields() {
    const enabled = !!document.getElementById('aclEnabled')?.checked;
    const wrap = document.getElementById('aclFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
    if (enabled) toggleAclTypeFields();
}

function toggleBandwidthFields() {
    const enabled = !!document.getElementById('bandwidthEnabled')?.checked;
    const wrap = document.getElementById('bandwidthFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
}

function toggleUdpFields() {
    const enabled = !!document.getElementById('udpOptionsEnabled')?.checked;
    const wrap = document.getElementById('udpFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
}

function toggleSniffFields() {
    const enabled = !!document.getElementById('sniffEnabled')?.checked;
    const wrap = document.getElementById('sniffFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
}

function toggleQuicFields() {
    const enabled = !!document.getElementById('quicEnabled')?.checked;
    const wrap = document.getElementById('quicFieldsWrap');
    if (wrap) wrap.style.display = enabled ? '' : 'none';
}

function generateSecret() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    let secret = '';
    for (let i = 0; i < 32; i++) secret += chars.charAt(Math.floor(Math.random() * chars.length));
    document.getElementById('statsSecret').value = secret;
}

function generateObfsPassword() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
    let pwd = '';
    for (let i = 0; i < 24; i++) pwd += chars.charAt(Math.floor(Math.random() * chars.length));
    document.getElementById('obfsPassword').value = pwd;
}

async function generateConfig() {
    const form = document.getElementById('nodeForm');
    const output = document.getElementById('customConfig');
    if (!form || !output) return;

    const formData = new URLSearchParams(new FormData(form));
    try {
        const res = await fetch('/panel/nodes/preview-config', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: formData.toString(),
        });
        const data = await res.json();
        if (!res.ok || !data.success) {
            throw new Error(data.error || 'Failed to generate preview');
        }
        output.value = data.config || '';
    } catch (err) {
        alert(i18nConfig.error + ': ' + err.message);
    }
}

async function loadCurrentConfig() {
    <% if (node) { %>
    if (!confirm(i18nConfig.loadConfigConfirm)) return;
    try {
        const res = await fetch('/panel/nodes/<%= node._id %>/get-config');
        const data = await res.json();
        if (data.success) {
            document.getElementById('customConfig').value = data.config;
            alert(i18nConfig.configLoaded);
        } else {
            alert(i18nConfig.error + ': ' + data.error);
        }
    } catch (err) {
        alert(i18nConfig.error + ': ' + err.message);
    }
    <% } else { %>
    alert(i18nConfig.saveFirst);
    <% } %>
}

function copyConfig() {
    const code = document.querySelector('.code-block code').textContent;
    navigator.clipboard.writeText(code);
    alert(i18nConfig.copied);
}

// ==================== Management actions ====================

<% if (node) { %>
function showLogs(logs) {
    const container = document.getElementById('logsContainer');
    const output = document.getElementById('logsOutput');
    container.style.display = 'block';
    let html = '';
    if (Array.isArray(logs)) {
        html = logs.map(line => {
            if (line.includes('✓') || line.includes('success')) return '<span class="success">' + escapeHtml(line) + '</span>';
            if (line.includes('❌') || line.includes('Error') || line.includes('[STDERR]')) return '<span class="error">' + escapeHtml(line) + '</span>';
            if (line.includes('⚠')) return '<span class="warning">' + escapeHtml(line) + '</span>';
            return escapeHtml(line);
        }).join('\n');
    } else {
        html = escapeHtml(String(logs));
    }
    output.innerHTML = html;
    output.scrollTop = output.scrollHeight;
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function clearLogs() {
    document.getElementById('logsContainer').style.display = 'none';
    document.getElementById('logsOutput').innerHTML = '';
}

async function setupNode() {
    const confirmMsg = nodeType === 'xray' ? i18n.autoSetupConfirmXray : i18n.autoSetupConfirm;
    if (!confirm(confirmMsg)) return;
    const btn = document.getElementById('btnSetup');
    btn.disabled = true;
    btn.innerHTML = '<span class="action-icon"><i class="ti ti-loader-2"></i></span><span>...</span>';
    document.getElementById('setupResult').innerHTML = '<div class="alert">' + i18n.setupRunning + '</div>';
    try {
        const res = await fetch('/panel/nodes/<%= node._id %>/setup', { method: 'POST' });
        const data = await res.json();
        if (data.logs) showLogs(data.logs);
        if (data.success) {
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-success"><i class="ti ti-check"></i> ' + data.message + '</div>';
        } else {
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + (data.error || i18n.error) + '</div>';
        }
    } catch (err) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + err.message + '</div>';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<span class="action-icon"><i class="ti ti-settings"></i></span><span>' + i18n.autoSetup + '</span>';
    }
}

async function getNodeLogs() {
    document.getElementById('setupResult').innerHTML = '<div class="alert">' + i18n.loadingLogs + '</div>';
    try {
        const res = await fetch('/panel/nodes/<%= node._id %>/logs');
        const data = await res.json();
        if (data.success) {
            document.getElementById('setupResult').innerHTML = '';
            showLogs(data.logs);
        } else {
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + data.error + '</div>';
        }
    } catch (err) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + err.message + '</div>';
    }
}

async function checkStatus() {
    document.getElementById('setupResult').innerHTML = '<div class="alert">' + i18n.checking + '</div>';
    try {
        const res = await fetch('/api/nodes/<%= node._id %>/status', { credentials: 'include' });
        const data = await res.json();
        const statusColors = { online: 'alert-success', offline: 'alert-warning', error: 'alert-error' };
        const statusIcons = { online: '<i class="ti ti-check"></i>', offline: '<i class="ti ti-alert-triangle"></i>', error: '<i class="ti ti-x"></i>' };
        const color = statusColors[data.status] || '';
        const icon = statusIcons[data.status] || '<i class="ti ti-help"></i>';
        document.getElementById('setupResult').innerHTML = '<div class="alert ' + color + '">' + icon + ' Status: ' + data.status + '</div>';
    } catch (err) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error">' + i18n.error + ': ' + err.message + '</div>';
    }
}

function openTerminal() {
    window.open('/panel/nodes/<%= node._id %>/terminal', '_blank', 'width=1000,height=600');
}

async function resetStatus() {
    document.getElementById('setupResult').innerHTML = '<div class="alert">' + i18n.resettingStatus + '</div>';
    try {
        const res = await fetch('/api/nodes/<%= node._id %>/reset-status', { method: 'POST', credentials: 'include' });
        const data = await res.json();
        if (data.success) {
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-success">' + i18n.statusReset + '</div>';
        } else {
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + (data.error || i18n.error) + '</div>';
        }
    } catch (err) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error">' + i18n.error + ': ' + err.message + '</div>';
    }
}
<% } %>

<% if (node && node.type === 'xray') { %>
async function refreshNodeInfo() {
    const btn = document.getElementById('btnRefreshInfo');
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="ti ti-loader-2"></i>'; }
    const errEl = document.getElementById('nodeInfoError');
    if (errEl) errEl.style.display = 'none';
    try {
        const res = await fetch('/api/nodes/<%= node._id %>/agent-info', { credentials: 'include' });
        const data = await res.json();
        if (data.xray_version) document.getElementById('infoXrayVersion').textContent = data.xray_version;
        if (data.agent_version) document.getElementById('infoAgentVersion').textContent = data.agent_version;
        if (data.users_count !== undefined) document.getElementById('infoUsersCount').textContent = data.users_count;
        const statusEl = document.getElementById('infoAgentStatus');
        if (statusEl) {
            const online = res.ok && !data.error;
            statusEl.innerHTML = `<span class="badge badge-${online ? 'success' : 'danger'}">${online ? 'online' : 'offline'}</span>`;
        }
        document.getElementById('infoLastSeen').textContent = new Date().toLocaleString();
    } catch (e) {
        if (errEl) {
            errEl.innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + e.message + '</div>';
            errEl.style.display = 'block';
        }
    } finally {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="ti ti-refresh"></i>'; }
    }
}
<% } %>

<% if (node && node.type === 'xray') { %>
async function generateXrayKeys() {
    if (!confirm(i18n.xrayGenerateKeysConfirm)) return;
    const btn = event.target;
    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader-2"></i>';
    try {
        const res = await fetch('/api/nodes/<%= node._id %>/generate-xray-keys', {
            method: 'POST',
            credentials: 'include',
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('xrayRealityPrivKey').value = data.privateKey;
            document.getElementById('xrayRealityPubKey').value = data.publicKey;
            alert(i18n.xrayKeysSuccess.replace('{key}', data.publicKey));
        } else {
            alert(i18n.error + ': ' + (data.error || 'Unknown error'));
        }
    } catch (err) {
        alert(i18n.error + ': ' + err.message);
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="ti ti-refresh"></i>';
    }
}
<% } %>

// Init UI on page load
(function() {
    const proto = document.querySelector('input[name="type"]:checked')?.value || 'hysteria';
    switchProto(proto);
    toggleAcmeByDomain();
    toggleAcmeTypeFields();
    toggleObfsPassword();
    toggleMasqueradeType();
    toggleBandwidthFields();
    toggleUdpFields();
    toggleSniffFields();
    toggleQuicFields();
    toggleResolverFields();
    toggleAclFields();
    if (proto === 'xray') {
        updateXrayTransportUI();
        updateXraySecurityUI();
    }
})();

// SSH private key file upload
document.getElementById('sshPrivateKeyFile')?.addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (e) => {
        document.getElementById('sshPrivateKey').value = e.target.result;
        document.getElementById('sshPrivateKeyBadge').style.display = '';
    };
    reader.readAsText(file);
    this.value = '';
});

// Clear private key button
document.getElementById('clearPrivateKeyBtn')?.addEventListener('click', function() {
    document.getElementById('sshPrivateKey').value = '';
    document.getElementById('clearPrivateKeyInput').value = '1';
    document.getElementById('sshPrivateKeyBadge').style.display = 'none';
    this.style.display = 'none';
});

// Show badge when user types in textarea
document.getElementById('sshPrivateKey')?.addEventListener('input', function() {
    document.getElementById('sshPrivateKeyBadge').style.display = this.value.trim() ? '' : 'none';
});

<% if (node && node._id) { %>
// Generate & Install SSH Key
document.getElementById('generateSshKeyBtn')?.addEventListener('click', async function() {
    const warning = '<%= t('nodes.generateSshKeyWarning').replace(/\n/g, '\\n').replace(/'/g, "\\'") %>';
    if (!confirm(warning)) return;

    const btn = this;
    const statusEl = document.getElementById('generateSshKeyStatus');
    btn.disabled = true;
    btn.textContent = '<%= t('nodes.sshKeyGenerating') %>';
    statusEl.textContent = '';
    statusEl.style.color = '';

    try {
        const res = await fetch('/panel/nodes/<%= node._id %>/generate-ssh-key', {
            method: 'POST',
            credentials: 'include',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
        });
        const data = await res.json();
        if (data.success) {
            statusEl.textContent = '<%= t('nodes.sshKeyInstalled') %>';
            statusEl.style.color = 'var(--color-success, #22c55e)';
            // Update UI to show key is now set
            const label = document.querySelector('label[for="sshPrivateKey"]');
            if (label && !label.querySelector('.badge')) {
                const badge = document.createElement('span');
                badge.className = 'badge badge-success';
                badge.textContent = '<%= t('nodes.sshPrivateKeySet') %>';
                label.appendChild(document.createTextNode(' '));
                label.appendChild(badge);
            }
        } else {
            statusEl.textContent = '<%= t('nodes.sshKeyError') %>: ' + (data.error || 'Unknown error');
            statusEl.style.color = 'var(--color-danger, #ef4444)';
        }
    } catch (err) {
        statusEl.textContent = '<%= t('nodes.sshKeyError') %>: ' + err.message;
        statusEl.style.color = 'var(--color-danger, #ef4444)';
    } finally {
        btn.disabled = false;
        btn.textContent = '<%= t('nodes.generateSshKey') %>';
    }
});
<% } %>

// Run port conflict check on page load and when IP changes
(function () {
    checkXrayPortConflict();
    const ipInput = document.getElementById('ip');
    if (ipInput) ipInput.addEventListener('input', checkXrayPortConflict);
})();

// ==================== Cascade link actions ====================

async function cascadeAction(linkId, action, btn) {
    const confirmMsg = action === 'deploy' ? i18n.confirmDeployCascade : i18n.confirmUndeployCascade;
    if (!confirm(confirmMsg)) return;
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="ti ti-loader-2" style="animation:spin 0.7s linear infinite;display:inline-block"></i>'; }
    try {
        const res = await fetch('/api/cascade/links/' + linkId + '/' + action, { method: 'POST' });
        if (res.ok) {
            location.reload();
        } else {
            const data = await res.json().catch(() => ({}));
            alert(i18n.error + ': ' + (data.error || 'Unknown error'));
            if (btn) { btn.disabled = false; btn.innerHTML = action === 'deploy' ? '<i class="ti ti-upload"></i>' : '<i class="ti ti-upload-off"></i>'; }
        }
    } catch (err) {
        alert(i18n.error + ': ' + err.message);
        if (btn) { btn.disabled = false; }
    }
}

async function cascadeDelete(linkId, name) {
    const confirmMsg = i18n.confirmDeleteCascade.replace('{name}', name);
    if (!confirm(confirmMsg)) return;
    try {
        const res = await fetch('/api/cascade/links/' + linkId, { method: 'DELETE' });
        if (res.ok) {
            location.reload();
        } else {
            const data = await res.json().catch(() => ({}));
            alert(i18n.error + ': ' + (data.error || 'Unknown error'));
        }
    } catch (err) {
        alert(i18n.error + ': ' + err.message);
    }
}

function switchNodesViewNetwork() {
    window.location.href = '/panel/nodes';
    sessionStorage.setItem('nodesView', 'network');
}
</script>
