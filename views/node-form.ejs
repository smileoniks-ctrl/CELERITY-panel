<script>
const i18nConfig = {
    copied: <%- JSON.stringify(t("common.copied")) %>,
    loadConfigConfirm: <%- JSON.stringify(t("nodes.loadConfigConfirm")) %>,
    configLoaded: <%- JSON.stringify(t("nodes.configLoaded")) %>,
    saveFirst: <%- JSON.stringify(t("nodes.saveFirst")) %>,
    error: <%- JSON.stringify(t("common.error")) %>,
    baseUrl: <%- JSON.stringify(baseUrl) %>
};

function copyConfig() {
    const code = document.querySelector('.code-block code').textContent;
    navigator.clipboard.writeText(code);
    alert(i18nConfig.copied);
}

function generateSecret() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
    let secret = '';
    for (let i = 0; i < 32; i++) {
        secret += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    document.getElementById('statsSecret').value = secret;
}

function toggleObfsPassword() {
    const type = document.getElementById('obfsType').value;
    document.getElementById('obfsPasswordGroup').style.display = type === 'salamander' ? '' : 'none';
}

function generateObfsPassword() {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
    let pwd = '';
    for (let i = 0; i < 24; i++) {
        pwd += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    document.getElementById('obfsPassword').value = pwd;
}

function toggleCustomConfig() {
    const checked = document.getElementById('useCustomConfig').checked;
    document.getElementById('customConfigSection').style.display = checked ? 'block' : 'none';
}

function generateConfig() {
    const name = document.getElementById('name').value || 'Node';
    const domain = document.getElementById('domain').value;
    const port = document.getElementById('port').value || 443;
    const statsPort = document.getElementById('statsPort').value || 9999;
    const statsSecret = document.getElementById('statsSecret').value || 'secret';
    const portRange = document.getElementById('portRange').value || '20000-50000';
    
    let tlsSection;
    if (domain) {
        tlsSection = `acme:
  domains:
    - ${domain}
  email: admin@${domain}
  dir: /etc/hysteria/acme
  listenHost: 0.0.0.0`;
    } else {
        tlsSection = `tls:
  cert: /etc/hysteria/cert.pem
  key: /etc/hysteria/key.pem`;
    }
    
    const config = `# Hysteria 2 Config - ${name}
# Generated: ${new Date().toISOString()}

listen: :${port}

${tlsSection}

sniff:
  enable: true
  timeout: 2s
  rewriteDomain: false
  tcpPorts: 80,443,8000-9000
  udpPorts: 443,80,53

quic:
  initStreamReceiveWindow: 8388608
  maxStreamReceiveWindow: 8388608
  initConnReceiveWindow: 20971520
  maxConnReceiveWindow: 20971520
  maxIdleTimeout: 60s
  maxIncomingStreams: 256

auth:
  type: http
  http:
    url: ${i18nConfig.baseUrl}/api/auth
    insecure: false

# bandwidth:
#   up: 100 mbps
#   down: 100 mbps
# ignoreClientBandwidth: true

masquerade:
  type: string
  string:
    content: "Service Unavailable"
    headers:
      Content-Type: text/plain
    statusCode: 503

acl:
  inline:
    - reject(geoip:cn)
    - reject(geoip:private)

trafficStats:
  listen: :${statsPort}
  secret: ${statsSecret}
`;
    
    document.getElementById('customConfig').value = config;
}

async function loadCurrentConfig() {
    <% if (node) { %>
    if (!confirm(i18nConfig.loadConfigConfirm)) return;
    
    try {
        const res = await fetch('/panel/nodes/<%= node._id %>/get-config');
        const data = await res.json();
        
        if (data.success) {
            document.getElementById('customConfig').value = data.config;
            alert(i18nConfig.configLoaded);
        } else {
            alert(i18nConfig.error + ': ' + data.error);
        }
    } catch (err) {
        alert(i18nConfig.error + ': ' + err.message);
    }
    <% } else { %>
    alert(i18nConfig.saveFirst);
    <% } %>
}

// ==================== XRAY UI ====================

function switchProto(proto) {
    const xraySection = document.getElementById('xraySection');
    const hysteriaSection = document.getElementById('hysteriaSection');
    const labelHysteria = document.getElementById('protoHysteriaLabel');
    const labelXray = document.getElementById('protoXrayLabel');
    const hysteriaOnlyFields = document.querySelectorAll('.hysteria-only');

    if (proto === 'xray') {
        xraySection.style.display = '';
        hysteriaSection.style.display = 'none';
        labelXray.classList.add('active');
        labelHysteria.classList.remove('active');
        hysteriaOnlyFields.forEach(el => el.style.display = 'none');
    } else {
        xraySection.style.display = 'none';
        hysteriaSection.style.display = '';
        labelHysteria.classList.add('active');
        labelXray.classList.remove('active');
        hysteriaOnlyFields.forEach(el => el.style.display = '');
    }
}

function updateXrayTransportUI() {
    const transport = document.getElementById('xrayTransport').value;
    document.getElementById('wsFields').style.display = transport === 'ws' ? '' : 'none';
    document.getElementById('grpcFields').style.display = transport === 'grpc' ? '' : 'none';
    document.getElementById('xhttpFields').style.display = transport === 'xhttp' ? '' : 'none';
    // Flow only makes sense for TCP
    const flowGroup = document.getElementById('xrayFlow').closest('.form-group');
    if (flowGroup) flowGroup.style.display = transport === 'tcp' ? '' : 'none';
}

function updateXraySecurityUI() {
    const security = document.getElementById('xraySecurity').value;
    document.getElementById('realityFields').style.display = security === 'reality' ? '' : 'none';
    // ALPN only for TLS (not Reality)
    document.getElementById('alpnGroup').style.display = security === 'tls' ? '' : 'none';
}

<% if (node && node.type === 'xray') { %>
async function generateXrayKeys() {
    if (!confirm('Generate new x25519 Reality keys via SSH? This will overwrite existing keys.')) return;

    const btn = event.target;
    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader-2"></i>';

    try {
        const res = await fetch('/api/nodes/<%= node._id %>/generate-xray-keys', {
            method: 'POST',
            credentials: 'include',
        });
        const data = await res.json();

        if (data.success) {
            document.getElementById('xrayRealityPrivKey').value = data.privateKey;
            document.getElementById('xrayRealityPubKey').value = data.publicKey;
            alert('Keys generated successfully! Public key: ' + data.publicKey);
        } else {
            alert('Error: ' + (data.error || 'Unknown error'));
        }
    } catch (err) {
        alert('Error: ' + err.message);
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="ti ti-refresh"></i>';
    }
}
<% } %>

// Preprocess comma-separated Xray array fields on form submit
document.querySelector('form').addEventListener('submit', function(e) {
    const proto = document.querySelector('input[name="type"]:checked')?.value || 'hysteria';
    if (proto !== 'xray') return;

    // Convert comma-separated SNI string to JSON array via hidden input trick:
    // We set the value back as comma-separated; server will split it.
    // (The panel form handler needs to handle this - done in nodes panel route)
});

// Init UI state on page load
(function() {
    const proto = document.querySelector('input[name="type"]:checked')?.value || 'hysteria';
    switchProto(proto);
    if (proto === 'xray') {
        updateXrayTransportUI();
        updateXraySecurityUI();
    }
})();
</script>
