<div class="page-header">
    <a href="/panel/nodes" class="btn btn-back"><i class="ti ti-chevron-left"></i> <%= t('common.backToList') %></a>
</div>

<% if (error) { %>
<div class="alert alert-error" style="margin-bottom:16px;"><i class="ti ti-alert-circle"></i> <%= error %></div>
<% } %>

<%
const hysteriaDocsByLang = {
    en: {
        portHopping: 'https://v2.hysteria.network/docs/advanced/Port-Hopping/',
        acme: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#tls',
        acmeDnsConfig: 'https://v2.hysteria.network/docs/advanced/ACME-DNS-Config/',
        stats: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#traffic-stats-api-http',
        obfuscation: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#obfuscation',
        masquerade: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#masquerade',
        bandwidth: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#bandwidth',
        speedTest: 'https://v2.hysteria.network/docs/advanced/Speed-Test/',
        udp: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#udp',
        sniff: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#protocol-sniffing',
        quic: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#quic-parameters',
        resolver: 'https://v2.hysteria.network/docs/advanced/Full-Server-Config/#resolver',
        acl: 'https://v2.hysteria.network/docs/advanced/ACL/',
    },
    ru: {
        portHopping: 'https://v2.hysteria.network/ru/docs/advanced/Port-Hopping/',
        acme: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#tls',
        acmeDnsConfig: 'https://v2.hysteria.network/ru/docs/advanced/ACME-DNS-Config/',
        stats: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#api-http',
        obfuscation: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#_2',
        masquerade: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#_13',
        bandwidth: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#_3',
        speedTest: 'https://v2.hysteria.network/ru/docs/advanced/Speed-Test/',
        udp: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#udp',
        sniff: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#_11',
        quic: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#quic',
        resolver: 'https://v2.hysteria.network/ru/docs/advanced/Full-Server-Config/#_10',
        acl: 'https://v2.hysteria.network/ru/docs/advanced/ACL/',
    },
};
const hysteriaDocs = hysteriaDocsByLang[lang] || hysteriaDocsByLang.en || {};
function docsHref(section) {
    return hysteriaDocs[section] || '';
}
function escAttr(value) {
    return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/"/g, '&quot;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
}
function renderDocsIcon(section) {
    const href = docsHref(section);
    if (!href) return '';
    const label = escAttr(t('nodes.docsLink'));
    return `<a class="docs-hint-link" href="${href}" target="_blank" rel="noopener noreferrer" title="${label}" aria-label="${label}">ⓘ</a>`;
}
const acmeAdvancedEnabled = !!(
    node?.acme?.email ||
    (node?.acme?.ca && node.acme.ca !== 'letsencrypt') ||
    (node?.acme?.listenHost && node.acme.listenHost !== '0.0.0.0') ||
    node?.acme?.type ||
    node?.acme?.httpAltPort ||
    node?.acme?.tlsAltPort ||
    node?.acme?.dnsName ||
    (node?.acme?.dnsConfig && Object.keys(node.acme.dnsConfig || {}).length > 0)
);
const bandwidthEnabled = !!(node?.bandwidth?.up || node?.bandwidth?.down || node?.ignoreClientBandwidth);
const udpOptionsEnabled = !!(node?.disableUDP || node?.udpIdleTimeout);
const sniffAdvancedEnabled = !!(
    node?.sniff?.enabled ||
    (node?.sniff?.timeout && node.sniff.timeout !== '2s') ||
    node?.sniff?.rewriteDomain ||
    (node?.sniff?.tcpPorts && node.sniff.tcpPorts !== '80,443,8000-9000') ||
    (node?.sniff?.udpPorts && node.sniff.udpPorts !== '443,80,53')
);
const quicSectionEnabled = !!(
    node?.quic?.enabled ||
    (node?.quic?.initStreamReceiveWindow != null && Number(node.quic.initStreamReceiveWindow) !== 8388608) ||
    (node?.quic?.maxStreamReceiveWindow != null && Number(node.quic.maxStreamReceiveWindow) !== 8388608) ||
    (node?.quic?.initConnReceiveWindow != null && Number(node.quic.initConnReceiveWindow) !== 20971520) ||
    (node?.quic?.maxConnReceiveWindow != null && Number(node.quic.maxConnReceiveWindow) !== 20971520) ||
    (node?.quic?.maxIdleTimeout && node.quic.maxIdleTimeout !== '60s') ||
    (node?.quic?.maxIncomingStreams != null && Number(node.quic.maxIncomingStreams) !== 256) ||
    node?.quic?.disablePathMTUDiscovery
);
const aclSectionEnabled = node ? (node?.acl?.enabled !== false) : true;
const sniffBaseEnabled = node?.sniff?.enable !== false;
const aclDefaultInlineRules = ['reject(geoip:cn)', 'reject(geoip:private)'];
const aclInlineRulesValue = (node?.aclRules && node.aclRules.length > 0)
    ? node.aclRules.join('\n')
    : aclDefaultInlineRules.join('\n');
%>

<div class="card">
    <div class="card-header">
        <h2><%= node ? t('nodes.editNode') : t('nodes.newNode') %></h2>
    </div>
    <div class="card-body">
        <form id="nodeForm" method="POST" action="/panel/nodes<%= node ? '/' + node._id : '' %>" class="form">
            <input type="hidden" name="useTlsFiles" value="<%= node?.useTlsFiles ? '1' : '0' %>">

            <%# ========== 1. Identification ========== %>
            <div class="form-row-3">
                <div class="form-group">
                    <label for="name"><%= t('nodes.nodeName') %></label>
                    <input type="text" id="name" name="name" value="<%= node?.name || '' %>"
                           placeholder="<%= t('nodes.nodeNamePlaceholder') %>" required>
                    <small><%= t('nodes.nodeNameHint') %></small>
                </div>
                <div class="form-group">
                    <label for="ip"><%= t('nodes.ipAddress') %></label>
                    <input type="text" id="ip" name="ip" value="<%= node?.ip || '' %>"
                           placeholder="123.45.67.89" required>
                </div>
                <div class="form-group">
                    <label for="flag"><%= t('nodes.flag') %></label>
                    <input type="text" id="flag" name="flag" value="<%= node?.flag || '' %>"
                           placeholder="<%= t('nodes.flagPlaceholder') %>">
                    <small><%= t('nodes.flagHint') %></small>
                </div>
            </div>

            <%# ========== 1b. Cascade Role & Country (Xray only) ========== %>
            <div class="form-section xray-only" id="cascadeRoleSection" style="<%= node?.type === 'xray' ? '' : 'display:none' %>">
                <h3><i class="ti ti-topology-star-3"></i> <%= t('nodes.cascadeRole') %></h3>
                <small class="section-hint"><%= t('nodes.cascadeRoleHint') %></small>

                <%# Hidden input carries the actual value %>
                <input type="hidden" id="cascadeRole" name="cascadeRole" value="<%= node?.cascadeRole || 'standalone' %>">

                <div class="cascade-role-picker">
                    <label class="role-card <%= (node?.cascadeRole || 'standalone') === 'standalone' ? 'active' : '' %>"
                           onclick="selectCascadeRole('standalone', this)">
                        <span class="role-card-icon role-standalone"><i class="ti ti-server"></i></span>
                        <span class="role-card-body">
                            <span class="role-card-name">Standalone</span>
                            <span class="role-card-desc"><%= t('nodes.roleStandalone') %></span>
                        </span>
                    </label>
                    <label class="role-card <%= node?.cascadeRole === 'portal' ? 'active' : '' %>"
                           onclick="selectCascadeRole('portal', this)">
                        <span class="role-card-icon role-portal"><i class="ti ti-door-enter"></i></span>
                        <span class="role-card-body">
                            <span class="role-card-name">Portal</span>
                            <span class="role-card-desc"><%= t('nodes.rolePortal') %></span>
                        </span>
                    </label>
                    <label class="role-card <%= node?.cascadeRole === 'bridge' ? 'active' : '' %>"
                           onclick="selectCascadeRole('bridge', this)">
                        <span class="role-card-icon role-bridge"><i class="ti ti-door-exit"></i></span>
                        <span class="role-card-body">
                            <span class="role-card-name">Bridge</span>
                            <span class="role-card-desc"><%= t('nodes.roleBridge') %></span>
                        </span>
                    </label>
                    <label class="role-card <%= node?.cascadeRole === 'relay' ? 'active' : '' %>"
                           onclick="selectCascadeRole('relay', this)">
                        <span class="role-card-icon role-relay"><i class="ti ti-arrows-exchange"></i></span>
                        <span class="role-card-body">
                            <span class="role-card-name">Relay</span>
                            <span class="role-card-desc"><%= t('nodes.roleRelay') %></span>
                        </span>
                    </label>
                </div>

                <div class="form-group" style="margin-top:12px; max-width:200px">
                    <label for="country"><%= t('nodes.country') %></label>
                    <input type="text" id="country" name="country"
                           value="<%= node?.country || '' %>"
                           placeholder="RU, DE, NL...">
                    <small><%= t('nodes.countryHint') %></small>
                </div>

                <div class="alert alert-info" id="cascadeBridgeHint" style="<%= node?.cascadeRole === 'bridge' ? '' : 'display:none' %>">
                    <i class="ti ti-info-circle"></i>
                    <%= t('nodes.bridgeNodeHint') %>
                </div>
                <div class="alert alert-info" id="cascadePortalHint" style="<%= node?.cascadeRole === 'portal' ? '' : 'display:none' %>">
                    <i class="ti ti-info-circle"></i>
                    <%= t('nodes.portalNodeHint') %>
                </div>
            </div>

            <%# ========== 2. Protocol ========== %>
            <div class="form-section">
                <h3><%= t('nodes.sectionProtocol') %></h3>
                <div class="proto-switcher">
                    <label class="proto-option <% if ((node?.type || 'hysteria') === 'hysteria') { %>active<% } %>" id="protoHysteriaLabel">
                        <input type="radio" name="type" value="hysteria" id="protoHysteria"
                               <%= (node?.type || 'hysteria') === 'hysteria' ? 'checked' : '' %>
                               onchange="switchProto('hysteria')">
                        <span class="proto-icon"><img src="/img/hysteria.svg" alt="Hysteria" style="width:24px;height:24px;"></span>
                        <span class="proto-name">Hysteria 2</span>
                        <span class="proto-desc">QUIC · HTTP auth · port hopping</span>
                    </label>
                    <label class="proto-option <% if (node?.type === 'xray') { %>active<% } %>" id="protoXrayLabel">
                        <input type="radio" name="type" value="xray" id="protoXray"
                               <%= node?.type === 'xray' ? 'checked' : '' %>
                               onchange="switchProto('xray')">
                        <span class="proto-icon"><img src="/img/xray.svg" alt="Xray" style="width:24px;height:24px;"></span>
                        <span class="proto-name">Xray VLESS</span>
                        <span class="proto-desc">Reality / TLS · WebSocket · gRPC</span>
                    </label>
                </div>
            </div>

            <%# ========== 3. Server Groups ========== %>
            <div class="form-section">
                <h3><%= t('nodes.groups') %></h3>
                <small class="section-hint"><%= t('nodes.groupsHint') %></small>
                <div class="groups-select">
                    <% if (groups && groups.length > 0) { %>
                        <% groups.forEach(group => {
                            const isSelected = node?.groups?.some(g => g._id?.toString() === group._id.toString() || g.toString() === group._id.toString());
                        %>
                            <label class="checkbox-tag" style="border-color: <%= group.color %>">
                                <input type="checkbox" name="groups" value="<%= group._id %>" <%= isSelected ? 'checked' : '' %>>
                                <span class="tag-dot" style="background: <%= group.color %>"></span>
                                <span><%= group.name %></span>
                            </label>
                        <% }); %>
                    <% } else { %>
                        <p class="hint"><%= t('nodes.noGroups') %> <a href="/panel/groups"><%= t('nodes.createGroup') %></a></p>
                    <% } %>
                </div>
            </div>

            <%# ========== 4. Network ========== %>
            <div class="form-section" id="networkSection">
                <h3><%= t('nodes.sectionNetwork') %></h3>

                <div class="form-row">
                    <div class="form-group">
                        <label for="port"><%= t('nodes.port') %></label>
                        <input type="number" id="port" name="port" value="<%= node?.port || 443 %>"
                               placeholder="443" oninput="checkXrayPortConflict()">
                    </div>
                    <div class="form-group hysteria-only" id="portRangeGroup" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                        <label for="portRange"><%= t('nodes.portRange') %></label>
                        <input type="text" id="portRange" name="portRange" value="<%= node?.portRange || '20000-50000' %>"
                               placeholder="20000-50000">
                        <small><%= t('nodes.portRangeHint') %></small>
                    </div>
                </div>

                <div class="form-group hysteria-only" id="hopIntervalGroup" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                    <label for="hopInterval"><%= t('nodes.hopInterval') %></label>
                    <input type="text" id="hopInterval" name="hopInterval" value="<%= node?.hopInterval || '' %>" placeholder="30s">
                    <small><%- renderDocsIcon('portHopping') %><%= t('nodes.hopIntervalHint') %></small>
                </div>

                <div id="xrayPortConflictWarn" class="alert alert-error" style="display:none;">
                    <i class="ti ti-alert-triangle"></i>
                    <strong><%= t('nodes.portConflictTitle') %>:</strong>
                    <%= t('nodes.portConflictDesc') %>
                </div>

                <div class="form-group hysteria-only" id="domainGroup" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                    <label for="domain"><%= t('nodes.domain') %></label>
                    <input type="text" id="domain" name="domain" value="<%= node?.domain || '' %>"
                           placeholder="de.example.com" oninput="toggleAcmeByDomain()">
                    <small><%= t('nodes.domainHintHysteria') %></small>
                </div>

                <div class="form-group hysteria-only" id="acmeAdvancedToggleGroup" style="<%= node?.type === 'xray' || !node?.domain ? 'display:none' : '' %>">
                    <div class="section-subtitle"><%= t('nodes.sectionAcmeAdvanced') %> (<%= t('nodes.optionalSuffix') %>)</div>
                    <small class="section-hint"><%- renderDocsIcon('acme') %><%= t('nodes.sectionAcmeAdvancedHint') %></small>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="acmeEmail"><%= t('nodes.acmeEmail') %></label>
                            <input type="text" id="acmeEmail" name="acme.email" value="<%= node?.acme?.email || '' %>" placeholder="admin@example.com">
                        </div>
                        <div class="form-group">
                            <label for="acmeCa"><%= t('nodes.acmeCa') %></label>
                            <select id="acmeCa" name="acme.ca">
                                <option value="letsencrypt" <%= (node?.acme?.ca || 'letsencrypt') === 'letsencrypt' ? 'selected' : '' %>>Let's Encrypt</option>
                                <option value="zerossl" <%= node?.acme?.ca === 'zerossl' ? 'selected' : '' %>>ZeroSSL</option>
                            </select>
                        </div>
                    </div>
                    <label class="checkbox-label">
                        <input type="checkbox" id="acmeAdvancedEnabled" name="acme.advanced.enabled" <%= acmeAdvancedEnabled ? 'checked' : '' %> onchange="toggleAcmeAdvancedFields()">
                        <span class="checkbox-text"><%= t('nodes.enableOptionalSection') %></span>
                    </label>
                </div>

                <div class="hysteria-only optional-fields-wrap" id="acmeAdvancedFieldsWrap" style="<%= node?.type === 'xray' || !node?.domain || !acmeAdvancedEnabled ? 'display:none' : '' %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="acmeListenHost"><%= t('nodes.acmeListenHost') %></label>
                            <input type="text" id="acmeListenHost" name="acme.listenHost" value="<%= node?.acme?.listenHost || '0.0.0.0' %>" placeholder="0.0.0.0">
                        </div>
                        <div class="form-group">
                            <label for="acmeType"><%= t('nodes.acmeType') %></label>
                            <select id="acmeType" name="acme.type" onchange="toggleAcmeTypeFields()">
                                <option value="" <%= !node?.acme?.type ? 'selected' : '' %>><%= t('nodes.acmeTypeAuto') %></option>
                                <option value="http" <%= node?.acme?.type === 'http' ? 'selected' : '' %>>HTTP-01</option>
                                <option value="tls" <%= node?.acme?.type === 'tls' ? 'selected' : '' %>>TLS-ALPN-01</option>
                                <option value="dns" <%= node?.acme?.type === 'dns' ? 'selected' : '' %>>DNS-01</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row" id="acmeAltPortFields" style="<%= (node?.acme?.type === 'http' || node?.acme?.type === 'tls') ? '' : 'display:none' %>">
                        <div class="form-group <%= node?.acme?.type && node?.acme?.type !== 'http' ? 'is-inactive' : '' %>" id="acmeHttpFieldGroup">
                            <label for="acmeHttpAltPort"><%= t('nodes.acmeHttpAltPort') %></label>
                            <input type="number" id="acmeHttpAltPort" name="acme.httpAltPort" value="<%= node?.acme?.httpAltPort || '' %>" placeholder="8080" min="1" max="65535">
                        </div>
                        <div class="form-group <%= node?.acme?.type && node?.acme?.type !== 'tls' ? 'is-inactive' : '' %>" id="acmeTlsFieldGroup">
                            <label for="acmeTlsAltPort"><%= t('nodes.acmeTlsAltPort') %></label>
                            <input type="number" id="acmeTlsAltPort" name="acme.tlsAltPort" value="<%= node?.acme?.tlsAltPort || '' %>" placeholder="8443" min="1" max="65535">
                        </div>
                    </div>

                    <div id="acmeDnsFields" style="<%= node?.acme?.type === 'dns' ? '' : 'display:none' %>">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="acmeDnsName"><%= t('nodes.acmeDnsName') %></label>
                                <input type="text" id="acmeDnsName" name="acme.dns.name" value="<%= node?.acme?.dnsName || '' %>" placeholder="cloudflare">
                                <small><%- renderDocsIcon('acmeDnsConfig') %><%= t('nodes.acmeDnsProviderHint') %></small>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="acmeDnsConfig"><%= t('nodes.acmeDnsConfig') %></label>
                            <textarea id="acmeDnsConfig" name="acme.dns.config" rows="6" class="code-textarea" placeholder='{"cloudflare_api_token":"..."}'><%= node?.acme?.dnsConfig && Object.keys(node.acme.dnsConfig || {}).length ? JSON.stringify(node.acme.dnsConfig, null, 2) : '' %></textarea>
                            <small><%= t('nodes.acmeDnsConfigHint') %></small>
                        </div>
                    </div>
                </div>

                <div class="form-group hysteria-only" id="sniGroup" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                    <label for="sni">SNI</label>
                    <input type="text" id="sni" name="sni" value="<%= node?.sni || '' %>"
                           placeholder="bing.com">
                    <small><%= t('nodes.sniHintHysteria') %></small>
                </div>
            </div>

            <%# ========== 5. Hysteria: Stats API ========== %>
            <div class="form-section hysteria-only" id="hysteriaStatsSection" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                <h3><%= t('nodes.statsPort') %> API</h3>
                <small class="section-hint"><%- renderDocsIcon('stats') %><%= t('nodes.sectionStatsHint') %></small>
                <div class="form-row">
                    <div class="form-group">
                        <label for="statsPort"><%= t('nodes.statsPort') %></label>
                        <input type="number" id="statsPort" name="statsPort" value="<%= node?.statsPort || 9999 %>">
                    </div>
                    <div class="form-group">
                        <label for="statsSecret"><%= t('nodes.statsSecret') %></label>
                        <div class="input-with-button">
                            <input type="text" id="statsSecret" name="statsSecret" value="<%= node?.statsSecret || '' %>"
                                   placeholder="<%= node ? 'secret123' : 'Auto-generated if empty' %>">
                            <button type="button" class="btn btn-sm" onclick="generateSecret()" title="Generate random secret"><i class="ti ti-dice"></i></button>
                        </div>
                        <% if (!node) { %><small><%= t('nodes.statsSecretAutoHint') %></small><% } %>
                    </div>
                </div>
            </div>

            <%# ========== 6. Hysteria: Obfuscation ========== %>
            <div class="form-section hysteria-only" id="hysteriaObfsSection" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                <h3><%= t('nodes.sectionObfuscation') %></h3>
                <small class="section-hint"><%- renderDocsIcon('obfuscation') %><%= t('nodes.sectionObfuscationHint') %></small>
                <div class="form-row">
                    <div class="form-group">
                        <label for="obfsType"><%= t('nodes.obfsType') %></label>
                        <select id="obfsType" name="obfs.type" onchange="toggleObfsPassword()">
                            <option value="" <%= !node?.obfs?.type ? 'selected' : '' %>><%= t('nodes.off') %></option>
                            <option value="salamander" <%= node?.obfs?.type === 'salamander' ? 'selected' : '' %>>Salamander</option>
                        </select>
                    </div>
                    <div class="form-group" id="obfsPasswordGroup" style="<%= node?.obfs?.type === 'salamander' ? '' : 'display:none' %>">
                        <label for="obfsPassword"><%= t('nodes.obfsPassword') %></label>
                        <div class="input-with-button">
                            <input type="text" id="obfsPassword" name="obfs.password"
                                   value="<%= node?.obfs?.password || '' %>"
                                   placeholder="cry_me_a_r1ver">
                            <button type="button" class="btn btn-sm" onclick="generateObfsPassword()" title="Generate password"><i class="ti ti-dice"></i></button>
                        </div>
                        <small><%= t('nodes.obfsPasswordHint') %></small>
                    </div>
                </div>
            </div>

            <%# ========== 7. Hysteria: Masquerade ========== %>
            <div class="form-section hysteria-only" id="hysteriaMasqueradeSection" style="<%= node?.type === 'xray' ? 'display:none' : '' %>">
                <h3><%= t('nodes.sectionMasquerade') %></h3>
                <small class="section-hint"><%- renderDocsIcon('masquerade') %><%= t('nodes.sectionMasqueradeHint') %></small>

                <div class="form-group">
                    <label for="masqueradeType"><%= t('nodes.masqueradeType') %></label>
                    <select id="masqueradeType" name="masquerade.type" onchange="toggleMasqueradeType()">
                        <option value="proxy" <%= (node?.masquerade?.type || 'proxy') === 'proxy' ? 'selected' : '' %>>proxy</option>
                        <option value="string" <%= node?.masquerade?.type === 'string' ? 'selected' : '' %>>string</option>
                    </select>
                </div>

                <div id="masqueradeProxyFields" style="<%= (node?.masquerade?.type || 'proxy') === 'proxy' ? '' : 'display:none' %>">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="masqProxyUrl"><%= t('nodes.masqueradeProxyUrl') %></label>
                            <input type="text" id="masqProxyUrl" name="masquerade.proxy.url" value="<%= node?.masquerade?.proxy?.url || 'https://www.google.com' %>" placeholder="https://www.google.com">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="checkbox-label">
                                <input type="checkbox" name="masquerade.proxy.rewriteHost" <%= node?.masquerade?.proxy?.rewriteHost === false ? '' : 'checked' %>>
                                <span class="checkbox-text"><%= t('nodes.masqueradeProxyRewriteHost') %></span>
                            </label>
                        </div>
                        <div class="form-group">
                            <label class="checkbox-label">
                                <input type="checkbox" name="masquerade.proxy.insecure" <%= node?.masquerade?.proxy?.insecure ? 'checked' : '' %>>
                                <span class="checkbox-text"><%= t('nodes.masqueradeProxyInsecure') %></span>
                            </label>
                        </div>
                    </div>
                </div>

